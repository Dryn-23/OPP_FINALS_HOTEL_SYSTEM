    <Window x:Class="OOP_FINALS.HotelReservation.HotelReservation"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            Title="Johncis Lodge — Reservation System"
            Height="980" Width="1720"
            WindowStyle="None" ResizeMode="NoResize"
            WindowStartupLocation="CenterScreen"
            Background="Transparent" AllowsTransparency="True"
            MouseDown="Window_MouseDown"
            Loaded="Window_Loaded">

        <Window.Resources>

            <!-- ═══════════════════════════════ -->
            <!--  WARM BROWN PALETTE            -->
            <!-- ═══════════════════════════════ -->
            <SolidColorBrush x:Key="BgRoot"        Color="#0E0A07"/>
            <SolidColorBrush x:Key="BgPanel"       Color="#16100A"/>
            <SolidColorBrush x:Key="BgCard"        Color="#1F1610"/>
            <SolidColorBrush x:Key="BgInput"       Color="#2A1E14"/>
            <SolidColorBrush x:Key="BgHover"       Color="#301F12"/>
            <SolidColorBrush x:Key="Gold"          Color="#C9922A"/>
            <SolidColorBrush x:Key="GoldLight"     Color="#E8B04A"/>
            <SolidColorBrush x:Key="GoldDim"       Color="#6B4A10"/>
            <SolidColorBrush x:Key="Amber"         Color="#D97706"/>
            <SolidColorBrush x:Key="TextPrimary"   Color="#F5ECD8"/>
            <SolidColorBrush x:Key="TextSecondary" Color="#A0856A"/>
            <SolidColorBrush x:Key="TextMuted"     Color="#4A3828"/>
            <SolidColorBrush x:Key="DividerColor"  Color="#2A1E14"/>
            <SolidColorBrush x:Key="BorderSubtle"  Color="#2E2016"/>
            <SolidColorBrush x:Key="GreenOk"       Color="#22C55E"/>
            <SolidColorBrush x:Key="RedAlert"      Color="#EF4444"/>
            <SolidColorBrush x:Key="OrangeWarn"    Color="#F59E0B"/>
            <SolidColorBrush x:Key="BlueTint"      Color="#38BDF8"/>
            <SolidColorBrush x:Key="StepActive"    Color="#C9922A"/>
            <SolidColorBrush x:Key="StepDone"      Color="#6B4A10"/>
            <SolidColorBrush x:Key="StepIdle"      Color="#2A1E14"/>

            <!-- ═══════════════════════════════ -->
            <!--  FIELD LABEL                   -->
            <!-- ═══════════════════════════════ -->
            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="Foreground"  Value="#A0856A"/>
                <Setter Property="FontSize"    Value="10"/>
                <Setter Property="FontWeight"  Value="SemiBold"/>
                <Setter Property="Margin"      Value="0,10,0,4"/>
                <Setter Property="FontFamily"  Value="Segoe UI"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <!-- ═══════════════════════════════ -->
            <!--  INPUTS                        -->
            <!-- ═══════════════════════════════ -->
            <Style x:Key="InputStyle" TargetType="TextBox">
                <Setter Property="Background"              Value="#2A1E14"/>
                <Setter Property="Foreground"              Value="#F5ECD8"/>
                <Setter Property="CaretBrush"              Value="#C9922A"/>
                <Setter Property="BorderBrush"             Value="#3A2618"/>
                <Setter Property="BorderThickness"         Value="1"/>
                <Setter Property="FontSize"                Value="13"/>
                <Setter Property="FontFamily"              Value="Segoe UI"/>
                <Setter Property="Height"                  Value="40"/>
                <Setter Property="Padding"                 Value="12,0"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="bd" Property="BorderBrush" Value="#C9922A"/>
                                    <Setter TargetName="bd" Property="Background"  Value="#321F12"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="BorderBrush" Value="#6B4A10"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════ -->
            <!--  COMBOBOX                      -->
            <!-- ═══════════════════════════════ -->
            <Style x:Key="ComboStyle" TargetType="ComboBox">
                <Setter Property="Background"      Value="#2A1E14"/>
                <Setter Property="Foreground"      Value="#F5ECD8"/>
                <Setter Property="BorderBrush"     Value="#3A2618"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize"        Value="13"/>
                <Setter Property="FontFamily"      Value="Segoe UI"/>
                <Setter Property="Height"          Value="40"/>
                <Setter Property="Padding"         Value="10,0"/>
            </Style>

            <!-- ═══════════════════════════════ -->
            <!--  DATEPICKER                    -->
            <!-- ═══════════════════════════════ -->
            <Style x:Key="DateStyle" TargetType="DatePicker">
                <Setter Property="Background"      Value="#2A1E14"/>
                <Setter Property="Foreground"      Value="#F5ECD8"/>
                <Setter Property="BorderBrush"     Value="#3A2618"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize"        Value="13"/>
                <Setter Property="FontFamily"      Value="Segoe UI"/>
                <Setter Property="Height"          Value="40"/>
            </Style>

            <!-- ═══════════════════════════════ -->
            <!--  PRIMARY BUTTON (GOLD)         -->
            <!-- ═══════════════════════════════ -->
            <Style x:Key="BtnPrimary" TargetType="Button">
                <Setter Property="Background"  Value="#C9922A"/>
                <Setter Property="Foreground"  Value="#0E0A07"/>
                <Setter Property="FontWeight"  Value="Bold"/>
                <Setter Property="FontSize"    Value="13"/>
                <Setter Property="FontFamily"  Value="Segoe UI"/>
                <Setter Property="Height"      Value="44"/>
                <Setter Property="Cursor"      Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" CornerRadius="10"
                                    Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#E8B04A"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#A07020"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════ -->
            <!--  SECONDARY BUTTON              -->
            <!-- ═══════════════════════════════ -->
            <Style x:Key="BtnSecondary" TargetType="Button">
                <Setter Property="Background"  Value="#2A1E14"/>
                <Setter Property="Foreground"  Value="#C9922A"/>
                <Setter Property="FontWeight"  Value="SemiBold"/>
                <Setter Property="FontSize"    Value="12"/>
                <Setter Property="FontFamily"  Value="Segoe UI"/>
                <Setter Property="Height"      Value="38"/>
                <Setter Property="Cursor"      Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" CornerRadius="8"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#C9922A" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#301F12"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════ -->
            <!--  DANGER BUTTON                 -->
            <!-- ═══════════════════════════════ -->
            <Style x:Key="BtnDanger" TargetType="Button">
                <Setter Property="Background"  Value="#2A1010"/>
                <Setter Property="Foreground"  Value="#EF4444"/>
                <Setter Property="FontWeight"  Value="SemiBold"/>
                <Setter Property="FontSize"    Value="12"/>
                <Setter Property="FontFamily"  Value="Segoe UI"/>
                <Setter Property="Height"      Value="38"/>
                <Setter Property="Cursor"      Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" CornerRadius="8"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#EF4444" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#3A1515"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- GHOST NAV BUTTON -->
            <Style x:Key="NavBtn" TargetType="Button">
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="Foreground"      Value="#A0856A"/>
                <Setter Property="FontSize"        Value="12"/>
                <Setter Property="FontFamily"      Value="Segoe UI"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Height"          Value="40"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" CornerRadius="8" Background="{TemplateBinding Background}" Padding="14,0">
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#2A1E14"/>
                                    <Setter Property="Foreground" Value="#C9922A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- STAT LABEL/VALUE -->
            <Style x:Key="StatLbl" TargetType="TextBlock">
                <Setter Property="Foreground"  Value="#A0856A"/>
                <Setter Property="FontSize"    Value="10"/>
                <Setter Property="FontWeight"  Value="SemiBold"/>
                <Setter Property="FontFamily"  Value="Segoe UI"/>
                <Setter Property="Margin"      Value="0,0,0,2"/>
            </Style>
            <Style x:Key="StatVal" TargetType="TextBlock">
                <Setter Property="Foreground"  Value="#F5ECD8"/>
                <Setter Property="FontSize"    Value="28"/>
                <Setter Property="FontWeight"  Value="Bold"/>
                <Setter Property="FontFamily"  Value="Segoe UI"/>
                <Setter Property="Margin"      Value="0,0,0,0"/>
            </Style>

            <!-- SECTION HEADER -->
            <Style x:Key="CardTitle" TargetType="TextBlock">
                <Setter Property="Foreground"  Value="#F5ECD8"/>
                <Setter Property="FontSize"    Value="13"/>
                <Setter Property="FontWeight"  Value="Bold"/>
                <Setter Property="FontFamily"  Value="Segoe UI"/>
                <Setter Property="Margin"      Value="0,0,0,14"/>
            </Style>

            <!-- STEP CIRCLE ACTIVE -->
            <Style x:Key="StepCircleActive" TargetType="Border">
                <Setter Property="Width"           Value="30"/>
                <Setter Property="Height"          Value="30"/>
                <Setter Property="CornerRadius"    Value="15"/>
                <Setter Property="Background"      Value="#C9922A"/>
            </Style>
            <Style x:Key="StepCircleIdle" TargetType="Border">
                <Setter Property="Width"           Value="30"/>
                <Setter Property="Height"          Value="30"/>
                <Setter Property="CornerRadius"    Value="15"/>
                <Setter Property="Background"      Value="#2A1E14"/>
                <Setter Property="BorderBrush"     Value="#3A2618"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>
            <Style x:Key="StepCircleDone" TargetType="Border">
                <Setter Property="Width"           Value="30"/>
                <Setter Property="Height"          Value="30"/>
                <Setter Property="CornerRadius"    Value="15"/>
                <Setter Property="Background"      Value="#3A2208"/>
                <Setter Property="BorderBrush"     Value="#6B4A10"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

        </Window.Resources>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- ROOT                                                    -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border CornerRadius="16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0E0A07" Offset="0"/>
                    <GradientStop Color="#16100A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="50" ShadowDepth="0" Opacity="0.95"/>
            </Border.Effect>

            <Border CornerRadius="16" BorderThickness="1">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#C9922A" Offset="0"/>
                        <GradientStop Color="#3A2208" Offset="0.5"/>
                        <GradientStop Color="#C9922A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <!-- Sidebar -->
                        <ColumnDefinition Width="*"/>
                        <!-- Main Area -->
                    </Grid.ColumnDefinitions>

                    <!-- ═══════════════════════════════════════════ -->
                    <!-- SIDEBAR                                     -->
                    <!-- ═══════════════════════════════════════════ -->
                    <Border Grid.Column="0" CornerRadius="16,0,0,16"
                            Background="#0A0703"
                            BorderBrush="#1E1206" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Logo -->
                            <StackPanel Grid.Row="0" Margin="20,24,20,20">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="36" Height="36" CornerRadius="10" Background="#C9922A">
                                        <TextBlock Text="🏨" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Margin="10,0,0,0">
                                        <TextBlock Text="JOHNCIS" Foreground="#C9922A" FontSize="14" FontWeight="Bold" FontFamily="Segoe UI"/>
                                        <TextBlock Text="LODGE" Foreground="#6B4A10" FontSize="10" FontFamily="Segoe UI" Margin="0,-2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Height="1" Background="#1E1206" Margin="0,16,0,0"/>
                            </StackPanel>

                            <!-- Nav -->
                            <StackPanel Grid.Row="1" Margin="12,0">
                                <TextBlock Text="RESERVATION" Foreground="#4A3828" FontSize="9" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="14,0,0,8"/>
                                <Button x:Name="btnNavNewBooking" Content="  ＋  New Booking"
                                        Style="{StaticResource NavBtn}"
                                        Click="NavNewBooking_Click"/>
                                <Button x:Name="btnNavRoomMap" Content="  🗺  Room Map"
                                        Style="{StaticResource NavBtn}"
                                        Click="NavRoomMap_Click"/>
                                <Button x:Name="btnNavBookings" Content="  📋  Active Bookings"
                                        Style="{StaticResource NavBtn}"
                                        Click="NavBookings_Click"/>

                                <Border Height="1" Background="#1E1206" Margin="14,12"/>

                                <TextBlock Text="OPERATIONS" Foreground="#4A3828" FontSize="9" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="14,0,0,8"/>
                                <Button Content="  🔍  Search Reservation"
                                        Style="{StaticResource NavBtn}"
                                        Click="BtnSearchReservation_Click"/>
                                <Button Content="  ✔  Check-Out Guest"
                                        Style="{StaticResource NavBtn}"
                                        Click="BtnCheckOut_Click"/>
                                <Button Content="  🧹  Housekeeping Log"
                                        Style="{StaticResource NavBtn}"
                                        Click="BtnHousekeeping_Click"/>
                                <Button Content="  🗑  Cancel Reservation"
                                        Style="{StaticResource NavBtn}"
                                        Foreground="#EF4444"
                                        Click="BtnCancel_Click"/>

                                <Border Height="1" Background="#1E1206" Margin="14,12"/>

                                <TextBlock Text="STATS" Foreground="#4A3828" FontSize="9" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="14,0,0,8"/>
                                <!-- Mini stat cards in sidebar -->
                                <Border Background="#1F1610" CornerRadius="10" Padding="14,10" Margin="2,2,2,4">
                                    <Grid>
                                        <TextBlock Text="OCCUPIED" Style="{StaticResource StatLbl}"/>
                                        <TextBlock x:Name="lblOccupied" HorizontalAlignment="Right"
                                                   Foreground="#EF4444" FontSize="20" FontWeight="Bold" FontFamily="Segoe UI" Text="—"/>
                                    </Grid>
                                </Border>
                                <Border Background="#1F1610" CornerRadius="10" Padding="14,10" Margin="2,2,2,4">
                                    <Grid>
                                        <TextBlock Text="AVAILABLE" Style="{StaticResource StatLbl}"/>
                                        <TextBlock x:Name="lblAvailable" HorizontalAlignment="Right"
                                                   Foreground="#22C55E" FontSize="20" FontWeight="Bold" FontFamily="Segoe UI" Text="—"/>
                                    </Grid>
                                </Border>
                                <Border Background="#1F1610" CornerRadius="10" Padding="14,10" Margin="2,2,2,4">
                                    <Grid>
                                        <TextBlock Text="ARRIVALS TODAY" Style="{StaticResource StatLbl}"/>
                                        <TextBlock x:Name="lblArrivals" HorizontalAlignment="Right"
                                                   Foreground="#F59E0B" FontSize="20" FontWeight="Bold" FontFamily="Segoe UI" Text="—"/>
                                    </Grid>
                                </Border>
                                <Border Background="#1F1610" CornerRadius="10" Padding="14,10" Margin="2,2,2,0">
                                    <Grid>
                                        <TextBlock Text="TODAY'S REVENUE" Style="{StaticResource StatLbl}"/>
                                        <TextBlock x:Name="lblRevenue" HorizontalAlignment="Right"
                                                   Foreground="#22C55E" FontSize="13" FontWeight="Bold" FontFamily="Segoe UI" Text="—"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!-- Staff Footer -->
                            <Border Grid.Row="2" BorderBrush="#1E1206" BorderThickness="0,1,0,0" Padding="16,12">
                                <StackPanel>
                                    <TextBlock x:Name="lblClock" Foreground="#4A3828" FontSize="10" FontFamily="Segoe UI" TextAlignment="Center"/>
                                    <Border Height="1" Background="#1E1206" Margin="0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="30" Height="30" CornerRadius="15" Background="#2A1E14">
                                            <TextBlock Text="👤" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock x:Name="lblStaffName" Text="Staff" Foreground="#F5ECD8" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                            <TextBlock x:Name="lblStaffRole" Text="Front Desk" Foreground="#6B4A10" FontSize="10" FontFamily="Segoe UI"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ═══════════════════════════════════════════ -->
                    <!-- MAIN CONTENT AREA                          -->
                    <!-- ═══════════════════════════════════════════ -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50"/>
                            <!-- Top bar -->
                            <RowDefinition Height="*"/>
                            <!-- Content -->
                        </Grid.RowDefinitions>

                        <!-- TOP BAR -->
                        <Border Grid.Row="0" Background="#0A0703"
                                CornerRadius="0,16,0,0"
                                BorderBrush="#1E1206" BorderThickness="0,0,0,1">
                            <Grid Margin="20,0">
                                <TextBlock x:Name="lblPageTitle"
                                           Text="New Reservation"
                                           Foreground="#C9922A"
                                           FontSize="14" FontWeight="SemiBold"
                                           FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
                                    <Button Content="—" Width="34" Height="28"
                                            Foreground="#6B4A10" Background="Transparent"
                                            BorderThickness="0" Cursor="Hand"
                                            Click="BtnMinimize_Click" FontFamily="Segoe UI"/>
                                    <Button Content="✕" Width="34" Height="28"
                                            Foreground="#6B4A10" Background="Transparent"
                                            BorderThickness="0" Cursor="Hand"
                                            Click="BtnClose_Click" FontFamily="Segoe UI"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ═══════════════════════════════════════ -->
                        <!-- PANELS (TabControl-like, code-switched) -->
                        <!-- ═══════════════════════════════════════ -->
                        <Grid Grid.Row="1" Margin="16,12,16,12">

                            <!-- ════════════════════════════════════ -->
                            <!-- PANEL A: NEW BOOKING (multi-step)   -->
                            <!-- ════════════════════════════════════ -->
                            <Grid x:Name="panelNewBooking">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="300"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left: Step Cards -->
                                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,10,0">
                                    <StackPanel>

                                        <!-- ── STEP PROGRESS BAR ── -->
                                        <Border Background="#1F1610" CornerRadius="14" Padding="20,16" Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Step 1 -->
                                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                    <Border x:Name="step1Circle" Style="{StaticResource StepCircleActive}" HorizontalAlignment="Center">
                                                        <TextBlock Text="1" Foreground="#0E0A07" FontWeight="Bold" FontSize="13"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                                    </Border>
                                                    <TextBlock x:Name="step1Lbl" Text="Guest Info" Foreground="#C9922A" FontSize="10"
                                                               HorizontalAlignment="Center" Margin="0,4,0,0" FontFamily="Segoe UI"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" Height="2" Background="#2A1E14" VerticalAlignment="Center"/>

                                                <!-- Step 2 -->
                                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                    <Border x:Name="step2Circle" Style="{StaticResource StepCircleIdle}" HorizontalAlignment="Center">
                                                        <TextBlock Text="2" Foreground="#6B4A10" FontWeight="Bold" FontSize="13"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                                    </Border>
                                                    <TextBlock x:Name="step2Lbl" Text="Reservation" Foreground="#6B4A10" FontSize="10"
                                                               HorizontalAlignment="Center" Margin="0,4,0,0" FontFamily="Segoe UI"/>
                                                </StackPanel>
                                                <Border Grid.Column="3" Height="2" Background="#2A1E14" VerticalAlignment="Center"/>

                                                <!-- Step 3 -->
                                                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                                    <Border x:Name="step3Circle" Style="{StaticResource StepCircleIdle}" HorizontalAlignment="Center">
                                                        <TextBlock Text="3" Foreground="#6B4A10" FontWeight="Bold" FontSize="13"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                                    </Border>
                                                    <TextBlock x:Name="step3Lbl" Text="Billing" Foreground="#6B4A10" FontSize="10"
                                                               HorizontalAlignment="Center" Margin="0,4,0,0" FontFamily="Segoe UI"/>
                                                </StackPanel>
                                                <Border Grid.Column="5" Height="2" Background="#2A1E14" VerticalAlignment="Center"/>

                                                <!-- Step 4 -->
                                                <StackPanel Grid.Column="6" HorizontalAlignment="Center">
                                                    <Border x:Name="step4Circle" Style="{StaticResource StepCircleIdle}" HorizontalAlignment="Center">
                                                        <TextBlock Text="4" Foreground="#6B4A10" FontWeight="Bold" FontSize="13"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                                    </Border>
                                                    <TextBlock x:Name="step4Lbl" Text="Payment" Foreground="#6B4A10" FontSize="10"
                                                               HorizontalAlignment="Center" Margin="0,4,0,0" FontFamily="Segoe UI"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- ════════════════════════ -->
                                        <!-- CARD 1: CUSTOMER INFO   -->
                                        <!-- ════════════════════════ -->
                                        <Border x:Name="cardGuest" Background="#1F1610" CornerRadius="14"
                                                BorderBrush="#C9922A" BorderThickness="1,1,1,1"
                                                Padding="22,18" Margin="0,0,0,10">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                                    <Border Width="32" Height="32" CornerRadius="8" Background="#2A1E14">
                                                        <TextBlock Text="👤" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="GUEST INFORMATION" Foreground="#C9922A"
                                                                   FontSize="11" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                        <TextBlock Text="Customer identity and contact details"
                                                                   Foreground="#6B4A10" FontSize="10" FontFamily="Segoe UI"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="FIRST NAME" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox x:Name="txtFirstName" Style="{StaticResource InputStyle}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="LAST NAME" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox x:Name="txtLastName" Style="{StaticResource InputStyle}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Margin="0,4,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="CONTACT NUMBER" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox x:Name="txtContactNumber" Style="{StaticResource InputStyle}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="EMAIL ADDRESS" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox x:Name="txtEmail" Style="{StaticResource InputStyle}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Margin="0,4,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="VALID ID TYPE" Style="{StaticResource FieldLabel}"/>
                                                        <ComboBox x:Name="cmbIDType" Style="{StaticResource ComboStyle}">
                                                            <ComboBoxItem Content="Passport"/>
                                                            <ComboBoxItem Content="Driver's License"/>
                                                            <ComboBoxItem Content="SSS ID"/>
                                                            <ComboBoxItem Content="PhilHealth ID"/>
                                                            <ComboBoxItem Content="Voter's ID"/>
                                                            <ComboBoxItem Content="National ID"/>
                                                        </ComboBox>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="ID NUMBER" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox x:Name="txtIDNumber" Style="{StaticResource InputStyle}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- ════════════════════════ -->
                                        <!-- CARD 2: RESERVATION     -->
                                        <!-- ════════════════════════ -->
                                        <Border x:Name="cardReservation" Background="#1F1610" CornerRadius="14"
                                                BorderBrush="#2A1E14" BorderThickness="1"
                                                Padding="22,18" Margin="0,0,0,10">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                                    <Border Width="32" Height="32" CornerRadius="8" Background="#2A1E14">
                                                        <TextBlock Text="🛏️" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="RESERVATION DETAILS" Foreground="#C9922A"
                                                                   FontSize="11" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                        <TextBlock Text="Room, dates, and number of guests"
                                                                   Foreground="#6B4A10" FontSize="10" FontFamily="Segoe UI"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <TextBlock Text="ROOM SELECTION" Style="{StaticResource FieldLabel}"/>
                                                <ComboBox x:Name="cmbRoom" Style="{StaticResource ComboStyle}"
                                                          SelectionChanged="CmbRoom_SelectionChanged"/>

                                                <Grid Margin="0,4,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="CHECK-IN DATE" Style="{StaticResource FieldLabel}"/>
                                                        <DatePicker x:Name="dpCheckIn" Style="{StaticResource DateStyle}"
                                                                    SelectedDateChanged="DatePicker_Changed"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="CHECK-OUT DATE" Style="{StaticResource FieldLabel}"/>
                                                        <DatePicker x:Name="dpCheckOut" Style="{StaticResource DateStyle}"
                                                                    SelectedDateChanged="DatePicker_Changed"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="NO. OF GUESTS" Style="{StaticResource FieldLabel}"/>
                                                        <ComboBox x:Name="cmbGuests" Style="{StaticResource ComboStyle}">
                                                            <ComboBoxItem Content="1"/>
                                                            <ComboBoxItem Content="2"/>
                                                            <ComboBoxItem Content="3"/>
                                                            <ComboBoxItem Content="4"/>
                                                            <ComboBoxItem Content="5"/>
                                                            <ComboBoxItem Content="6"/>
                                                        </ComboBox>
                                                    </StackPanel>
                                                </Grid>

                                                <TextBlock Text="PROCESSED BY (STAFF)" Style="{StaticResource FieldLabel}"/>
                                                <ComboBox x:Name="cmbStaff" Style="{StaticResource ComboStyle}"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- ════════════════════════ -->
                                        <!-- CARD 3: BILLING DETAILS -->
                                        <!-- ════════════════════════ -->
                                        <Border x:Name="cardBilling" Background="#1F1610" CornerRadius="14"
                                                BorderBrush="#2A1E14" BorderThickness="1"
                                                Padding="22,18" Margin="0,0,0,10">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                                    <Border Width="32" Height="32" CornerRadius="8" Background="#2A1E14">
                                                        <TextBlock Text="🧾" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="BILLING SUMMARY" Foreground="#C9922A"
                                                                   FontSize="11" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                        <TextBlock Text="Charges, taxes, and discounts"
                                                                   Foreground="#6B4A10" FontSize="10" FontFamily="Segoe UI"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Billing breakdown grid -->
                                                <Border Background="#16100A" CornerRadius="10" Padding="16,12">
                                                    <StackPanel>
                                                        <Grid Margin="0,0,0,8">
                                                            <TextBlock Text="Room Rate / Night" Foreground="#A0856A" FontSize="12" FontFamily="Segoe UI"/>
                                                            <TextBlock x:Name="lblRoomRate" HorizontalAlignment="Right"
                                                                       Foreground="#C9922A" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                                        </Grid>
                                                        <Grid Margin="0,0,0,8">
                                                            <TextBlock Text="Number of Nights" Foreground="#A0856A" FontSize="12" FontFamily="Segoe UI"/>
                                                            <TextBlock x:Name="lblNights" HorizontalAlignment="Right"
                                                                       Foreground="#F5ECD8" FontSize="12" FontFamily="Segoe UI"/>
                                                        </Grid>
                                                        <Grid Margin="0,0,0,8">
                                                            <TextBlock Text="Subtotal" Foreground="#A0856A" FontSize="12" FontFamily="Segoe UI"/>
                                                            <TextBlock x:Name="lblSubtotal" HorizontalAlignment="Right"
                                                                       Foreground="#F5ECD8" FontSize="12" FontFamily="Segoe UI"/>
                                                        </Grid>
                                                        <Grid Margin="0,0,0,8">
                                                            <TextBlock Text="Tax (12%)" Foreground="#A0856A" FontSize="12" FontFamily="Segoe UI"/>
                                                            <TextBlock x:Name="lblTax" HorizontalAlignment="Right"
                                                                       Foreground="#F5ECD8" FontSize="12" FontFamily="Segoe UI"/>
                                                        </Grid>

                                                        <!-- Discount row -->
                                                        <Grid Margin="0,0,0,4">
                                                            <TextBlock Text="DISCOUNT AMOUNT (₱)" Style="{StaticResource FieldLabel}" Margin="0,4,0,4"/>
                                                        </Grid>
                                                        <TextBox x:Name="txtDiscount" Style="{StaticResource InputStyle}"
                                                                 Height="36" Text="0"
                                                                 TextChanged="Discount_Changed"/>

                                                        <Border Height="1" Background="#2A1E14" Margin="0,10"/>

                                                        <Grid>
                                                            <TextBlock Text="FINAL TOTAL" Foreground="#F5ECD8"
                                                                       FontSize="14" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                            <TextBlock x:Name="lblTotal" HorizontalAlignment="Right"
                                                                       Foreground="#22C55E" FontSize="16"
                                                                       FontWeight="Bold" FontFamily="Segoe UI"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Extra billing items -->
                                                <TextBlock Text="ADDITIONAL CHARGES" Style="{StaticResource FieldLabel}"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="txtItemDesc" Style="{StaticResource InputStyle}" Height="36"
                                                             Grid.Column="0" Tag="Description"/>
                                                    <TextBox x:Name="txtItemQty" Style="{StaticResource InputStyle}" Height="36"
                                                             Grid.Column="2" Tag="Qty"/>
                                                    <TextBox x:Name="txtItemPrice" Style="{StaticResource InputStyle}" Height="36"
                                                             Grid.Column="4" Tag="Unit Price"/>
                                                    <Button Grid.Column="6" Content="+ Add"
                                                            Style="{StaticResource BtnSecondary}"
                                                            Height="36"
                                                            Click="AddBillingItem_Click"/>
                                                </Grid>
                                                <ListView x:Name="lvBillingItems" Background="Transparent" BorderThickness="0"
                                                          Foreground="#F5ECD8" FontFamily="Segoe UI" FontSize="12"
                                                          MaxHeight="100" Margin="0,6,0,0">
                                                    <ListView.View>
                                                        <GridView>
                                                            <GridViewColumn Header="Description" Width="200" DisplayMemberBinding="{Binding Description}"/>
                                                            <GridViewColumn Header="Qty"         Width="50"  DisplayMemberBinding="{Binding Quantity}"/>
                                                            <GridViewColumn Header="Unit Price"  Width="100" DisplayMemberBinding="{Binding UnitPrice}"/>
                                                            <GridViewColumn Header="Subtotal"    Width="100" DisplayMemberBinding="{Binding Subtotal}"/>
                                                        </GridView>
                                                    </ListView.View>
                                                </ListView>
                                            </StackPanel>
                                        </Border>

                                        <!-- ════════════════════════ -->
                                        <!-- CARD 4: PAYMENT         -->
                                        <!-- ════════════════════════ -->
                                        <Border x:Name="cardPayment" Background="#1F1610" CornerRadius="14"
                                                BorderBrush="#2A1E14" BorderThickness="1"
                                                Padding="22,18" Margin="0,0,0,10">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                                    <Border Width="32" Height="32" CornerRadius="8" Background="#2A1E14">
                                                        <TextBlock Text="💳" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="PAYMENT DETAILS" Foreground="#C9922A"
                                                                   FontSize="11" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                        <TextBlock Text="How the guest is settling their bill"
                                                                   Foreground="#6B4A10" FontSize="10" FontFamily="Segoe UI"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="PAYMENT METHOD" Style="{StaticResource FieldLabel}"/>
                                                        <ComboBox x:Name="cmbPaymentMethod" Style="{StaticResource ComboStyle}">
                                                            <ComboBoxItem Content="Cash"/>
                                                            <ComboBoxItem Content="Credit Card"/>
                                                            <ComboBoxItem Content="Debit Card"/>
                                                            <ComboBoxItem Content="GCash"/>
                                                            <ComboBoxItem Content="Maya"/>
                                                            <ComboBoxItem Content="Bank Transfer"/>
                                                        </ComboBox>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="REFERENCE NUMBER" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox x:Name="txtPaymentRef" Style="{StaticResource InputStyle}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Margin="0,4,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="AMOUNT PAID (₱)" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox x:Name="txtAmountPaid" Style="{StaticResource InputStyle}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="PAYMENT STATUS" Style="{StaticResource FieldLabel}"/>
                                                        <Border Background="#16100A" CornerRadius="8" Padding="12,10" BorderBrush="#3A2618" BorderThickness="1">
                                                            <TextBlock x:Name="lblPaymentStatus" Text="Pending — enter amount above"
                                                                       Foreground="#F59E0B" FontSize="12" FontFamily="Segoe UI"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- ACTION BUTTONS -->
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="160"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="✕  Clear Form"
                                                    Style="{StaticResource BtnSecondary}"
                                                    Height="44"
                                                    Click="BtnClear_Click"/>
                                            <Button Grid.Column="2" Content="✔  CONFIRM BOOKING"
                                                    Style="{StaticResource BtnPrimary}"
                                                    Click="BtnBook_Click"/>
                                        </Grid>

                                    </StackPanel>
                                </ScrollViewer>

                                <!-- Right: Room Map Preview -->
                                <Border Grid.Column="1" Background="#1F1610" CornerRadius="14"
                                        BorderBrush="#2A1E14" BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Margin="16,14,16,8">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <TextBlock Text="🗺  ROOM MAP" Foreground="#C9922A"
                                                           FontSize="11" FontWeight="Bold" FontFamily="Segoe UI"
                                                           VerticalAlignment="Center"/>
                                                <Button Content="↺" Width="28" Height="28" Margin="8,0,0,0"
                                                        Style="{StaticResource BtnSecondary}"
                                                        Click="BtnRefresh_Click"/>
                                            </StackPanel>
                                            <!-- Legend -->
                                            <WrapPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,10,4">
                                                    <Ellipse Width="8" Height="8" Fill="#22C55E" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Available" Foreground="#6B4A10" FontSize="10" Margin="4,0,0,0" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,10,4">
                                                    <Ellipse Width="8" Height="8" Fill="#EF4444" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Occupied" Foreground="#6B4A10" FontSize="10" Margin="4,0,0,0" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,10,4">
                                                    <Ellipse Width="8" Height="8" Fill="#F59E0B" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Cleaning" Foreground="#6B4A10" FontSize="10" Margin="4,0,0,0" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <Ellipse Width="8" Height="8" Fill="#555555" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Maint." Foreground="#6B4A10" FontSize="10" Margin="4,0,0,0" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </WrapPanel>
                                        </StackPanel>

                                        <Border Grid.Row="1" Height="1" Background="#2A1E14"/>

                                        <ScrollViewer Grid.Row="2" Margin="10,10,10,10"
                                                      VerticalScrollBarVisibility="Auto">
                                            <ItemsControl x:Name="icRooms">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Width="118" Height="90" CornerRadius="10" Margin="4"
                                                                Cursor="Hand"
                                                                BorderThickness="1"
                                                                BorderBrush="{Binding BorderColor}"
                                                                Background="{Binding BackgroundColor}">
                                                            <Border.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick"
                                                                              Command="{Binding RoomClickCommand}"/>
                                                            </Border.InputBindings>
                                                            <Grid>
                                                                <Border CornerRadius="10,10,0,0" Height="4"
                                                                        VerticalAlignment="Top"
                                                                        Background="{Binding StatusColor}"/>
                                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,4,0,0">
                                                                    <TextBlock Text="{Binding RoomNumber}"
                                                                               Foreground="#F5ECD8" FontSize="18" FontWeight="Bold"
                                                                               FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding TypeName}"
                                                                               Foreground="#A0856A" FontSize="9"
                                                                               FontFamily="Segoe UI" HorizontalAlignment="Center"
                                                                               TextWrapping="Wrap" TextAlignment="Center" MaxWidth="100"/>
                                                                    <Border CornerRadius="4" Padding="5,2" Margin="0,4,0,0"
                                                                            Background="{Binding StatusBadgeBg}">
                                                                        <TextBlock Text="{Binding Status}"
                                                                                   Foreground="{Binding StatusColor}"
                                                                                   FontSize="9" FontWeight="Bold"
                                                                                   FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                                                                    </Border>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- ════════════════════════════════════ -->
                            <!-- PANEL B: ACTIVE BOOKINGS TABLE      -->
                            <!-- ════════════════════════════════════ -->
                            <Grid x:Name="panelBookings" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Search bar -->
                                <Border Grid.Row="0" Background="#1F1610" CornerRadius="12"
                                        BorderBrush="#2A1E14" BorderThickness="1" Padding="16,12" Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔎" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBox x:Name="txtSearch"
                                                 Style="{StaticResource InputStyle}"
                                                 Width="300" Height="36"
                                                 TextChanged="TxtSearch_TextChanged"/>
                                        <TextBlock Text="Search by guest name, reservation ID, or room"
                                                   Foreground="#4A3828" FontSize="11" FontFamily="Segoe UI"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Column headers -->
                                <Border Grid.Row="1" Background="#16100A" CornerRadius="8"
                                        Padding="10,8" Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="RES. ID"   Foreground="#6B4A10" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                        <TextBlock Grid.Column="1" Text="GUEST"     Foreground="#6B4A10" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                        <TextBlock Grid.Column="2" Text="ROOM"      Foreground="#6B4A10" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                        <TextBlock Grid.Column="3" Text="TYPE"      Foreground="#6B4A10" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                        <TextBlock Grid.Column="4" Text="CHECK-IN"  Foreground="#6B4A10" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                        <TextBlock Grid.Column="5" Text="CHECK-OUT" Foreground="#6B4A10" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                        <TextBlock Grid.Column="6" Text="GUESTS"    Foreground="#6B4A10" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                        <TextBlock Grid.Column="7" Text="TOTAL"     Foreground="#6B4A10" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                        <TextBlock Grid.Column="8" Text="STATUS"    Foreground="#6B4A10" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                        <TextBlock Grid.Column="9" Text="PAYMENT"   Foreground="#6B4A10" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                    </Grid>
                                </Border>

                                <ListView x:Name="lvBookings" Grid.Row="2"
                                          Background="Transparent" BorderThickness="0"
                                          Foreground="#F5ECD8" FontFamily="Segoe UI" FontSize="12"
                                          SelectionChanged="LvBookings_SelectionChanged">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="" Width="70"   DisplayMemberBinding="{Binding ReservationID}"/>
                                            <GridViewColumn Header="" Width="160"  DisplayMemberBinding="{Binding GuestName}"/>
                                            <GridViewColumn Header="" Width="70"   DisplayMemberBinding="{Binding RoomNumber}"/>
                                            <GridViewColumn Header="" Width="130"  DisplayMemberBinding="{Binding RoomType}"/>
                                            <GridViewColumn Header="" Width="100"  DisplayMemberBinding="{Binding CheckIn}"/>
                                            <GridViewColumn Header="" Width="100"  DisplayMemberBinding="{Binding CheckOut}"/>
                                            <GridViewColumn Header="" Width="60"   DisplayMemberBinding="{Binding Guests}"/>
                                            <GridViewColumn Header="" Width="110"  DisplayMemberBinding="{Binding Total}"/>
                                            <GridViewColumn Header="" Width="100"  DisplayMemberBinding="{Binding Status}"/>
                                            <GridViewColumn Header="" Width="100"  DisplayMemberBinding="{Binding PaymentStatus}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Grid>

                            <!-- ════════════════════════════════════ -->
                            <!-- PANEL C: ROOM MAP (standalone)      -->
                            <!-- ════════════════════════════════════ -->
                            <Grid x:Name="panelRoomMap" Visibility="Collapsed">
                                <Border Background="#1F1610" CornerRadius="14"
                                        BorderBrush="#2A1E14" BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0" Margin="20,14,20,12">
                                            <TextBlock Text="🗺  FULL ROOM MAP" Foreground="#C9922A"
                                                       FontSize="13" FontWeight="Bold" FontFamily="Segoe UI"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Content="⟳  Refresh" HorizontalAlignment="Right"
                                                    Style="{StaticResource BtnSecondary}" Width="100"
                                                    Click="BtnRefresh_Click"/>
                                        </Grid>
                                        <ScrollViewer Grid.Row="1" Margin="14,0,14,14"
                                                      VerticalScrollBarVisibility="Auto">
                                            <ItemsControl x:Name="icRoomsLarge">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Width="140" Height="110" CornerRadius="12" Margin="6"
                                                                Cursor="Hand" BorderThickness="1"
                                                                BorderBrush="{Binding BorderColor}"
                                                                Background="{Binding BackgroundColor}">
                                                            <Border.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick" Command="{Binding RoomClickCommand}"/>
                                                            </Border.InputBindings>
                                                            <Grid>
                                                                <Border CornerRadius="12,12,0,0" Height="5"
                                                                        VerticalAlignment="Top" Background="{Binding StatusColor}"/>
                                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,6,0,0">
                                                                    <TextBlock Text="{Binding RoomNumber}"
                                                                               Foreground="#F5ECD8" FontSize="22" FontWeight="Bold"
                                                                               FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding TypeName}"
                                                                               Foreground="#A0856A" FontSize="10"
                                                                               FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding PriceDisplay}"
