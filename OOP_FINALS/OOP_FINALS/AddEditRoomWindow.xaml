<Window x:Class="OOP_FINALS.AddEditRoomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Room"
        Height="300" Width="400">

    <StackPanel Margin="20">

        <TextBlock Text="Room Number" Foreground="Black"/>
        <TextBox x:Name="RoomNumberBox"/>

        <TextBlock Text="Status" Margin="0,10,0,0"/>
        <TextBox x:Name="StatusBox"/>

        <Button Content="Save"
                Click="Save_Click"
                Margin="0,20,0,0"/>

    </StackPanel>
</Window>