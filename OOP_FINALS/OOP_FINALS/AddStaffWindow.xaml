<Window x:Class="OOP_FINALS.AddStaffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Staff"
        Width="1400" Height="950"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize">

    <!-- [Previous animations and styles remain the same - I'll include only the key parts] -->
    <Window.Resources>
        <!-- ERROR INPUT STYLE -->
        <Style x:Key="ErrorInput" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#EF4444"/>
            <Setter Property="BorderThickness" Value="0,0,0,3"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Margin" Value="0,0,0,25"/>
        </Style>

        <!-- TEXTBOX STYLE -->
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Margin" Value="0,0,0,25"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#FF9E6827"/>
                    <Setter Property="BorderThickness" Value="0,0,0,3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- PASSWORD BOX STYLE -->
        <Style x:Key="ModernPassword" TargetType="PasswordBox">
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Margin" Value="0,0,0,25"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#FF9E6827"/>
                    <Setter Property="BorderThickness" Value="0,0,0,3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- COMBOBOX STYLE -->
        <Style x:Key="ModernCombo" TargetType="ComboBox">
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="0,0,0,25"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#FF9E6827"/>
                    <Setter Property="BorderThickness" Value="0,0,0,3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- BUTTON STYLES -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FF9E6827"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="40,0"/>
            <Setter Property="Margin" Value="0,20,0,0"/>
        </Style>

        <Style x:Key="ToggleButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="45"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <!-- MAIN UI -->
    <Grid>
        <!-- BACKGROUND -->
        <Border>
            <Border.Background>
                <ImageBrush ImageSource="images\BG.jpg" Stretch="UniformToFill"/>
            </Border.Background>
        </Border>

        <!-- OVERLAY -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                    <GradientStop Color="#CC000000" Offset="0"/>
                    <GradientStop Color="#CC9E6827" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- MAIN CARD -->
        <Border x:Name="MainCard" Width="1200" Height="780" Background="White" 
                CornerRadius="24" Opacity="0" RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
            </Border.RenderTransform>
            <Grid>
                <!-- HEADER -->
                <Border Background="#FF9E6827" CornerRadius="24,24,0,0" Height="80">
                    <Grid>
                        <TextBlock Text="Add New Staff Member" Foreground="White" FontSize="24" 
                                   FontWeight="SemiBold" VerticalAlignment="Center" Margin="40,0"/>
                        <Button Content="✕" HorizontalAlignment="Right" Margin="0,0,30,0" 
                                Width="40" Height="40" Background="Transparent" BorderThickness="0" 
                                Foreground="White" FontSize="18" Cursor="Hand" Click="CloseButton_Click"/>
                    </Grid>
                </Border>

                <!-- CONTENT -->
                <Grid Margin="0,80,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT PANEL -->
                    <Border x:Name="LeftPanel" Grid.Column="0" Background="#F9FAFB" 
                            Margin="50,0,25,50" Padding="40" Opacity="0">
                        <Border.RenderTransform>
                            <TranslateTransform X="-40"/>
                        </Border.RenderTransform>
                        <StackPanel>
                            <TextBlock Text="👤 Personal Info" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,30"/>

                            <!-- FULL NAME -->
                            <TextBlock Text="Full Name" FontSize="14" FontWeight="Medium" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,25">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="FirstNameTextBox" Grid.Column="0" 
                                         Style="{StaticResource ModernInput}" Text="First Name"/>
                                <TextBox x:Name="LastNameTextBox" Grid.Column="2" 
                                         Style="{StaticResource ModernInput}" Text="Last Name"/>
                            </Grid>

                            <!-- USERNAME -->
                            <TextBlock Text="Username" FontSize="14" FontWeight="Medium" Margin="0,0,0,8"/>
                            <TextBox x:Name="UsernameTextBox" Style="{StaticResource ModernInput}"/>

                            <!-- PASSWORD -->
                            <TextBlock Text="Password" FontSize="14" FontWeight="Medium" Margin="0,0,0,8"/>
                            <Grid>
                                <PasswordBox x:Name="PasswordBox" Style="{StaticResource ModernPassword}"/>
                                <TextBox x:Name="PasswordTextBox" Style="{StaticResource ModernInput}" 
                                         Visibility="Collapsed"/>
                                <Button Content="👁" Style="{StaticResource ToggleButton}" 
                                        Click="TogglePassword_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- RIGHT PANEL -->
                    <Border x:Name="RightPanel" Grid.Column="1" Background="#FF9E6827" 
                            Margin="25,0,50,50" Padding="40" Opacity="0">
                        <Border.RenderTransform>
                            <TranslateTransform X="40"/>
                        </Border.RenderTransform>
                        <StackPanel>
                            <TextBlock Text="📞 Contact Info" Foreground="White" FontSize="20" 
                                       FontWeight="SemiBold" Margin="0,0,0,30"/>

                            <!-- CONTACT -->
                            <TextBlock Text="Contact Number" Foreground="White" FontSize="14" 
                                       FontWeight="Medium" Margin="0,0,0,8"/>
                            <TextBox x:Name="ContactTextBox" Style="{StaticResource ModernInput}"/>

                            <!-- EMAIL -->
                            <TextBlock Text="Email" Foreground="White" FontSize="14" FontWeight="Medium" Margin="0,0,0,8"/>
                            <TextBox x:Name="EmailTextBox" Style="{StaticResource ModernInput}"/>

                            <!-- DEPARTMENT **FIXED HERE** -->
                            <TextBlock Text="Department" Foreground="White" FontSize="14" FontWeight="Medium" Margin="0,0,0,8"/>
                            <ComboBox x:Name="DepartmentComboBox" Style="{StaticResource ModernCombo}">
                                <ComboBoxItem Content="Receptionist" IsSelected="True"/>
                                <ComboBoxItem Content="Housekeeping"/>
                                <ComboBoxItem Content="Manager"/>
                                <ComboBoxItem Content="Maintenance"/>
                                <ComboBoxItem Content="Accounting"/>
                                <ComboBoxItem Content="Security"/>
                            </ComboBox>

                            <!-- SAVE BUTTON -->
                            <Button x:Name="SaveButton" Content="💾 Save Staff Member" 
                                    Style="{StaticResource PrimaryButton}" Click="SaveButton_Click"/>

                            <!-- CANCEL BUTTON -->
                            <Button Content="❌ Cancel" Style="{StaticResource PrimaryButton}" 
                                    Background="#6B7280" Click="CancelButton_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>

    <!-- Window animations (same as before) -->
    <Window.Triggers>
        <!-- [Animation code here - same as your original] -->
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- CARD -->
                    <DoubleAnimation Storyboard.TargetName="MainCard" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                    <DoubleAnimation Storyboard.TargetName="MainCard" Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" From="0.9" To="1" Duration="0:0:0.4"/>
                    <DoubleAnimation Storyboard.TargetName="MainCard" Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" From="0.9" To="1" Duration="0:0:0.4"/>
                    <!-- LEFT -->
                    <DoubleAnimation Storyboard.TargetName="LeftPanel" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.4" BeginTime="0:0:0.2"/>
                    <DoubleAnimation Storyboard.TargetName="LeftPanel" Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)" To="0" Duration="0:0:0.4" BeginTime="0:0:0.2"/>
                    <!-- RIGHT -->
                    <DoubleAnimation Storyboard.TargetName="RightPanel" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.4" BeginTime="0:0:0.3"/>
                    <DoubleAnimation Storyboard.TargetName="RightPanel" Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)" To="0" Duration="0:0:0.4" BeginTime="0:0:0.3"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>