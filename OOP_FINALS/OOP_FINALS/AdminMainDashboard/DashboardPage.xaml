<Page x:Class="OOP_FINALS.AdminMainDashboard.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Dashboard"
      Loaded="Page_Loaded"
      Unloaded="Page_Unloaded">

    <Page.Resources>

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFDFC"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="1" Opacity="0.06" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="1" Opacity="0.06" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1A1A2E"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>

        <Style x:Key="StatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#64748B"/>
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1A1A2E"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="MiniStatStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,12"/>
        </Style>

        <DataTemplate x:Key="BookingItemTemplate">
            <Grid Margin="0,0,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding GuestName}"  FontSize="13" FontWeight="Medium" Foreground="#1A1A2E" VerticalAlignment="Center" Padding="0,10"/>
                <TextBlock Grid.Column="1" Text="{Binding RoomInfo}"   FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding CheckIn}"    FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="{Binding CheckOut}"   FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                <Border    Grid.Column="4" CornerRadius="99" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center"
                           Background="{Binding StatusBg}">
                    <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Medium" Foreground="{Binding StatusFg}"/>
                </Border>
                <TextBlock Grid.Column="5" Text="{Binding Amount}"     FontSize="13" FontWeight="Medium" Foreground="#1A1A2E" VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ActivityItemTemplate">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Ellipse Width="8" Height="8" Fill="{Binding DotColor}" Margin="0,5,12,0" VerticalAlignment="Top"/>
                <StackPanel>
                    <TextBlock Text="{Binding Description}" FontSize="13" Foreground="#1A1A2E" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding TimeAgo}"     FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

    </Page.Resources>

    <!-- Outer page grid: sticky header + scrollable body -->
    <Grid Background="#F5F1EB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             STICKY HEADER
        ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#654321"
                Padding="28,14"
                Panel.ZIndex="10">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.05" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Dashboard"
                               FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock x:Name="WelcomeSubText"
                               Text="Welcome back — here's what's happening today"
                               FontSize="13" Foreground="#E5E7EB" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="34" Height="34" CornerRadius="17" Background="#E6F1FB" Margin="0,0,10,0">
                        <TextBlock x:Name="UserInitialsText"
                                   Text="AD" FontSize="12" FontWeight="Medium" Foreground="#185FA5"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="UserNameText"
                                   Text="Admin" FontSize="13" FontWeight="Medium" Foreground="White"/>
                        <TextBlock Text="Administrator" FontSize="11" Foreground="#E5E7EB"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             SCROLLABLE BODY  — inner Grid owns all row definitions
        ═══════════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Row 0: stat cards        -->
                    <RowDefinition Height="Auto"/>
                    <!-- Row 1: room status        -->
                    <RowDefinition Height="Auto"/>
                    <!-- Row 2: bookings + activity-->
                    <RowDefinition Height="Auto"/>
                    <!-- Row 3: bar chart          -->
                    <RowDefinition Height="Auto"/>
                    <!-- Row 4: housekeeping + inv -->
                </Grid.RowDefinitions>

                <!-- ─── ROW 0 — STAT CARDS ──────────────────────────────── -->
                <Grid Grid.Row="0" Margin="28,24,28,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <Border Width="36" Height="36" CornerRadius="8" Background="#E6F1FB" HorizontalAlignment="Left">
                                <TextBlock Text="📋" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="TotalBookingsText" Text="—" Style="{StaticResource StatValueStyle}"/>
                            <TextBlock Text="Total Active Bookings" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <Border Width="36" Height="36" CornerRadius="8" Background="#EAF3DE" HorizontalAlignment="Left">
                                <TextBlock Text="✅" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="TodayCheckinsText" Text="—" Style="{StaticResource StatValueStyle}"/>
                            <TextBlock Text="Check-ins Today" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <Border Width="36" Height="36" CornerRadius="8" Background="#FAEEDA" HorizontalAlignment="Left">
                                <TextBlock Text="💰" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="TodayRevenueText" Text="—" Style="{StaticResource StatValueStyle}"/>
                            <TextBlock Text="Monthly Revenue" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource StatCardStyle}" Margin="0">
                        <StackPanel>
                            <Border Width="36" Height="36" CornerRadius="8" Background="#FAECE7" HorizontalAlignment="Left">
                                <TextBlock Text="🏨" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="OccupancyRateText" Text="—" Style="{StaticResource StatValueStyle}"/>
                            <TextBlock Text="Room Occupancy Rate" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ─── ROW 1 — ROOM STATUS ──────────────────────────────── -->
                <Grid Grid.Row="1" Margin="28,16,28,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,14,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="10" Height="10" Fill="#E24B4A" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock x:Name="OccupiedText"  Text="—" FontSize="24" FontWeight="SemiBold" Foreground="#1A1A2E"/>
                                <TextBlock Text="Rooms Occupied"  FontSize="12" Foreground="#64748B"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,14,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="10" Height="10" Fill="#639922" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock x:Name="AvailableText"  Text="—" FontSize="24" FontWeight="SemiBold" Foreground="#1A1A2E"/>
                                <TextBlock Text="Rooms Available"  FontSize="12" Foreground="#64748B"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="10" Height="10" Fill="#888780" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock x:Name="MaintenanceText" Text="—" FontSize="24" FontWeight="SemiBold" Foreground="#1A1A2E"/>
                                <TextBlock Text="Under Maintenance"  FontSize="12" Foreground="#64748B"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ─── ROW 2 — RECENT BOOKINGS + QUICK STATS / ACTIVITY ─── -->
                <Grid Grid.Row="3" Margin="28,16,28,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <!-- Recent Bookings -->
                    <Border Grid.Column="0"
            Style="{StaticResource CardStyle}"
            Margin="0,0,14,0">

                        <StackPanel>
                            <TextBlock Text="Recent Bookings"
                       Style="{StaticResource CardTitleStyle}" />

                            <!-- Header -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="1.5*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                           Text="GUEST"
                           Margin="0,0,16,0"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#64748B" />

                                <TextBlock Grid.Column="1"
                           Text="ROOM"
                           Margin="0,0,16,0"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#64748B" />

                                <TextBlock Grid.Column="2"
                           Text="CHECK-IN"
                           Margin="0,0,16,0"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#64748B" />

                                <TextBlock Grid.Column="3"
                           Text="CHECK-OUT"
                           Margin="0,0,16,0"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#64748B" />

                                <TextBlock Grid.Column="4"
                           Text="STATUS"
                           Margin="0,0,16,0"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#64748B" />

                                <TextBlock Grid.Column="5"
                           Text="AMOUNT"
                           HorizontalAlignment="Right"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#64748B" />
                            </Grid>

                            <Separator Margin="0,0,0,4"
                       Background="#F1F5F9" />

                            <ListBox x:Name="BookingsListBox"
                     Background="Transparent"
                     BorderThickness="0"
                     MaxHeight="240"
                     ItemTemplate="{StaticResource BookingItemTemplate}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Focusable" Value="False" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <!-- Right Side -->
                    <StackPanel Grid.Column="1">

                        <!-- Quick Stats -->
                        <Border Style="{StaticResource CardStyle}"
                Margin="0,0,0,14">

                            <StackPanel>
                                <TextBlock Text="Quick Stats"
                           Style="{StaticResource CardTitleStyle}" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,0,8,8"
                            Style="{StaticResource MiniStatStyle}">
                                        <StackPanel>
                                            <TextBlock x:Name="CleanedTodayText"
                                       Text="—"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="#1A1A2E" />

                                            <TextBlock Text="Rooms Cleaned"
                                       Margin="0,2,0,0"
                                       FontSize="11"
                                       Foreground="#64748B" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="0"
                            Grid.Column="1"
                            Margin="0,0,0,8"
                            Style="{StaticResource MiniStatStyle}">
                                        <StackPanel>
                                            <TextBlock x:Name="NewGuestsTodayText"
                                       Text="—"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="#1A1A2E" />

                                            <TextBlock Text="New Guests"
                                       Margin="0,2,0,0"
                                       FontSize="11"
                                       Foreground="#64748B" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,0,8,0"
                            Style="{StaticResource MiniStatStyle}">
                                        <StackPanel>
                                            <TextBlock x:Name="WeekCheckinsText"
                                       Text="—"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="#1A1A2E" />

                                            <TextBlock Text="This Week"
                                       Margin="0,2,0,0"
                                       FontSize="11"
                                       Foreground="#64748B" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource MiniStatStyle}">
                                        <StackPanel>
                                            <TextBlock x:Name="CheckoutsTodayText"
                                       Text="—"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="#1A1A2E" />

                                            <TextBlock Text="Check-outs"
                                       Margin="0,2,0,0"
                                       FontSize="11"
                                       Foreground="#64748B" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Recent Activity -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Recent Activity"
                           Style="{StaticResource CardTitleStyle}" />

                                <ListBox x:Name="ActivityListBox"
                         Background="Transparent"
                         BorderThickness="0"
                         MaxHeight="160"
                         ItemTemplate="{StaticResource ActivityItemTemplate}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0,0,0,8" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Focusable" Value="False" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- ─── ROW 3 — MONTHLY BAR CHART ───────────────────────── -->
                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="28,16,28,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Monthly Guests &amp; Revenue"
                                           FontSize="14" FontWeight="SemiBold" Foreground="#1A1A2E"/>
                                <TextBlock x:Name="ChartYearLabel"
                                           Text="2025" FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Rectangle Width="10" Height="10" RadiusX="2" RadiusY="2"
                                           Fill="#7A4A17" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Guests" FontSize="11" Foreground="#64748B" Margin="0,0,14,0"/>
                                <Rectangle Width="10" Height="10" RadiusX="2" RadiusY="2"
                                           Fill="#185FA5" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Current month" FontSize="11" Foreground="#64748B"/>
                            </StackPanel>
                        </Grid>

                        <Canvas x:Name="BarChartCanvas"
                                Height="220"
                                Background="Transparent"
                                SizeChanged="BarChartCanvas_SizeChanged"
                                MouseMove="BarChart_MouseMove"
                                MouseLeave="BarChart_MouseLeave"/>

                        <Border x:Name="ChartTooltip"
                                Background="#1A1A2E"
                                CornerRadius="8"
                                Padding="12,8"
                                Visibility="Collapsed"
                                HorizontalAlignment="Left"
                                Margin="0,6,0,0">
                            <StackPanel>
                                <TextBlock x:Name="TooltipMonth"   FontSize="12" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                                <TextBlock x:Name="TooltipGuests"  FontSize="11" Foreground="#94A3B8" Margin="0,3,0,0"/>
                                <TextBlock x:Name="TooltipRevenue" FontSize="11" Foreground="#FBBF24" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ─── ROW 4 — HOUSEKEEPING + INVENTORY ALERTS ──────────── -->
                <Grid Grid.Row="4" Margin="28,16,28,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="Pending Housekeeping" Style="{StaticResource CardTitleStyle}"/>
                            <ListBox x:Name="HousekeepingListBox"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     MaxHeight="120">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding RoomInfo}" FontSize="13"
                                                       Foreground="#1A1A2E" VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" CornerRadius="99" Background="#FAEEDA"
                                                    Padding="8,3" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Status}" FontSize="11"
                                                           FontWeight="Medium" Foreground="#854F0B"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="Low Inventory Alerts" Style="{StaticResource CardTitleStyle}"/>
                            <ListBox x:Name="InventoryAlertListBox"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     MaxHeight="120">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding ItemName}" FontSize="13"
                                                       Foreground="#1A1A2E" VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" CornerRadius="99" Background="#FCEBEB"
                                                    Padding="8,3" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StockInfo}" FontSize="11"
                                                           FontWeight="Medium" Foreground="#A32D2D"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </Grid>

            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
