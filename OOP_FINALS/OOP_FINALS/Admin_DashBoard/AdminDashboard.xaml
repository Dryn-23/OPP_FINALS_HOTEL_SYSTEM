<Window x:Class="OOP_FINALS.AdminDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AdminDashboard"
        Height="700"
        Width="1200"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown">

    <Border CornerRadius="12">
        <!-- BACKGROUND IMAGE -->
        <Border.Background>
            <ImageBrush ImageSource="images/BG.jpg" Stretch="Fill"/>
        </Border.Background>

        <!-- MAIN CONTAINER -->
        <Border CornerRadius="10" BorderThickness="2" Opacity="0.95">
            <!-- BORDER GRADIENT -->
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFA7D82A" Offset="0"/>
                    <GradientStop Color="#DA34AE" Offset="0.75"/>
                    <GradientStop Color="#FF9800E0" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <!-- BACKGROUND GRADIENT -->
            <Border.Background>
                <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                    <GradientStop Color="Black" Offset="0"/>
                    <GradientStop Color="#FF9E6827" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <!-- ✅ FIXED: Single Grid with proper structure -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 🔵 SIDEBAR -->
                <Border Background="White" CornerRadius="10,0,0,0" Grid.Column="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition/>
                            <RowDefinition Height="90"/>
                        </Grid.RowDefinitions>

                        <!-- Logo -->
                        <TextBlock Text="Delisas" FontSize="24" FontWeight="Bold" 
                                   Margin="25,25,25,15" Grid.Row="0"/>

                        <!-- Menu Buttons -->
                        <StackPanel Grid.Row="1" Margin="0,10">
                            <Button x:Name="btnDashboard" Content="🏠 Dashboard" Click="Dashboard_Click" 
                                    Margin="15,5" Height="45" Background="Transparent" BorderThickness="0"/>
                            <Button x:Name="btnBookings" Content="📅 Bookings" Click="Bookings_Click" 
                                    Margin="15,5" Height="45" Background="Transparent" BorderThickness="0"/>
                            <Button x:Name="btnGuests" Content="👥 Guests" Click="Guests_Click" 
                                    Margin="15,5" Height="45" Background="Transparent" BorderThickness="0"/>
                            <Button x:Name="btnAnalytics" Content="📊 Analytics" Click="Analytics_Click" 
                                    Margin="15,5" Height="45" Background="Transparent" BorderThickness="0"/>
                            <Button x:Name="btnTransactions" Content="💳 Transactions" Click="Transactions_Click" 
                                    Margin="15,5" Height="45" Background="Transparent" BorderThickness="0"/>
                            <Button x:Name="btnHousekeeping" Content="🧹 Housekeeping" Click="Housekeeping_Click"
        Margin="15,5" Height="45" Background="Transparent" BorderThickness="0"/>
                            <Button x:Name="btnInventory" Content="📦 Inventory" Click="Inventory_Click"
        Margin="15,5" Height="45" Background="Transparent" BorderThickness="0"/>
                            <Button x:Name="btnInventoryUsage" Content="📉 Inventory Usage" Click="InventoryUsage_Click"
        Margin="15,5" Height="45" Background="Transparent" BorderThickness="0"/>
                            <Button x:Name="btnSettings" Content="⚙️ Settings" Click="Settings_Click" 
                                    Margin="15,5" Height="45" Background="Transparent" BorderThickness="0"/>
                        </StackPanel>

                        <!-- Profile -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="20,10" VerticalAlignment="Bottom">
                            <Ellipse Width="45" Height="45" Fill="#E0E0E0" Margin="0,0,15,0"/>
                            <StackPanel>
                                <TextBlock Text="Admin User" FontWeight="Bold"/>
                                <TextBlock Text="Administrator" FontSize="11" Foreground="Gray"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 🟢 MAIN CONTENT AREA -->
                <Grid Grid.Column="1" Margin="25">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="txtSearch" Height="40" VerticalAlignment="Center" Padding="15,0,40,0"
                                 Background="White" BorderThickness="0" FontSize="13"
                                 Text="🔍 Search..." GotFocus="txtSearch_GotFocus" LostFocus="txtSearch_LostFocus"/>

                        <ComboBox x:Name="cmbFilter" Grid.Column="1" Height="40" Margin="10,0,0,0"
                                  SelectionChanged="cmbFilter_SelectionChanged">
                            <ComboBoxItem Content="Daily"/>
                            <ComboBoxItem Content="Weekly"/>
                            <ComboBoxItem Content="Monthly" IsSelected="True"/>
                        </ComboBox>

                        <!-- Window Controls -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="btnMinimize" Content="–" Width="45" Height="40" Margin="5,0,0,0"
                                    Background="Transparent" BorderThickness="0" Foreground="White" 
                                    FontSize="20" Click="btnMinimize_Click"/>
                            <Button x:Name="btnClose" Content="✕" Width="45" Height="40" 
                                    Background="#E74C3C" BorderThickness="0" Foreground="White" 
                                    FontSize="16" Click="btnClose_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- ✅ Frame for Pages (No overlap now) -->
                    <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
                </Grid>
            </Grid>
        </Border>
    </Border>   
</Window>