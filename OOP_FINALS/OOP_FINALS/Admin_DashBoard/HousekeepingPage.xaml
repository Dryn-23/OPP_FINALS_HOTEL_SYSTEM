<Page x:Class="OOP_FINALS.HousekeepingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="HousekeepingPage"
      Background="#1E1E2D">

    <Grid Margin="20">
        <!-- HEADER -->
        <Border CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFA7D82A" Offset="0"/>
                    <GradientStop Color="#DA34AE" Offset="0.7"/>
                    <GradientStop Color="#FF9800E0" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <TextBlock Text="Housekeeping" FontSize="26" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- DATA GRID CONTAINER -->
        <Border CornerRadius="12" Background="#2E2E3E" Padding="15" Grid.Row="1" >
            <DataGrid x:Name="dgHousekeeping" AutoGenerateColumns="True" 
                      Background="#2E2E3E" 
                      Foreground="White" 
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      RowBackground="#3A3A4A"
                      AlternatingRowBackground="#2E2E3E"
                      BorderBrush="Transparent"
                      CanUserAddRows="False"
                      FontSize="14"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      >
                <!-- HEADER STYLE -->
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#444456"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10,5"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
            </DataGrid>
        </Border>
    </Grid>
</Page>