<Page x:Class="OOP_FINALS.ManageStaffPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Manage Staff"
                   FontSize="24"
                   Foreground="Black"
                   Margin="0,0,0,20"
                   Grid.Row="0"/>

        <!-- DataGrid -->
        <DataGrid x:Name="StaffDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  Background="#22000000"
                  Foreground="Black"
                  GridLinesVisibility="None"
                  RowBackground="#33000000"
                  AlternatingRowBackground="#22000000"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  Margin="0,0,0,10" SelectionChanged="StaffDataGrid_SelectionChanged">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding StaffID}" Width="50" IsReadOnly="True"/>
                <DataGridTextColumn Header="Emp ID" Binding="{Binding EmployeeID}" Width="70" IsReadOnly="True"/>
                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="120"/>
                <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>

                <!-- SIMPLE Role ComboBox - NO ElementStyle issues -->
                <DataGridComboBoxColumn Header="Position" 
                                        x:Name="RoleComboColumn"
                                        SelectedValueBinding="{Binding RoleID}"
                                        SelectedValuePath="RoleID"
                                        DisplayMemberPath="RoleName"
                                        Width="140"/>

                <!-- SIMPLE Status Text Column -->
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
            <Button x:Name="AddStaffButton" 
                    Content="Add Staff" 
                    Width="100" 
                    Height="35" 
                    Margin="5"
                    Background="#FF4CAF50"
                    Foreground="White"
                    Click="AddStaffButton_Click"/>
            <Button x:Name="DeleteStaffButton" 
                    Content="Delete Staff" 
                    Width="100" 
                    Height="35" 
                    Margin="5"
                    Background="#FFF44336"
                    Foreground="White"
                    Click="DeleteStaffButton_Click"/>
            <Button x:Name="SaveChangesButton" 
                    Content="Save Changes" 
                    Width="100" 
                    Height="35" 
                    Margin="5"
                    Background="#FF2196F3"
                    Foreground="White"
                    Click="SaveChangesButton_Click"/>
            <Button x:Name="RefreshButton" 
                    Content="Refresh" 
                    Width="80" 
                    Height="35" 
                    Margin="5"
                    Background="#FF757575"
                    Foreground="White"
                    Click="RefreshButton_Click"/>
        </StackPanel>

        <!-- Status Message -->
        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="3"
                   Foreground="#FF4CAF50"
                   FontSize="14"
                   Text="Ready"
                   HorizontalAlignment="Center"
                   Margin="0,5"/>
    </Grid>
</Page>