<Page x:Class="OOP_FINALS.RoomsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:OOP_FINALS"
      Background="Transparent">

    <Page.DataContext>
        <local:RoomViewModel x:Name="DesignDataContext"/>
    </Page.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled"
                  Margin="0,20">

        <StackPanel Margin="30">

            <!-- HEADER -->
            <Grid Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="🏨 Rooms" 
                               FontSize="36" FontWeight="Bold" 
                               Foreground="White"/>
                    <TextBlock Text="Manage your accommodations" 
                               Foreground="#CBD5F5" FontSize="16" 
                               Margin="0,5,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Content="+ Add Room" 
                        Command="{Binding AddRoomCommand}"
                        Background="#FF9E6827" Foreground="White"
                        BorderThickness="0" Padding="16,12"
                        FontWeight="Medium" MinWidth="140" Height="48"
                        Cursor="Hand"/>
            </Grid>

            <!-- ROOMS GRID -->
            <ItemsControl ItemsSource="{Binding Rooms}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel ItemWidth="280" ItemHeight="340"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Margin" Value="15"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1E293B" CornerRadius="20" 
                                Cursor="Hand"
                                RenderTransformOrigin="0.5,0.5">

                            <!-- Scale Transform -->
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="cardScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>

                            <!-- HOVER ANIMATIONS (Card Scale Only) -->
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="cardScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.03" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="cardScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.03" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>

                                <EventTrigger RoutedEvent="MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="cardScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="cardScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="160"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- IMAGE -->
                                <Image Grid.Row="0" 
                                       Source="{Binding ImagePath}"
                                       Stretch="UniformToFill"/>

                                <!-- STATUS BADGE - ULTRA SIMPLE -->
                                <Border Grid.Row="0" Background="#9E9E9E" CornerRadius="12" 
                                        Padding="8,6"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="16">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Available">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <SolidColorBrush Color="#4CAF50"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Occupied">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <SolidColorBrush Color="#F44336"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Cleaning">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <SolidColorBrush Color="#FF9800"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status}" 
                                               FontSize="12" FontWeight="Medium" 
                                               Foreground="White"
                                               HorizontalAlignment="Center"/>
                                </Border>

                                <!-- DETAILS -->
                                <StackPanel Grid.Row="1" Margin="20" 
                                            VerticalAlignment="Bottom">

                                    <TextBlock Text="{Binding RoomNumber}"
                                               FontSize="24" FontWeight="Bold" 
                                               Foreground="White"
                                               Margin="0,0,0,8"/>

                                    <TextBlock Text="{Binding TypeName}"
                                               Foreground="#CBD5F5" FontSize="16"
                                               Margin="0,0,0,16"/>

                                    <!-- PRICE -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <TextBlock Text="₱" Foreground="#4CAF50" 
                                                   FontSize="20" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Price, StringFormat={}{0:N0}}" 
                                                   Foreground="#4CAF50" FontSize="24" 
                                                   FontWeight="Bold" Margin="4,0,0,0"/>
                                        <TextBlock Text="/night" Foreground="#CBD5F5" 
                                                   FontSize="14" Margin="8,0,0,0"/>
                                    </StackPanel>

                                    <!-- ACTION BUTTONS - SIMPLE -->
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Book Now" 
                                                Command="{Binding DataContext.RoomClickCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                Background="#4CAF50" Foreground="White"
                                                BorderThickness="0" Padding="12,8"
                                                FontWeight="Medium" Width="110"
                                                Margin="0,0,8,0"
                                                Cursor="Hand"/>

                                        <Button Content="Edit" 
                                                Command="{Binding DataContext.EditRoomCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                Background="#FF9E6827" Foreground="White"
                                                BorderThickness="0" Padding="12,8"
                                                FontWeight="Medium" Width="80"
                                                Cursor="Hand"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- EMPTY STATE -->
            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Rooms.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="🛏️" FontSize="64" HorizontalAlignment="Center" Margin="0,60,0,20"/>
                <TextBlock Text="No rooms available" FontSize="24" Foreground="White" 
                           FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="Add your first room to get started" 
                           Foreground="#CBD5F5" HorizontalAlignment="Center" FontSize="16"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>