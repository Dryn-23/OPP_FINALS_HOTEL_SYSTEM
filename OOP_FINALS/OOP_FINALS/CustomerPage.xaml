<UserControl x:Class="CustomerDashboard.CustomerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             xmlns:local="clr-namespace:CustomerDashboard"
             d:DesignHeight="800" d:DesignWidth="1400">

    <!-- ================= RESOURCES ================= -->
    <UserControl.Resources >
        <Storyboard x:Key="ShimmerAnimation" RepeatBehavior="Forever">
            <DoubleAnimation 
        Storyboard.TargetProperty="(Panel.Background).(LinearGradientBrush.GradientStops)[1].Offset"
        From="-1" To="2"
        Duration="0:0:1.5" />
        </Storyboard>
        <!-- Gradient -->
        <LinearGradientBrush x:Key="HeaderGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A4712A" Offset="0"/>
            <GradientStop Color="#7B4F1D" Offset="1"/>
        </LinearGradientBrush>
        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#EFE6DB"/>
            <Setter Property="Foreground" Value="#5C3A1A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#D6C2A8"/>
        </Style>
        <!-- Card -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>

            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" Opacity="0.1"/>
                </Setter.Value>
            </Setter>

            <Style.Triggers>

                <!-- Hover Lift -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="-5"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>

            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="White"/>

            <Style.Triggers>

                <!-- Hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EFE6DB"/>
                </Trigger>

                <!-- Selected (THIS removes blue highlight) -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D6C2A8"/>
                    <Setter Property="Foreground" Value="#3E2A14"/>
                </Trigger>

            </Style.Triggers>
        </Style>

        <!-- Search Box -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#D6C2A8"/>
            <Setter Property="Background" Value="White"/>
        </Style>

    </UserControl.Resources >

    <!-- ================= LAYOUT ================= -->
    <Grid Background="Transparent">
        
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation 
                    Storyboard.TargetProperty="Opacity"
                    From="0" To="1" Duration="0:0:0.4"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <Border Grid.Row="0"
                Background="{StaticResource HeaderGradientBrush}"
                CornerRadius="12"
                Padding="25"
                Margin="0,0,0,20">

            <StackPanel>
                <TextBlock Text="Customers"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="Manage your customers efficiently"
                           FontSize="14"
                           Foreground="White"
                           Opacity="0.9"/>
            </StackPanel>
        </Border>

        <!-- ================= SEARCH ================= -->
        <Border Grid.Row="1"
                Margin="0,0,0,20"
                CornerRadius="10"
                BorderThickness="2"
                BorderBrush="#E2E8F0">

            <TextBox x:Name="SearchTextBox"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     TextChanged="SearchTextBox_TextChanged"/>
        </Border>

        <!-- ================= MAIN ================= -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- ========= DATA GRID ========= -->
            <Border Grid.Column="0"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,15,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            Background="#F3ECE4"
                            Padding="20"
                            BorderBrush="#E2E8F0"
                            BorderThickness="0,0,0,1">

                        <TextBlock x:Name="CustomerCountText"
           FontSize="18"
           FontWeight="SemiBold">

                            <TextBlock.Text>
                                <Binding Path="Customers.Count" StringFormat="Customers ({0})"/>
                            </TextBlock.Text>

                        </TextBlock>
                    </Border>
                    <Grid x:Name="SkeletonLoader" Loaded="SkeletonLoader_Loaded">

                        <!-- Base skeleton -->
                        <StackPanel>
                            <Border Height="20" Margin="0,8" Background="#E0D6C8" CornerRadius="5"/>
                            <Border Height="20" Margin="0,8" Background="#E0D6C8" CornerRadius="5"/>
                            <Border Height="20" Margin="0,8" Background="#E0D6C8" CornerRadius="5"/>
                            <Border Height="20" Margin="0,8" Background="#E0D6C8" CornerRadius="5"/>
                            <Border Height="20" Margin="0,8" Background="#E0D6C8" CornerRadius="5"/>
                        </StackPanel>

                        <!-- Shimmer overlay -->
                        <Rectangle x:Name="Shimmer"
               Width="120"
               Fill="#FFFFFF"
               Opacity="0.3"
               HorizontalAlignment="Left">
                            <Rectangle.RenderTransform>
                                <TranslateTransform X="-150"/>
                            </Rectangle.RenderTransform>
                        </Rectangle>

                    </Grid>

                    <!-- Table -->
                    <DataGrid Grid.Row="1"
                              x:Name="CustomersDataGrid"
                              Visibility="Collapsed"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              MouseDoubleClick="CustomersDataGrid_MouseDoubleClick"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}">

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Action" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Edit"
                    Click="EditButton_Click"
                    Padding="5,2"
                    Margin="5"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <!-- Customer -->
                            <DataGridTemplateColumn Header="Customer" Width="250">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">

                                            <!-- Avatar -->
                                            <Grid Width="35" Height="35" Margin="0,0,10,0">
                                                <Ellipse>
                                                    <Ellipse.Fill>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#A4712A" Offset="0"/>
                                                            <GradientStop Color="#7B4F1D" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Ellipse.Fill>
                                                </Ellipse>

                                                <TextBlock Text="{Binding Initials}"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Grid>

                                            <StackPanel>
                                                <TextBlock Text="{Binding FirstName}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding LastName}" Foreground="#7A5C3E"/>
                                            </StackPanel>

                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Contact"
                                                Binding="{Binding ContactNumber}"
                                                Width="150"
                                                IsReadOnly="True"/>

                            <DataGridTextColumn Header="Email"
                                                Binding="{Binding Email}"
                                                Width="200"
                                                IsReadOnly="True"/>

                            <DataGridTextColumn Header="ID Type"
                                                Binding="{Binding ValidIDType}"
                                                Width="120"
                                                IsReadOnly="True"/>

                            <DataGridTextColumn Header="ID Number"
                                                Binding="{Binding ValidIDNumber}"
                                                Width="*"
                                                IsReadOnly="True"/>

                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ========= INFO PANEL ========= -->
            <Border Grid.Column="1"
                    x:Name="CustomerInfoCard"
                    Style="{StaticResource CardStyle}"
                    Visibility="Collapsed">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            Background="{StaticResource HeaderGradientBrush}"
                            Padding="20">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock x:Name="InfoNameText"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="White"/>
                                <TextBlock x:Name="InfoCustomerIdText"
                                           Foreground="White"
                                           Opacity="0.8"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="✕"
                                    Width="35"
                                    Height="35"
                                    Click="CloseInfoButton_Click"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="White"/>
                        </Grid>
                    </Border>

                    <!-- Details -->

                    <Border Grid.Row="1" Padding="20">
                        <StackPanel>

                            <TextBlock Text="Contact Number" FontWeight="SemiBold"/>
                            <TextBlock x:Name="ContactValueText" Margin="0,0,0,15"/>

                            <TextBlock Text="Email" FontWeight="SemiBold"/>
                            <TextBlock x:Name="EmailValueText" Margin="0,0,0,15"/>

                            <TextBlock Text="Valid ID Type" FontWeight="SemiBold"/>
                            <TextBlock x:Name="ValidIdTypeText" Margin="0,0,0,15"/>

                            <TextBlock Text="Valid ID Number" FontWeight="SemiBold"/>
                            <TextBlock x:Name="ValidIdNumberText"/>

                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
            <Border x:Name="EditPanel"
        Background="White"
        CornerRadius="12"
        Padding="20"
        Visibility="Collapsed"
        Margin="20"
        Panel.ZIndex="10">

                <StackPanel>

                    <TextBlock Text="Edit Customer"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

                    <TextBox x:Name="EditFirstName" Margin="0,5"/>
                    <TextBox x:Name="EditLastName" Margin="0,5"/>
                    <TextBox x:Name="EditContact"/>
                    <TextBox x:Name="EditEmail"/>
                    <TextBox x:Name="EditIDType"/>
                    <TextBox x:Name="EditIDNumber"/>

                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                        <Button Content="Save" Click="SaveEdit_Click" Margin="0,0,10,0"/>
                        <Button Content="Cancel" Click="CancelEdit_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>

        </Grid>

    </Grid>
</UserControl>