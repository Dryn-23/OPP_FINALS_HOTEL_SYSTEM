<Page x:Class="OOP_FINALS.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Title="Dashboard">

    <Page.Resources>
        <!-- Fixed Recent Booking Template -->
        <DataTemplate x:Key="RecentBookingTemplate">
            <Border Background="#2A9E6827" CornerRadius="16" Margin="0,0,0,12" Padding="24">
                <Border.Effect>
                    <DropShadowEffect Color="#40000000" BlurRadius="12" ShadowDepth="4" Opacity="0.6"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{Binding CustomerName}" FontSize="15" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding RoomInfo}" FontSize="13" Foreground="#F0D9B5" FontWeight="Medium"/>
                    <!-- Fixed Progress Bar using Rectangle -->
                    <Rectangle Height="4"
                               Margin="0,8,0,0"
                               RadiusX="2"
                               RadiusY="2"
                               Fill="#4CAF50"
                               HorizontalAlignment="Left"
                               Width="120"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Fixed Glass Card Style -->
        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="28"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#40000000" Direction="270" ShadowDepth="16" BlurRadius="32" Opacity="0.8"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Live Counter Style -->
        <Style x:Key="LiveCounterStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="40"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        </Style>

        <!-- Label Styles -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <Style x:Key="TitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <!-- Fixed ListBoxItem Style -->
        <Style x:Key="ListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" 
                  PanningMode="VerticalOnly" Margin="0">

        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Welcome Header -->
            <Border Grid.Row="0" Margin="40,40,40,24">

                <!-- PROPERTIES FIRST -->
                <Border.Effect>
                    <DropShadowEffect Color="#40000000" BlurRadius="20" ShadowDepth="8"/>
                </Border.Effect>

                <!-- THEN CONTENT -->
                <Border.Child>
                    <StackPanel>
                        <TextBlock x:Name="WelcomeUserText" 
                       Text="Welcome Back, Edrian!" 
                       FontSize="42" FontWeight="Bold" 
                       Foreground="White" Margin="0,0,0,12">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#40000000" BlurRadius="8"/>
                            </TextBlock.Effect>
                        </TextBlock>

                        <TextBlock Text="Here's what's happening at JohnCis Lodge today"
                       FontSize="20"
                       Foreground="#FFF7ED"
                       FontWeight="Medium"/>
                    </StackPanel>
                </Border.Child>

            </Border>

            <!-- Stats Cards -->
            <!-- Stats Cards - 4 COLUMNS -->
            <Grid Grid.Row="1" Margin="40,0,40,40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 1. Total Bookings -->
                <Border Grid.Column="0" Style="{StaticResource GlassCardStyle}" Margin="0,0,12,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF9E6827" Offset="0"/>
                            <GradientStop Color="#FF8C4A3F" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="📋 Total Bookings" FontSize="15" Foreground="#FFF7ED" FontWeight="Medium"/>
                        <TextBlock x:Name="TotalBookingsText" Text="0" Style="{StaticResource LiveCounterStyle}"/>
                        <TextBlock Text="+12% from last month" FontSize="15" Foreground="#F0D9B5" FontWeight="Medium"/>
                    </StackPanel>
                </Border>

                <!-- 2. Today Check-ins -->
                <Border Grid.Column="1" Style="{StaticResource GlassCardStyle}" Margin="0,0,12,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF6B4E31" Offset="0"/>
                            <GradientStop Color="#FF5A3D27" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="📅 Today Check-ins" FontSize="15" Foreground="#FFF7ED" FontWeight="Medium"/>
                        <TextBlock x:Name="TodayCheckinsText" Text="0" Style="{StaticResource LiveCounterStyle}"/>
                        <TextBlock Text="Live updates" FontSize="13" Foreground="#F0D9B8"/>
                    </StackPanel>
                </Border>

                <!-- 3. WEEK Check-ins (NEW!) -->
                <Border Grid.Column="2" Style="{StaticResource GlassCardStyle}" Margin="0,0,12,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF4CAF50" Offset="0"/>
                            <GradientStop Color="#FF45A049" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="📊 Week Check-ins" FontSize="15" Foreground="#E8F5E8" FontWeight="Medium"/>
                        <TextBlock x:Name="WeekCheckinsText" Text="0" Style="{StaticResource LiveCounterStyle}"/>
                        <TextBlock Text="Last 7 days" FontSize="13" Foreground="#E8F5E8"/>
                    </StackPanel>
                </Border>

                <!-- 4. Revenue -->
                <Border Grid.Column="3" Style="{StaticResource GlassCardStyle}"  Margin="0,0,12,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF2196F3" Offset="0"/>
                            <GradientStop Color="#FF1976D2" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="💰 Revenue Today" FontSize="15" Foreground="White" FontWeight="Medium"/>
                        <TextBlock x:Name="TodayRevenueText" Text="₱0" Style="{StaticResource LiveCounterStyle}"/>
                        <TextBlock Text="+₱3,850 yesterday" FontSize="13" Foreground="#BBDEFB"/>
                    </StackPanel>
                </Border>
            </Grid>
            <!-- Charts Section -->
            <Grid Grid.Row="2" Margin="40,0,40,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="📊 Live Analytics Dashboard" 
                           FontSize="28" FontWeight="Bold" Foreground="White" 
                           Margin="0,0,0,32"/>

                <!-- Charts Row -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LIVE Revenue Chart -->
                    <Border Grid.Column="0" Style="{StaticResource GlassCardStyle}" Margin="0,0,20,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="280"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="💹 Revenue Trend (Live - 30 days)" Style="{StaticResource TitleStyle}"/>

                            <!-- Live Chart Canvases -->
                            <Grid Grid.Row="1" Margin="20">
                                <Canvas x:Name="RevenueChartCanvas" Width="420" Height="200" Background="Transparent"/>
                                <Canvas x:Name="SparklineDotsCanvas" Width="420" Height="200" Canvas.Top="0" Canvas.Left="0"/>
                                <Canvas x:Name="GridLinesCanvas" Width="420" Height="200" Canvas.Top="0" Canvas.Left="0"/>

                                <!-- Live Labels -->
                                <StackPanel Canvas.Right="20" Canvas.Top="20" Canvas.ZIndex="10">
                                    <TextBlock x:Name="LiveRevenueLabel" Text="₱4,250" FontSize="18" 
                                               Foreground="#4CAF50" FontWeight="Bold"/>
                                    <TextBlock Text="Live Peak" FontSize="12" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- FIXED Donut Chart -->
                    <Border Grid.Column="1" Style="{StaticResource GlassCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="🏨 Room Occupancy" Style="{StaticResource TitleStyle}"/>

                            <!-- Fixed Donut Chart -->
                            <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20">

                                <!-- Outer Ring -->
                                <Ellipse Width="170" Height="170" Stroke="#4A5568" StrokeThickness="20" 
                                         Fill="Transparent"/>

                                <!-- Occupied Arc -->
                                <Path x:Name="OccupiedArcPath" 
                                      Stroke="#4CAF50" StrokeThickness="20" StrokeLineJoin="Round" 
                                      Fill="Transparent">
                                    <Path.Data>
                                        <PathGeometry>
                                            <PathFigure StartPoint="70,10">
                                                <ArcSegment Size="60,60" RotationAngle="0" IsLargeArc="False" 
                                                            SweepDirection="Clockwise" Point="128,47"/>
                                                <LineSegment Point="70,10"/>
                                            </PathFigure>
                                        </PathGeometry>
                                    </Path.Data>
                                </Path>

                                <!-- Available Arc -->
                                <Path x:Name="AvailableArcPath" 
                                      Stroke="#374151" StrokeThickness="20" StrokeLineJoin="Round" 
                                      Fill="Transparent">
                                    <Path.Data>
                                        <PathGeometry>
                                            <PathFigure StartPoint="70,10">
                                                <ArcSegment Size="60,60" RotationAngle="0" IsLargeArc="False" 
                                                            SweepDirection="Counterclockwise" Point="12,47"/>
                                                <LineSegment Point="70,10"/>
                                            </PathFigure>
                                        </PathGeometry>
                                    </Path.Data>
                                </Path>

                                <!-- Center Circle -->
                                <Ellipse x:Name="CenterPulseEllipse" Width="90" Height="90" 
                                         Stroke="#4CAF50" StrokeThickness="3" Fill="#1A202C"/>
                            </Grid>

                            <!-- Live Stats -->
                            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,24,0,0">
                                <TextBlock x:Name="OccupancyRateText" Text="72%" 
                                           FontSize="36" FontWeight="Bold" Foreground="#4CAF50">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#40000000" BlurRadius="8"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="Live Occupancy Rate" FontSize="15" Foreground="#94A3B8"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Activity Section -->
                <Grid Grid.Row="2" Margin="0,40,0,40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Recent Bookings -->
                    <Border Grid.Column="0" Style="{StaticResource GlassCardStyle}" Height="260">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="📅 Live Recent Bookings" Style="{StaticResource TitleStyle}"/>

                            <ListBox x:Name="RecentBookingsListBox" Grid.Row="1" 
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ItemTemplate="{StaticResource RecentBookingTemplate}"
                                     ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                                     MaxHeight="200"/>
                        </Grid>
                    </Border>

                    <!-- Quick Stats -->
                    <Border Grid.Column="1" Style="{StaticResource GlassCardStyle}" Height="260">
                        <StackPanel>
                            <TextBlock Text="⚡ Live Quick Stats" Style="{StaticResource TitleStyle}"/>

                            <!-- Rooms Cleaned -->
                            <StackPanel Orientation="Horizontal" Margin="0,20,0,24">
                                <Ellipse Width="60" Height="60" Margin="0,0,20,0" Fill="#FF9E6827">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#40000000" BlurRadius="12" ShadowDepth="4"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="RoomsCleanedText" Text="24" FontSize="28" 
                                               FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="Rooms Cleaned" FontSize="15" Foreground="White" FontWeight="Medium"/>
                                    <TextBlock x:Name="RoomsCleanedSubText" Text="Live +8 today" FontSize="13" Foreground="#F0D9B5"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- New Guests -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Ellipse Width="60" Height="60" Margin="0,0,20,0" Fill="#4CAF50">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#40000000" BlurRadius="12" ShadowDepth="4"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="NewGuestsText" Text="15" FontSize="28" 
                                               FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="New Guests" FontSize="15" Foreground="White" FontWeight="Medium"/>
                                    <TextBlock x:Name="NewGuestsSubText" Text="Live +3% week" FontSize="13" Foreground="#E8F5E8"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>