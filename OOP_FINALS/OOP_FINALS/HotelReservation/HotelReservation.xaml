<Window x:Class="OOP_FINALS.HotelReservation.HotelReservation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Johncis Lodge — Reservation System"
        Height="740" Width="1280"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent" AllowsTransparency="True"
        MouseDown="Window_MouseDown"
        Loaded="Window_Loaded">

    <Window.Resources>

        <!-- ══════════════════════════════════
             COLOUR PALETTE
        ══════════════════════════════════ -->
        <SolidColorBrush x:Key="BgRoot"        Color="#0A0804"/>
        <SolidColorBrush x:Key="BgSidebar"     Color="#110D08"/>
        <SolidColorBrush x:Key="BgPanel"       Color="#0F0C08"/>
        <SolidColorBrush x:Key="BgCard"        Color="#181210"/>
        <SolidColorBrush x:Key="BgInput"       Color="#1E1610"/>
        <SolidColorBrush x:Key="Gold"          Color="#C8882E"/>
        <SolidColorBrush x:Key="GoldLight"     Color="#E8B050"/>
        <SolidColorBrush x:Key="GoldDim"       Color="#6A4810"/>
        <SolidColorBrush x:Key="GoldFaint"     Color="#2A1C06"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="Black"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#B89A70"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#6A5030"/>
        <SolidColorBrush x:Key="BorderSubtle"  Color="#241A0E"/>
        <SolidColorBrush x:Key="BorderMid"     Color="#362614"/>
        <SolidColorBrush x:Key="Green"         Color="#28C068"/>
        <SolidColorBrush x:Key="GreenFaint"    Color="#0A1C10"/>
        <SolidColorBrush x:Key="Red"           Color="#E84848"/>
        <SolidColorBrush x:Key="Amber"         Color="#F0A020"/>

        <!-- ══════════════════════════════════
             TYPOGRAPHY HELPERS
        ══════════════════════════════════ -->
        <Style x:Key="EyebrowLabel" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#6A4810"/>
            <Setter Property="FontSize"     Value="9"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#B89A70"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="Margin"      Value="0,10,0,5"/>
        </Style>

        <!-- ══════════════════════════════════
             INPUTS
        ══════════════════════════════════ -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background"               Value="#1E1610"/>
            <Setter Property="Foreground"               Value="#F2E8D8"/>
            <Setter Property="CaretBrush"               Value="#C8882E"/>
            <Setter Property="BorderBrush"              Value="#241A0E"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="FontFamily"               Value="Segoe UI"/>
            <Setter Property="Height"                   Value="42"/>
            <Setter Property="Padding"                  Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#C8882E"/>
                                <Setter TargetName="bd" Property="Background"  Value="#261C0E"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#4A3218"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Background"      Value="#1E1610"/>
            <Setter Property="Foreground"      Value="Black"/>
            <Setter Property="BorderBrush"     Value="#241A0E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Padding"         Value="10,0"/>
        </Style>

        <Style x:Key="DateStyle" TargetType="DatePicker">
            <Setter Property="Background"      Value="#1E1610"/>
            <Setter Property="Foreground"      Value="Black"/>
            <Setter Property="BorderBrush"     Value="#241A0E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Height"          Value="42"/>
        </Style>

        <!-- ══════════════════════════════════
             BUTTONS
        ══════════════════════════════════ -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"  Value="#C8882E"/>
            <Setter Property="Foreground"  Value="#0A0804"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="FontSize"    Value="12.5"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="Height"      Value="44"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="9" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E8A040"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#A06820"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#241A0E"/>
                                <Setter Property="Foreground" Value="#4A3218"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="#C8882E"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="Height"      Value="42"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="9" Background="{TemplateBinding Background}"
                                BorderBrush="#362614" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#1E1610"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#C8882E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#8A7050"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="8" Background="{TemplateBinding Background}" Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A1208"/>
                                <Setter Property="Foreground" Value="#C8882E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Receipt row styles -->
        <Style x:Key="RcptLabel" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#8A7050"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="RcptValue" TargetType="TextBlock">
            <Setter Property="Foreground"            Value="#F2E8D8"/>
            <Setter Property="FontSize"              Value="12.5"/>
            <Setter Property="FontFamily"            Value="Segoe UI"/>
            <Setter Property="FontWeight"            Value="SemiBold"/>
            <Setter Property="HorizontalAlignment"   Value="Right"/>
            <Setter Property="VerticalAlignment"     Value="Center"/>
        </Style>

        <!-- Stat mini card value -->
        <Style x:Key="StatVal" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="22"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
        </Style>

    </Window.Resources>

    <!-- ══════════════════════════════════
         ROOT CHROME  (rounded, gold-border)
    ══════════════════════════════════ -->
    <Border CornerRadius="16">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0A0804" Offset="0"/>
                <GradientStop Color="#130E08" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="55" ShadowDepth="0" Opacity="0.96"/>
        </Border.Effect>

        <Border CornerRadius="16" BorderThickness="1">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#C8882E" Offset="0"/>
                    <GradientStop Color="#2A1C06" Offset="0.5"/>
                    <GradientStop Color="#C8882E" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ══════════════════════════════════
                     SIDEBAR
                ══════════════════════════════════ -->
                <Border Grid.Column="0" CornerRadius="16,0,0,16" BorderThickness="0,0,1,0"
                        BorderBrush="#1E1610">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#140E08" Offset="0"/>
                            <GradientStop Color="#110C07" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Brand -->
                        <StackPanel Grid.Row="0" Margin="16,20,16,14">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="40" Height="40" CornerRadius="10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#C8882E" Offset="0"/>
                                            <GradientStop Color="#7A5018" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="🏨" FontSize="19"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="JOHNCIS" Foreground="#C8882E" FontSize="14"
                                               FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Text="LODGE" Foreground="#4A3218" FontSize="9.5"
                                               FontFamily="Segoe UI" Margin="0,-1,0,0" FontWeight="Bold"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Height="1" Margin="0,14,0,0" Background="#1E1610"/>
                        </StackPanel>

                        <!-- Nav -->
                        <StackPanel Grid.Row="1" Margin="8,0">

                            <TextBlock Text="RESERVATION" Style="{StaticResource EyebrowLabel}" Margin="12,0,0,6"/>
                            <Button x:Name="btnNavNewBooking" Content="＋  New Booking"
                                    Style="{StaticResource NavBtn}" Click="NavNewBooking_Click"/>
                            <Button x:Name="btnNavRoomMap" Content="🗺  Room Map"
                                    Style="{StaticResource NavBtn}" Click="NavRoomMap_Click"/>
                            <Button x:Name="btnNavBookings" Content="📋  Active Bookings"
                                    Style="{StaticResource NavBtn}" Click="NavBookings_Click"/>

                            <Border Height="1" Background="#1A1208" Margin="8,10"/>

                            <TextBlock Text="OPERATIONS" Style="{StaticResource EyebrowLabel}" Margin="12,0,0,6"/>
                            <Button Content="🔍  Search Reservation"
                                    Style="{StaticResource NavBtn}" Click="BtnSearchReservation_Click"/>
                            <Button Content="✔  Check-Out Guest"
                                    Style="{StaticResource NavBtn}" Click="BtnCheckOut_Click"/>
                            <Button Content="📅  Extend Stay"
                                    Style="{StaticResource NavBtn}" Click="BtnExtendStay_Click"/>
                            <Button Content="🧹  Housekeeping Log"
                                    Style="{StaticResource NavBtn}" Click="BtnHousekeeping_Click"/>
                            <Button Content="🗑  Cancel Reservation" Foreground="#C04040"
                                    Style="{StaticResource NavBtn}" Click="BtnCancel_Click"/>

                            <Border Height="1" Background="#1A1208" Margin="8,10"/>

                            <!-- Dashboard Stats -->
                            <TextBlock Text="DASHBOARD" Style="{StaticResource EyebrowLabel}" Margin="12,0,0,8"/>

                            <Grid Margin="4,0,4,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="#160F08" CornerRadius="9" Padding="10,8"
                                        BorderBrush="#241A0E" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="OCCUPIED" Foreground="#4A3218" FontSize="8"
                                                   FontWeight="Bold" FontFamily="Segoe UI"/>
                                        <TextBlock x:Name="lblOccupied" Text="—" Foreground="#E84848"
                                                   Style="{StaticResource StatVal}" FontSize="20"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Background="#160F08" CornerRadius="9" Padding="10,8"
                                        BorderBrush="#241A0E" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="AVAILABLE" Foreground="#4A3218" FontSize="8"
                                                   FontWeight="Bold" FontFamily="Segoe UI"/>
                                        <TextBlock x:Name="lblAvailable" Text="—" Foreground="#28C068"
                                                   Style="{StaticResource StatVal}" FontSize="20"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid Margin="4,0,4,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="#160F08" CornerRadius="9" Padding="10,8"
                                        BorderBrush="#241A0E" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="ARRIVALS" Foreground="#4A3218" FontSize="8"
                                                   FontWeight="Bold" FontFamily="Segoe UI"/>
                                        <TextBlock x:Name="lblArrivals" Text="—" Foreground="#F0A020"
                                                   Style="{StaticResource StatVal}" FontSize="20"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Background="#160F08" CornerRadius="9" Padding="10,8"
                                        BorderBrush="#241A0E" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="REVENUE" Foreground="#4A3218" FontSize="8"
                                                   FontWeight="Bold" FontFamily="Segoe UI"/>
                                        <TextBlock x:Name="lblRevenue" Text="—" Foreground="#28C068"
                                                   FontSize="11" FontWeight="Bold" FontFamily="Segoe UI"
                                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                   Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                        </StackPanel>

                        <!-- Staff Footer -->
                        <Border Grid.Row="2" BorderBrush="#1A1208" BorderThickness="0,1,0,0" Padding="14,12">
                            <StackPanel>
                                <TextBlock x:Name="lblClock" Foreground="#2E2010" FontSize="9"
                                           FontFamily="Segoe UI" TextAlignment="Center" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="30" Height="30" CornerRadius="15" Background="#1A1208"
                                            BorderBrush="#2E2010" BorderThickness="1">
                                        <TextBlock Text="👤" FontSize="13"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Margin="9,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="lblStaffName" Text="Staff" Foreground="#D8C8A8"
                                                   FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                        <TextBlock x:Name="lblStaffRole" Text="Front Desk" Foreground="#6A4810"
                                                   FontSize="10" FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════
                     MAIN CONTENT AREA
                ══════════════════════════════════ -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Top Bar -->
                    <Border Grid.Row="0" CornerRadius="0,16,0,0"
                            BorderBrush="#1A1208" BorderThickness="0,0,0,1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#0E0A06" Offset="0"/>
                                <GradientStop Color="#110C07" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid Margin="20,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="3" Height="18" CornerRadius="2" Background="#C8882E" Margin="0,0,11,0"/>
                                <TextBlock x:Name="lblPageTitle" Text="New Reservation"
                                           Foreground="#F2E8D8" FontSize="14" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Button Content="—" Width="32" Height="26" Foreground="#6A5030"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Click="BtnMinimize_Click" FontFamily="Segoe UI" FontSize="13"/>
                                <Button Content="✕" Width="32" Height="26" Foreground="#6A5030"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Click="BtnClose_Click" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ══════════════════════════════════
                         CONTENT PANELS  (only one visible at a time)
                    ══════════════════════════════════ -->
                    <Grid Grid.Row="1" Margin="14,10,14,12">

                        <!-- ─────────────────────────────
                             PANEL: NEW BOOKING
                        ───────────────────────────── -->
                        <Grid x:Name="panelNewBooking">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Step Progress Bar -->
                            <Border Grid.Row="0" Background="#141008" CornerRadius="12"
                                    BorderBrush="#241A0E" BorderThickness="1"
                                    Padding="24,14" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Step 1 -->
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <Border x:Name="step1Circle" Width="36" Height="36" CornerRadius="18"
                                                Background="#C8882E" HorizontalAlignment="Center">
                                            <TextBlock Text="🛏" FontSize="16"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock x:Name="step1Lbl" Text="Select Room"
                                                   Foreground="#C8882E" FontSize="10" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" Margin="0,5,0,0" FontFamily="Segoe UI"/>
                                    </StackPanel>

                                    <Border Grid.Column="1" Height="2" VerticalAlignment="Center" Margin="0,0,0,18">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#C8882E" Offset="0"/>
                                                <GradientStop Color="#241A0E" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>

                                    <!-- Step 2 -->
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <Border x:Name="step2Circle" Width="36" Height="36" CornerRadius="18"
                                                Background="#1A1208" BorderBrush="#241A0E" BorderThickness="1"
                                                HorizontalAlignment="Center">
                                            <TextBlock x:Name="step2Icon" Text="👤" FontSize="16"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.35"/>
                                        </Border>
                                        <TextBlock x:Name="step2Lbl" Text="Guest Info"
                                                   Foreground="#4A3218" FontSize="10" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" Margin="0,5,0,0" FontFamily="Segoe UI"/>
                                    </StackPanel>

                                    <Border Grid.Column="3" Height="2" Background="#241A0E"
                                            VerticalAlignment="Center" Margin="0,0,0,18"/>

                                    <!-- Step 3 -->
                                    <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                        <Border x:Name="step3Circle" Width="36" Height="36" CornerRadius="18"
                                                Background="#1A1208" BorderBrush="#241A0E" BorderThickness="1"
                                                HorizontalAlignment="Center">
                                            <TextBlock x:Name="step3Icon" Text="💳" FontSize="16"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.35"/>
                                        </Border>
                                        <TextBlock x:Name="step3Lbl" Text="Payment"
                                                   Foreground="#4A3218" FontSize="10" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" Margin="0,5,0,0" FontFamily="Segoe UI"/>
                                    </StackPanel>

                                    <Border Grid.Column="5" Height="2" Background="#241A0E"
                                            VerticalAlignment="Center" Margin="0,0,0,18"/>

                                    <!-- Step 4 -->
                                    <StackPanel Grid.Column="6" HorizontalAlignment="Center">
                                        <Border x:Name="step4Circle" Width="36" Height="36" CornerRadius="18"
                                                Background="#1A1208" BorderBrush="#241A0E" BorderThickness="1"
                                                HorizontalAlignment="Center">
                                            <TextBlock x:Name="step4Icon" Text="✅" FontSize="16"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.35"/>
                                        </Border>
                                        <TextBlock x:Name="step4Lbl" Text="Confirmation"
                                                   Foreground="#4A3218" FontSize="10" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" Margin="0,5,0,0" FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Step Content -->
                            <Grid Grid.Row="1">

                                <!-- ━━━ STEP 1: ROOM SELECTION ━━━ -->
                                <Grid x:Name="pageStep1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Filter Bar -->
                                    <Border Grid.Row="0" Background="#141008" CornerRadius="11"
                                            BorderBrush="#241A0E" BorderThickness="1"
                                            Padding="18,12" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="110"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="CHECK-IN DATE" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                                <DatePicker x:Name="dpCheckIn" Style="{StaticResource DateStyle}"
                                                            SelectedDateChanged="DateFilter_Changed"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="CHECK-OUT DATE" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                                <DatePicker x:Name="dpCheckOut" Style="{StaticResource DateStyle}"
                                                            SelectedDateChanged="DateFilter_Changed"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="ROOM TYPE" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="cmbRoomTypeFilter" Style="{StaticResource ComboStyle}"
                                                          SelectionChanged="RoomTypeFilter_Changed">
                                                    <ComboBoxItem Content="All Types"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <Button Grid.Column="6" Content="↺  Refresh"
                                                    Style="{StaticResource BtnSecondary}"
                                                    Margin="0,22,0,0" Click="BtnRefresh_Click"/>
                                        </Grid>
                                    </Border>

                                    <!-- Room Cards -->
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <TextBlock x:Name="lblRoomStatus" Foreground="#6A5030"
                                                       FontSize="11" FontFamily="Segoe UI" Margin="2,0,0,8"/>
                                            <ItemsControl x:Name="icRoomCards">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Width="218" Height="180" CornerRadius="12" Margin="5"
                                                                Cursor="Hand" BorderThickness="1.5"
                                                                BorderBrush="{Binding BorderColor}"
                                                                Background="{Binding BackgroundColor}">
                                                            <Border.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick" Command="{Binding SelectCommand}"/>
                                                            </Border.InputBindings>
                                                            <Grid>
                                                                <Border CornerRadius="12,12,0,0" Height="3"
                                                                        VerticalAlignment="Top"
                                                                        Background="{Binding StatusColor}"/>
                                                                <StackPanel Margin="14,10,14,10" VerticalAlignment="Center">
                                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                        <TextBlock Text="{Binding RoomNumber}"
                                                                                   Foreground="#F2E8D8" FontSize="22"
                                                                                   FontWeight="Bold" FontFamily="Segoe UI"/>
                                                                        <Border CornerRadius="6" Padding="6,2" Margin="7,5,0,0"
                                                                                Background="{Binding StatusBadgeBg}" VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Status}"
                                                                                       Foreground="{Binding StatusColor}"
                                                                                       FontSize="9" FontWeight="Bold"
                                                                                       FontFamily="Segoe UI"/>
                                                                        </Border>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding TypeName}"
                                                                               Foreground="#B89A70" FontSize="12"
                                                                               FontFamily="Segoe UI" Margin="0,1,0,0"/>
                                                                    <TextBlock Text="{Binding Description}"
                                                                               Foreground="#6A5030" FontSize="10"
                                                                               FontFamily="Segoe UI" TextWrapping="Wrap"
                                                                               Margin="0,3,0,0" MaxHeight="28"/>
                                                                    <Border Height="1" Background="#241A0E" Margin="0,7"/>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="₱" Foreground="#C8882E"
                                                                                   FontSize="13" FontFamily="Segoe UI"
                                                                                   VerticalAlignment="Bottom" Margin="0,0,1,2"/>
                                                                        <TextBlock Text="{Binding PriceFormatted}"
                                                                                   Foreground="#C8882E" FontSize="19"
                                                                                   FontWeight="Bold" FontFamily="Segoe UI"/>
                                                                        <TextBlock Text="/3 hrs" Foreground="#4A3218"
                                                                                   FontSize="10.5" FontFamily="Segoe UI"
                                                                                   VerticalAlignment="Bottom" Margin="4,0,0,3"/>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding SelectHint}"
                                                                               Foreground="{Binding HintColor}"
                                                                               FontSize="10" FontFamily="Segoe UI"
                                                                               Margin="0,4,0,0" FontWeight="SemiBold"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <!-- Selected Room Bar -->
                                    <Border Grid.Row="2" x:Name="selectedRoomBar"
                                            Background="#141008" CornerRadius="11" Padding="18,12"
                                            BorderBrush="#C8882E" BorderThickness="1"
                                            Margin="0,8,0,0" Visibility="Collapsed">
                                        <Grid>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="SELECTED ROOM" Foreground="#6A4810"
                                                           FontSize="9" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                <TextBlock x:Name="lblSelectedRoomSummary"
                                                           Foreground="#F2E8D8" FontSize="13"
                                                           FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Button Content="✕  Deselect" Style="{StaticResource BtnSecondary}"
                                                        Width="110" Margin="0,0,10,0" Click="BtnDeselect_Click"/>
                                                <Button Content="Next: Guest Info  →"
                                                        Style="{StaticResource BtnPrimary}"
                                                        Width="180" Click="BtnStep1Next_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- ━━━ STEP 2: GUEST INFO ━━━ -->
                                <Grid x:Name="pageStep2" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <!-- Guest Identity -->
                                            <Border Background="#141008" CornerRadius="12"
                                                    BorderBrush="#C8882E" BorderThickness="1"
                                                    Padding="22,18" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                                        <Border Width="34" Height="34" CornerRadius="9"
                                                                Background="#1A1208" BorderBrush="#362614" BorderThickness="1">
                                                            <TextBlock Text="👤" FontSize="16"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock Text="GUEST INFORMATION" Foreground="#C8882E"
                                                                       FontSize="12" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                            <TextBlock Text="Identity and contact details"
                                                                       Foreground="#6A4810" FontSize="10.5" FontFamily="Segoe UI"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="FIRST NAME" Style="{StaticResource FieldLabel}"/>
                                                            <TextBox x:Name="txtFirstName" Style="{StaticResource InputStyle}"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="LAST NAME" Style="{StaticResource FieldLabel}"/>
                                                            <TextBox x:Name="txtLastName" Style="{StaticResource InputStyle}"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Margin="0,4,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="CONTACT NUMBER" Style="{StaticResource FieldLabel}"/>
                                                            <TextBox x:Name="txtContactNumber" Style="{StaticResource InputStyle}"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="EMAIL ADDRESS" Style="{StaticResource FieldLabel}"/>
                                                            <TextBox x:Name="txtEmail" Style="{StaticResource InputStyle}"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Margin="0,4,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="VALID ID TYPE" Style="{StaticResource FieldLabel}"/>
                                                            <ComboBox x:Name="cmbIDType" Style="{StaticResource ComboStyle}">
                                                                <ComboBoxItem Content="Passport"/>
                                                                <ComboBoxItem Content="Driver's License"/>
                                                                <ComboBoxItem Content="SSS ID"/>
                                                                <ComboBoxItem Content="PhilHealth ID"/>
                                                                <ComboBoxItem Content="Voter's ID"/>
                                                                <ComboBoxItem Content="National ID"/>
                                                            </ComboBox>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="ID NUMBER" Style="{StaticResource FieldLabel}"/>
                                                            <TextBox x:Name="txtIDNumber" Style="{StaticResource InputStyle}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <!-- Stay Details -->
                                            <Border Background="#141008" CornerRadius="12"
                                                    BorderBrush="#241A0E" BorderThickness="1"
                                                    Padding="22,18" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                                        <Border Width="34" Height="34" CornerRadius="9"
                                                                Background="#1A1208" BorderBrush="#362614" BorderThickness="1">
                                                            <TextBlock Text="🛏️" FontSize="16"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock Text="STAY DETAILS" Foreground="#C8882E"
                                                                       FontSize="12" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                            <TextBlock Text="Dates and number of guests"
                                                                       Foreground="#6A4810" FontSize="10.5" FontFamily="Segoe UI"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="CHECK-IN DATE" Style="{StaticResource FieldLabel}"/>
                                                            <Border Background="#1A1208" CornerRadius="8"
                                                                    Padding="12,11" BorderBrush="#241A0E" BorderThickness="1" Height="42">
                                                                <TextBlock x:Name="lblCheckInDisplay"
                                                                           Foreground="#F2E8D8" FontSize="12.5" FontFamily="Segoe UI"
                                                                           VerticalAlignment="Center"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="CHECK-OUT DATE" Style="{StaticResource FieldLabel}"/>
                                                            <Border Background="#1A1208" CornerRadius="8"
                                                                    Padding="12,11" BorderBrush="#241A0E" BorderThickness="1" Height="42">
                                                                <TextBlock x:Name="lblCheckOutDisplay"
                                                                           Foreground="#F2E8D8" FontSize="12.5" FontFamily="Segoe UI"
                                                                           VerticalAlignment="Center"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="4">
                                                            <TextBlock Text="NO. OF GUESTS" Style="{StaticResource FieldLabel}"/>
                                                            <ComboBox x:Name="cmbGuests" Style="{StaticResource ComboStyle}">
                                                                <ComboBoxItem Content="1"/>
                                                                <ComboBoxItem Content="2"/>
                                                                <ComboBoxItem Content="3"/>
                                                                <ComboBoxItem Content="4"/>
                                                                <ComboBoxItem Content="5"/>
                                                                <ComboBoxItem Content="6"/>
                                                            </ComboBox>
                                                        </StackPanel>
                                                    </Grid>

                                                    <TextBlock Text="PROCESSED BY (STAFF)" Style="{StaticResource FieldLabel}"/>
                                                    <ComboBox x:Name="cmbStaff" Style="{StaticResource ComboStyle}"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <Grid Grid.Row="1" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="200"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="← Back"
                                                Style="{StaticResource BtnSecondary}" Click="BtnStep2Back_Click"/>
                                        <Button Grid.Column="2" Content="Next: Payment  →"
                                                Style="{StaticResource BtnPrimary}" Click="BtnStep2Next_Click"/>
                                    </Grid>
                                </Grid>

                                <!-- ━━━ STEP 3: PAYMENT ━━━ -->
                                <Grid x:Name="pageStep3" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="330"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left: Payment form -->
                                    <Grid Grid.Column="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <Border Background="#141008" CornerRadius="12"
                                                        BorderBrush="#C8882E" BorderThickness="1"
                                                        Padding="22,18" Margin="0,0,0,10">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                                            <Border Width="34" Height="34" CornerRadius="9"
                                                                    Background="#1A1208" BorderBrush="#362614" BorderThickness="1">
                                                                <TextBlock Text="💳" FontSize="16"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                                                <TextBlock Text="PAYMENT DETAILS" Foreground="#C8882E"
                                                                           FontSize="12" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                                <TextBlock Text="How the guest will settle the bill"
                                                                           Foreground="#6A4810" FontSize="10.5" FontFamily="Segoe UI"/>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="PAYMENT METHOD" Style="{StaticResource FieldLabel}"/>
                                                                <ComboBox x:Name="cmbPaymentMethod" Style="{StaticResource ComboStyle}">
                                                                    <ComboBoxItem Content="Cash"/>
                                                                    <ComboBoxItem Content="Credit Card"/>
                                                                    <ComboBoxItem Content="Debit Card"/>
                                                                    <ComboBoxItem Content="GCash"/>
                                                                    <ComboBoxItem Content="Maya"/>
                                                                    <ComboBoxItem Content="Bank Transfer"/>
                                                                </ComboBox>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="REFERENCE NUMBER" Style="{StaticResource FieldLabel}"/>
                                                                <TextBox x:Name="txtPaymentRef" Style="{StaticResource InputStyle}"/>
                                                            </StackPanel>
                                                        </Grid>

                                                        <Grid Margin="0,6,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="DISCOUNT (₱)" Style="{StaticResource FieldLabel}"/>
                                                                <TextBox x:Name="txtDiscount" Style="{StaticResource InputStyle}"
                                                                         Text="0" TextChanged="Discount_Changed"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="AMOUNT PAID (₱)" Style="{StaticResource FieldLabel}"/>
                                                                <TextBox x:Name="txtAmountPaid" Style="{StaticResource InputStyle}"
                                                                         TextChanged="AmountPaid_Changed"/>
                                                            </StackPanel>
                                                        </Grid>

                                                        <Border Background="#0E0A06" CornerRadius="8"
                                                                Padding="14,11" BorderBrush="#241A0E"
                                                                BorderThickness="1" Margin="0,12,0,0">
                                                            <TextBlock x:Name="lblPaymentStatus"
                                                                       Text="— Enter amount above"
                                                                       Foreground="#4A3218"
                                                                       FontSize="12" FontFamily="Segoe UI"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Additional Charges -->
                                                <Border Background="#141008" CornerRadius="12"
                                                        BorderBrush="#241A0E" BorderThickness="1"
                                                        Padding="22,18">
                                                    <StackPanel>
                                                        <TextBlock Text="ADDITIONAL CHARGES" Foreground="#C8882E"
                                                                   FontSize="11.5" FontWeight="Bold"
                                                                   FontFamily="Segoe UI" Margin="0,0,0,4"/>
                                                        <TextBlock Text="Optional — add extra services to the bill"
                                                                   Foreground="#6A4810" FontSize="10"
                                                                   FontFamily="Segoe UI" Margin="0,0,0,12"/>

                                                        <!-- Entry Row -->
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="2*"/>
                                                                <ColumnDefinition Width="8"/>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition Width="8"/>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition Width="8"/>
                                                                <ColumnDefinition Width="80"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox x:Name="txtItemDesc" Style="{StaticResource InputStyle}"
                                                                     Height="38" Grid.Column="0"/>
                                                            <TextBox x:Name="txtItemQty" Style="{StaticResource InputStyle}"
                                                                     Height="38" Grid.Column="2"/>
                                                            <TextBox x:Name="txtItemPrice" Style="{StaticResource InputStyle}"
                                                                     Height="38" Grid.Column="4"/>
                                                            <Button Grid.Column="6" Content="＋ Add"
                                                                    Style="{StaticResource BtnSecondary}"
                                                                    Height="38" Click="AddBillingItem_Click"/>
                                                        </Grid>
                                                        <!-- Column Hints -->
                                                        <Grid Margin="0,4,0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="2*"/>
                                                                <ColumnDefinition Width="8"/>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition Width="8"/>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition Width="96"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="Description" Foreground="#4A3218" FontSize="9.5" FontFamily="Segoe UI" Margin="4,0,0,0"/>
                                                            <TextBlock Grid.Column="2" Text="Qty"         Foreground="#4A3218" FontSize="9.5" FontFamily="Segoe UI" Margin="4,0,0,0"/>
                                                            <TextBlock Grid.Column="4" Text="Unit Price"  Foreground="#4A3218" FontSize="9.5" FontFamily="Segoe UI" Margin="4,0,0,0"/>
                                                        </Grid>

                                                        <ListView x:Name="lvBillingItems" Background="Transparent"
                                                                  BorderThickness="0" Foreground="#F2E8D8"
                                                                  FontFamily="Segoe UI" FontSize="12" MaxHeight="100">
                                                            <ListView.View>
                                                                <GridView>
                                                                    <GridViewColumn Header="Description" Width="180" DisplayMemberBinding="{Binding Description}"/>
                                                                    <GridViewColumn Header="Qty"         Width="52"  DisplayMemberBinding="{Binding Quantity}"/>
                                                                    <GridViewColumn Header="Unit Price"  Width="90"  DisplayMemberBinding="{Binding UnitPrice}"/>
                                                                    <GridViewColumn Header="Subtotal"    Width="90"  DisplayMemberBinding="{Binding Subtotal}"/>
                                                                </GridView>
                                                            </ListView.View>
                                                        </ListView>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <Grid Grid.Row="1" Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="220"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="← Back"
                                                    Style="{StaticResource BtnSecondary}" Click="BtnStep3Back_Click"/>
                                            <Button Grid.Column="2" Content="✔  CONFIRM BOOKING"
                                                    Style="{StaticResource BtnPrimary}" Click="BtnBook_Click"/>
                                        </Grid>
                                    </Grid>

                                    <!-- Right: Billing Summary -->
                                    <Border Grid.Column="2" Background="#141008" CornerRadius="12"
                                            BorderBrush="#241A0E" BorderThickness="1" Padding="20,18">
                                        <StackPanel>
                                            <TextBlock Text="🧾  BOOKING SUMMARY" Foreground="#C8882E"
                                                       FontSize="11.5" FontWeight="Bold"
                                                       FontFamily="Segoe UI" Margin="0,0,0,16"/>

                                            <!-- Room Info -->
                                            <Border Background="#0E0A06" CornerRadius="10"
                                                    Padding="14,12" Margin="0,0,0,12"
                                                    BorderBrush="#241A0E" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock x:Name="summRoomNumber" Foreground="#F2E8D8"
                                                               FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                    <TextBlock x:Name="summRoomType" Foreground="#B89A70"
                                                               FontSize="12" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                                                    <TextBlock x:Name="summDates" Foreground="#6A5030"
                                                               FontSize="10.5" FontFamily="Segoe UI" Margin="0,5,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Totals -->
                                            <Border Background="#0E0A06" CornerRadius="10"
                                                    Padding="14,12" BorderBrush="#241A0E" BorderThickness="1">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,8">
                                                        <TextBlock Text="Rate / 3 hrs" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="lblRoomRate" Style="{StaticResource RcptValue}" Foreground="#C8882E"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,8">
                                                        <TextBlock Text="Sessions" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="lblNights" Style="{StaticResource RcptValue}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,8">
                                                        <TextBlock Text="Subtotal" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="lblSubtotal" Style="{StaticResource RcptValue}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,8">
                                                        <TextBlock Text="Tax (12%)" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="lblTax" Style="{StaticResource RcptValue}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,4">
                                                        <TextBlock Text="Discount" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="lblDiscount" Style="{StaticResource RcptValue}" Foreground="#E84848"/>
                                                    </Grid>
                                                    <Border Height="1" Background="#241A0E" Margin="0,10"/>
                                                    <Grid>
                                                        <TextBlock Text="TOTAL DUE" Foreground="#F2E8D8"
                                                                   FontSize="14" FontWeight="Bold" FontFamily="Segoe UI"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="lblTotal" HorizontalAlignment="Right"
                                                                   Foreground="#28C068" FontSize="20"
                                                                   FontWeight="Bold" FontFamily="Segoe UI"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- ━━━ STEP 4: CONFIRMATION ━━━ -->
                                <Grid x:Name="pageStep4" Visibility="Collapsed">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel HorizontalAlignment="Center" MaxWidth="680" Margin="0,16,0,16">

                                            <Border Width="80" Height="80" CornerRadius="40"
                                                    Background="#0A1C10" HorizontalAlignment="Center"
                                                    BorderBrush="#28C068" BorderThickness="2">
                                                <TextBlock Text="✓" Foreground="#28C068" FontSize="38"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontFamily="Segoe UI" FontWeight="Bold"/>
                                            </Border>

                                            <TextBlock Text="BOOKING CONFIRMED" Foreground="#28C068"
                                                       FontSize="22" FontWeight="Bold" FontFamily="Segoe UI"
                                                       HorizontalAlignment="Center" Margin="0,16,0,4"/>
                                            <TextBlock x:Name="lblConfirmSubtitle"
                                                       Text="A confirmation has been recorded for the guest."
                                                       Foreground="#6A5030" FontSize="12.5"
                                                       FontFamily="Segoe UI" HorizontalAlignment="Center"
                                                       Margin="0,0,0,22"/>

                                            <!-- Receipt -->
                                            <Border Background="#141008" CornerRadius="14"
                                                    BorderBrush="#C8882E" BorderThickness="1" Padding="26,22">
                                                <StackPanel>
                                                    <TextBlock Text="TRANSACTION RECEIPT" Foreground="#C8882E"
                                                               FontSize="10.5" FontWeight="Bold" FontFamily="Segoe UI"
                                                               HorizontalAlignment="Center" Margin="0,0,0,20"/>

                                                    <Border Background="#0E0A06" CornerRadius="9"
                                                            Padding="0,12" Margin="0,0,0,16"
                                                            BorderBrush="#2A1C06" BorderThickness="1">
                                                        <StackPanel HorizontalAlignment="Center">
                                                            <TextBlock Text="RESERVATION ID" Foreground="#6A5030"
                                                                       FontSize="9" FontWeight="Bold" FontFamily="Segoe UI"
                                                                       HorizontalAlignment="Center"/>
                                                            <TextBlock x:Name="rcptResID" Foreground="#C8882E"
                                                                       FontSize="28" FontWeight="Bold"
                                                                       FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Height="1" Background="#241A0E" Margin="0,0,0,12"/>

                                                    <Grid Margin="0,0,0,9">
                                                        <TextBlock Text="Guest Name" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="rcptGuest" Style="{StaticResource RcptValue}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,9">
                                                        <TextBlock Text="Email" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="rcptEmail" Style="{StaticResource RcptValue}" FontSize="11"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,9">
                                                        <TextBlock Text="Room" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="rcptRoom" Style="{StaticResource RcptValue}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,9">
                                                        <TextBlock Text="Check-In" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="rcptCheckIn" Style="{StaticResource RcptValue}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,9">
                                                        <TextBlock Text="Check-Out" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="rcptCheckOut" Style="{StaticResource RcptValue}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,9">
                                                        <TextBlock Text="Sessions (3 hrs each)" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="rcptNights" Style="{StaticResource RcptValue}"/>
                                                    </Grid>

                                                    <Border Height="1" Background="#241A0E" Margin="0,6,0,12"/>

                                                    <Grid Margin="0,0,0,9">
                                                        <TextBlock Text="Total Due" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="rcptTotal" Style="{StaticResource RcptValue}" Foreground="#28C068" FontSize="15"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,9">
                                                        <TextBlock Text="Amount Paid" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="rcptAmountPaid" Style="{StaticResource RcptValue}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,9">
                                                        <TextBlock Text="Payment Status" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="rcptPayStatus" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                    </Grid>
                                                    <Grid>
                                                        <TextBlock Text="Payment Date &amp; Time" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="rcptPaymentDate" Style="{StaticResource RcptValue}" Foreground="#B89A70" FontSize="11"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <Grid Margin="0,18,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Content="📋  View All Bookings"
                                                        Style="{StaticResource BtnSecondary}"
                                                        Click="BtnViewBookings_Click"/>
                                                <Button Grid.Column="2" Content="＋  New Booking"
                                                        Style="{StaticResource BtnPrimary}"
                                                        Click="BtnNewBookingFromConfirm_Click"/>
                                            </Grid>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>

                            </Grid>
                        </Grid>

                        <!-- ─────────────────────────────
                             PANEL: ACTIVE BOOKINGS
                        ───────────────────────────── -->
                        <Grid x:Name="panelBookings" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Search -->
                            <Border Grid.Row="0" Background="#141008" CornerRadius="11"
                                    BorderBrush="#241A0E" BorderThickness="1"
                                    Padding="16,10" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔎" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#6A5030"/>
                                    <TextBox x:Name="txtSearch" Style="{StaticResource InputStyle}"
                                             Width="340" Height="36" TextChanged="TxtSearch_TextChanged"/>
                                    <TextBlock Text="Search by guest name, reservation ID, or room number"
                                               Foreground="#2E2010" FontSize="10.5" FontFamily="Segoe UI"
                                               VerticalAlignment="Center" Margin="14,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Table Header -->
                            <Border Grid.Row="1" Background="#0E0A06" CornerRadius="8"
                                    Padding="10,8" Margin="0,0,0,3" BorderBrush="#241A0E" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="65"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="62"/>
                                        <ColumnDefinition Width="125"/>
                                        <ColumnDefinition Width="94"/>
                                        <ColumnDefinition Width="94"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="105"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"  Text="RES. ID"   Foreground="#6A4810" FontSize="9.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Grid.Column="1"  Text="GUEST"     Foreground="#6A4810" FontSize="9.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Grid.Column="2"  Text="ROOM"      Foreground="#6A4810" FontSize="9.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Grid.Column="3"  Text="TYPE"      Foreground="#6A4810" FontSize="9.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Grid.Column="4"  Text="CHECK-IN"  Foreground="#6A4810" FontSize="9.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Grid.Column="5"  Text="CHECK-OUT" Foreground="#6A4810" FontSize="9.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Grid.Column="6"  Text="PAX"       Foreground="#6A4810" FontSize="9.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Grid.Column="7"  Text="TOTAL"     Foreground="#6A4810" FontSize="9.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Grid.Column="8"  Text="STATUS"    Foreground="#6A4810" FontSize="9.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Grid.Column="9"  Text="PAYMENT"   Foreground="#6A4810" FontSize="9.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Grid.Column="10" Text="PAID AT"   Foreground="#6A4810" FontSize="9.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                                </Grid>
                            </Border>

                            <ListView x:Name="lvBookings" Grid.Row="2"
                                      Background="Transparent" BorderThickness="0"
                                      Foreground="#D8C8A8" FontFamily="Segoe UI" FontSize="12"
                                      SelectionChanged="LvBookings_SelectionChanged">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="" Width="65"   DisplayMemberBinding="{Binding ReservationID}"/>
                                        <GridViewColumn Header="" Width="150"  DisplayMemberBinding="{Binding GuestName}"/>
                                        <GridViewColumn Header="" Width="62"   DisplayMemberBinding="{Binding RoomNumber}"/>
                                        <GridViewColumn Header="" Width="125"  DisplayMemberBinding="{Binding RoomType}"/>
                                        <GridViewColumn Header="" Width="94"   DisplayMemberBinding="{Binding CheckIn}"/>
                                        <GridViewColumn Header="" Width="94"   DisplayMemberBinding="{Binding CheckOut}"/>
                                        <GridViewColumn Header="" Width="50"   DisplayMemberBinding="{Binding Guests}"/>
                                        <GridViewColumn Header="" Width="105"  DisplayMemberBinding="{Binding Total}"/>
                                        <GridViewColumn Header="" Width="90"   DisplayMemberBinding="{Binding Status}"/>
                                        <GridViewColumn Header="" Width="90"   DisplayMemberBinding="{Binding PaymentStatus}"/>
                                        <GridViewColumn Header="" Width="140"  DisplayMemberBinding="{Binding PaymentDate}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>

                        <!-- ─────────────────────────────
                             PANEL: ROOM MAP
                        ───────────────────────────── -->
                        <Grid x:Name="panelRoomMap" Visibility="Collapsed">
                            <Border Background="#141008" CornerRadius="13"
                                    BorderBrush="#241A0E" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Legend -->
                                    <Grid Grid.Row="0" Margin="20,14,20,12">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="🗺  FULL ROOM MAP" Foreground="#C8882E"
                                                       FontSize="13" FontWeight="Bold" FontFamily="Segoe UI"/>
                                            <StackPanel Orientation="Horizontal" Margin="24,0,0,0">
                                                <Ellipse Width="8" Height="8" Fill="#28C068" VerticalAlignment="Center"/>
                                                <TextBlock Text="Available" Foreground="#6A5030" FontSize="10"
                                                           Margin="5,0,12,0" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                                <Ellipse Width="8" Height="8" Fill="#E84848" VerticalAlignment="Center"/>
                                                <TextBlock Text="Occupied"  Foreground="#6A5030" FontSize="10"
                                                           Margin="5,0,12,0" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                                <Ellipse Width="8" Height="8" Fill="#F0A020" VerticalAlignment="Center"/>
                                                <TextBlock Text="Cleaning"  Foreground="#6A5030" FontSize="10"
                                                           Margin="5,0,12,0" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                                <Ellipse Width="8" Height="8" Fill="#666" VerticalAlignment="Center"/>
                                                <TextBlock Text="Maint."    Foreground="#6A5030" FontSize="10"
                                                           Margin="5,0,0,0"  FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button Content="⟳  Refresh" HorizontalAlignment="Right"
                                                Style="{StaticResource BtnSecondary}" Width="100"
                                                Click="BtnRefresh_Click"/>
                                    </Grid>

                                    <ScrollViewer Grid.Row="1" Margin="12,0,12,12"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="icRoomsLarge">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="140" Height="112" CornerRadius="11" Margin="5"
                                                            Cursor="Hand" BorderThickness="1"
                                                            BorderBrush="{Binding BorderColor}"
                                                            Background="{Binding BackgroundColor}">
                                                        <Grid>
                                                            <Border CornerRadius="11,11,0,0" Height="3"
                                                                    VerticalAlignment="Top"
                                                                    Background="{Binding StatusColor}"/>
                                                            <StackPanel VerticalAlignment="Center"
                                                                        HorizontalAlignment="Center"
                                                                        Margin="0,4,0,0">
                                                                <TextBlock Text="{Binding RoomNumber}"
                                                                           Foreground="#F2E8D8" FontSize="22"
                                                                           FontWeight="Bold" FontFamily="Segoe UI"
                                                                           HorizontalAlignment="Center"/>
                                                                <TextBlock Text="{Binding TypeName}"
                                                                           Foreground="#B89A70" FontSize="10"
                                                                           FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                                                                <TextBlock Text="{Binding PriceDisplay}"
                                                                           Foreground="#C8882E" FontSize="10"
                                                                           FontWeight="SemiBold" FontFamily="Segoe UI"
                                                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                                <Border CornerRadius="6" Padding="6,2" Margin="0,5,0,0"
                                                                        Background="{Binding StatusBadgeBg}">
                                                                    <TextBlock Text="{Binding Status}"
                                                                               Foreground="{Binding StatusColor}"
                                                                               FontSize="9" FontWeight="Bold"
                                                                               FontFamily="Segoe UI"
                                                                               HorizontalAlignment="Center"/>
                                                                </Border>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ─────────────────────────────
                             PANEL: EXTEND STAY
                        ───────────────────────────── -->
                        <Grid x:Name="panelExtendStay" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Border Grid.Row="0" Background="#141008" CornerRadius="11"
                                    BorderBrush="#C8882E" BorderThickness="1"
                                    Padding="18,13" Margin="0,0,0,10">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="34" Height="34" CornerRadius="9" Background="#1A1208"
                                                BorderBrush="#362614" BorderThickness="1">
                                            <TextBlock Text="📅" FontSize="16"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="EXTEND GUEST STAY" Foreground="#C8882E"
                                                       FontSize="12.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                                            <TextBlock Text="Add more 3-hour sessions to an existing confirmed reservation"
                                                       Foreground="#6A4810" FontSize="10.5" FontFamily="Segoe UI"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Button Content="← Back to Bookings" HorizontalAlignment="Right"
                                            Style="{StaticResource BtnSecondary}" Width="150"
                                            Click="BtnExtendBack_Click"/>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="360"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left: Extension Form -->
                                <Border Grid.Column="0" Background="#141008" CornerRadius="12"
                                        BorderBrush="#241A0E" BorderThickness="1" Padding="22,20">
                                    <StackPanel>
                                        <!-- Current Booking Info -->
                                        <Border Background="#0E0A06" CornerRadius="9"
                                                Padding="16,13" Margin="0,0,0,18"
                                                BorderBrush="#241A0E" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="RESERVATION" Foreground="#6A4810" FontSize="8.5"
                                                               FontWeight="Bold" FontFamily="Segoe UI"/>
                                                    <TextBlock x:Name="extResID" Foreground="#C8882E"
                                                               FontSize="18" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,4,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="GUEST" Foreground="#6A4810" FontSize="8.5"
                                                               FontWeight="Bold" FontFamily="Segoe UI"/>
                                                    <TextBlock x:Name="extGuestName" Foreground="#F2E8D8"
                                                               FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,4,0,0"/>
                                                    <TextBlock x:Name="extRoomInfo" Foreground="#B89A70"
                                                               FontSize="11" FontFamily="Segoe UI"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="CURRENT CHECK-OUT" Foreground="#6A4810" FontSize="8.5"
                                                               FontWeight="Bold" FontFamily="Segoe UI"/>
                                                    <TextBlock x:Name="extCurrentCheckOut" Foreground="#F0A020"
                                                               FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="EXTENSION DETAILS" Foreground="#6A4810"
                                                   FontSize="9" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,12"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="ADDITIONAL SESSIONS" Style="{StaticResource FieldLabel}"/>
                                                <ComboBox x:Name="cmbExtSessions" Style="{StaticResource ComboStyle}"
                                                          SelectionChanged="ExtSessions_Changed">
                                                    <ComboBoxItem Content="1  (3 hrs)"/>
                                                    <ComboBoxItem Content="2  (6 hrs)"/>
                                                    <ComboBoxItem Content="3  (9 hrs)"/>
                                                    <ComboBoxItem Content="4  (12 hrs)"/>
                                                    <ComboBoxItem Content="5  (15 hrs)"/>
                                                    <ComboBoxItem Content="6  (18 hrs)"/>
                                                    <ComboBoxItem Content="7  (21 hrs)"/>
                                                    <ComboBoxItem Content="8  (24 hrs)"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="NEW CHECK-OUT DATE" Style="{StaticResource FieldLabel}"/>
                                                <Border Background="#1A1208" CornerRadius="8"
                                                        Padding="12,10" BorderBrush="#C8882E" BorderThickness="1" Height="42">
                                                    <TextBlock x:Name="extNewCheckOut" Foreground="#28C068"
                                                               FontSize="12.5" FontWeight="SemiBold" FontFamily="Segoe UI"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <Border Height="1" Background="#241A0E" Margin="0,18,0,18"/>

                                        <TextBlock Text="EXTENSION PAYMENT" Foreground="#6A4810"
                                                   FontSize="9" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,12"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="PAYMENT METHOD" Style="{StaticResource FieldLabel}"/>
                                                <ComboBox x:Name="cmbExtPayMethod" Style="{StaticResource ComboStyle}">
                                                    <ComboBoxItem Content="Cash"/>
                                                    <ComboBoxItem Content="Credit Card"/>
                                                    <ComboBoxItem Content="Debit Card"/>
                                                    <ComboBoxItem Content="GCash"/>
                                                    <ComboBoxItem Content="Maya"/>
                                                    <ComboBoxItem Content="Bank Transfer"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="REFERENCE NUMBER" Style="{StaticResource FieldLabel}"/>
                                                <TextBox x:Name="txtExtPayRef" Style="{StaticResource InputStyle}"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="DISCOUNT (₱)" Style="{StaticResource FieldLabel}"/>
                                                <TextBox x:Name="txtExtDiscount" Style="{StaticResource InputStyle}"
                                                         Text="0" TextChanged="ExtDiscount_Changed"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="AMOUNT PAID (₱)" Style="{StaticResource FieldLabel}"/>
                                                <TextBox x:Name="txtExtAmountPaid" Style="{StaticResource InputStyle}"
                                                         TextChanged="ExtAmountPaid_Changed"/>
                                            </StackPanel>
                                        </Grid>

                                        <Border Background="#0E0A06" CornerRadius="8"
                                                Padding="14,11" BorderBrush="#241A0E"
                                                BorderThickness="1" Margin="0,12,0,0">
                                            <TextBlock x:Name="lblExtPayStatus"
                                                       Text="— Enter amount above"
                                                       Foreground="#4A3218"
                                                       FontSize="12" FontFamily="Segoe UI"/>
                                        </Border>

                                        <Button Content="📅  CONFIRM EXTENSION"
                                                Style="{StaticResource BtnPrimary}"
                                                Margin="0,18,0,0" Click="BtnConfirmExtension_Click"/>
                                    </StackPanel>
                                </Border>

                                <!-- Right: Extension Summary -->
                                <Border Grid.Column="2" Background="#141008" CornerRadius="12"
                                        BorderBrush="#241A0E" BorderThickness="1" Padding="20,18">
                                    <StackPanel>
                                        <TextBlock Text="🧾  EXTENSION SUMMARY" Foreground="#C8882E"
                                                   FontSize="11.5" FontWeight="Bold"
                                                   FontFamily="Segoe UI" Margin="0,0,0,16"/>

                                        <Border Background="#0E0A06" CornerRadius="10"
                                                Padding="14,12" Margin="0,0,0,12"
                                                BorderBrush="#241A0E" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock x:Name="extSummRoom" Foreground="#F2E8D8"
                                                           FontSize="17" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                <TextBlock x:Name="extSummType" Foreground="#B89A70"
                                                           FontSize="11.5" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                                                <TextBlock x:Name="extSummPeriod" Foreground="#6A5030"
                                                           FontSize="10.5" FontFamily="Segoe UI" Margin="0,5,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Background="#0E0A06" CornerRadius="10"
                                                Padding="14,12" BorderBrush="#241A0E" BorderThickness="1">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,8">
                                                    <TextBlock Text="Rate / 3 hrs" Style="{StaticResource RcptLabel}"/>
                                                    <TextBlock x:Name="extSummRate" Style="{StaticResource RcptValue}" Foreground="#C8882E"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,8">
                                                    <TextBlock Text="Sessions to Add" Style="{StaticResource RcptLabel}"/>
                                                    <TextBlock x:Name="extSummSessions" Style="{StaticResource RcptValue}"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,8">
                                                    <TextBlock Text="Subtotal" Style="{StaticResource RcptLabel}"/>
                                                    <TextBlock x:Name="extSummSubtotal" Style="{StaticResource RcptValue}"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,8">
                                                    <TextBlock Text="Tax (12%)" Style="{StaticResource RcptLabel}"/>
                                                    <TextBlock x:Name="extSummTax" Style="{StaticResource RcptValue}"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,4">
                                                    <TextBlock Text="Discount" Style="{StaticResource RcptLabel}"/>
                                                    <TextBlock x:Name="extSummDiscount" Style="{StaticResource RcptValue}" Foreground="#E84848"/>
                                                </Grid>
                                                <Border Height="1" Background="#241A0E" Margin="0,10"/>
                                                <Grid>
                                                    <TextBlock Text="EXTENSION TOTAL" Foreground="#F2E8D8"
                                                               FontSize="13" FontWeight="Bold" FontFamily="Segoe UI"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="extSummTotal" HorizontalAlignment="Right"
                                                               Foreground="#28C068" FontSize="20"
                                                               FontWeight="Bold" FontFamily="Segoe UI"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- Info Note -->
                                        <Border Background="#0A1810" CornerRadius="9"
                                                Padding="13,11" Margin="0,12,0,0"
                                                BorderBrush="#162A1A" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="ℹ  HOW EXTENSION WORKS"
                                                           Foreground="#28C068" FontSize="9.5" FontWeight="Bold"
                                                           FontFamily="Segoe UI" Margin="0,0,0,7"/>
                                                <TextBlock TextWrapping="Wrap" Foreground="#4A7058" FontSize="10"
                                                           FontFamily="Segoe UI" LineHeight="16">
                                                    Each session = 3 hours. The room stays Occupied and the guest's check-out is pushed forward. A separate payment record is created for the extension.
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
