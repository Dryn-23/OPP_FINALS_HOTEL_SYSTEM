<Window x:Class="OOP_FINALS.HotelReservation.HotelReservation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Johncis Lodge — Reservation System"
        Height="960" Width="1700"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent" AllowsTransparency="True"
        MouseDown="Window_MouseDown"
        Loaded="Window_Loaded">

    <Window.Resources>

        <!-- COLOR PALETTE -->
        <SolidColorBrush x:Key="BgDark"        Color="#0D0D0D"/>
        <SolidColorBrush x:Key="BgPanel"       Color="#141414"/>
        <SolidColorBrush x:Key="BgCard"        Color="#1C1C1C"/>
        <SolidColorBrush x:Key="BgInput"       Color="#242424"/>
        <SolidColorBrush x:Key="AccentGold"    Color="#C9922A"/>
        <SolidColorBrush x:Key="AccentGoldDim" Color="#7F5915"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#28AEED"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#F0F0F0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#888888"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#444444"/>
        <SolidColorBrush x:Key="StatusGreen"   Color="#2ECC71"/>
        <SolidColorBrush x:Key="StatusRed"     Color="#E53935"/>
        <SolidColorBrush x:Key="StatusOrange"  Color="#FF9800"/>
        <SolidColorBrush x:Key="Divider"       Color="#2A2A2A"/>

        <!-- LABEL STYLE -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#888888"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,12,0,4"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
        </Style>

        <!-- INPUT STYLE -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background"        Value="#242424"/>
            <Setter Property="Foreground"        Value="#F0F0F0"/>
            <Setter Property="CaretBrush"        Value="#C9922A"/>
            <Setter Property="BorderBrush"       Value="#2A2A2A"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="Height"            Value="38"/>
            <Setter Property="Padding"           Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#C9922A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#7F5915"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- COMBO STYLE -->
        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Background"      Value="#242424"/>
            <Setter Property="Foreground"      Value="#F0F0F0"/>
            <Setter Property="BorderBrush"     Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="Padding"         Value="8,0"/>
        </Style>

        <!-- DATEPICKER STYLE -->
        <Style x:Key="DateStyle" TargetType="DatePicker">
            <Setter Property="Background"      Value="#242424"/>
            <Setter Property="Foreground"      Value="#F0F0F0"/>
            <Setter Property="BorderBrush"     Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Height"          Value="38"/>
        </Style>

        <!-- PRIMARY BUTTON -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"  Value="#C9922A"/>
            <Setter Property="Foreground"  Value="#0D0D0D"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="Height"      Value="42"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="8"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E0A830"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#A07020"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SECONDARY BUTTON -->
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background"  Value="#242424"/>
            <Setter Property="Foreground"  Value="#C9922A"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="Height"      Value="36"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#C9922A" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A2A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DANGER BUTTON -->
        <Style x:Key="BtnDanger" TargetType="Button">
            <Setter Property="Background"  Value="#3A1010"/>
            <Setter Property="Foreground"  Value="#E53935"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="Height"      Value="36"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#E53935" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#4A1515"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SECTION TITLE -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#F0F0F0"/>
            <Setter Property="FontSize"    Value="15"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="Margin"      Value="0,0,0,16"/>
        </Style>

        <!-- STAT CARD TITLE -->
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#888888"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="Margin"      Value="0,0,0,2"/>
        </Style>

        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#F0F0F0"/>
            <Setter Property="FontSize"    Value="26"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="Margin"      Value="0,0,0,14"/>
        </Style>

    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROOT BORDER                                        -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Border CornerRadius="14">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D0D0D" Offset="0"/>
                <GradientStop Color="#141008" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.9"/>
        </Border.Effect>

        <Border CornerRadius="14" BorderThickness="1">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#C9922A" Offset="0"/>
                    <GradientStop Color="#3A2A0A" Offset="0.5"/>
                    <GradientStop Color="#C9922A" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/>
                    <!-- Top bar -->
                    <RowDefinition Height="*"/>
                    <!-- Main content -->
                    <RowDefinition Height="230"/>
                    <!-- Footer / bookings list -->
                </Grid.RowDefinitions>

                <!-- ══════════════════════════════════════ -->
                <!-- TOP BAR                               -->
                <!-- ══════════════════════════════════════ -->
                <Border Grid.Row="0" Background="#0A0A0A"
                        CornerRadius="14,14,0,0"
                        BorderBrush="#1E1E1E" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Logo / Title -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="18,0">
                            <TextBlock Text="🏨" FontSize="18" VerticalAlignment="Center"/>
                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center">
                                <Run Text="JOHNCIS LODGE" Foreground="#C9922A"
                                     FontWeight="Bold" FontSize="14" FontFamily="Segoe UI"/>
                                <Run Text="  ·  RESERVATION SYSTEM" Foreground="#555555"
                                     FontSize="11" FontFamily="Segoe UI"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Clock -->
                        <TextBlock x:Name="lblClock" Grid.Column="1"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#555555" FontSize="12" FontFamily="Segoe UI"/>

                        <!-- Window controls -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,12,0">
                            <Button Content="—" Width="36" Height="28" Margin="2,0"
                                    Foreground="#888" Background="Transparent"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="BtnMinimize_Click" FontFamily="Segoe UI"/>
                            <Button Content="✕" Width="36" Height="28" Margin="2,0"
                                    Foreground="#888" Background="Transparent"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="BtnClose_Click" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════ -->
                <!-- MAIN CONTENT                          -->
                <!-- ══════════════════════════════════════ -->
                <Grid Grid.Row="1" Margin="16,12,16,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="400"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="330"/>
                    </Grid.ColumnDefinitions>

                    <!-- ═══════════════════════════════════ -->
                    <!-- LEFT PANEL – RESERVATION FORM      -->
                    <!-- ═══════════════════════════════════ -->
                    <Border Grid.Column="0" CornerRadius="12"
                            Background="#141414" Margin="0,0,8,0"
                            BorderBrush="#1E1E1E" BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="22,20">

                                <!-- ── SECTION: CUSTOMER INFO ── -->
                                <TextBlock Style="{StaticResource SectionTitle}"
                                           Text="👤  GUEST INFORMATION"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="FIRST NAME" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="txtFirstName" Style="{StaticResource InputStyle}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="LAST NAME" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="txtLastName" Style="{StaticResource InputStyle}"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="CONTACT NUMBER" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="txtContactNumber" Style="{StaticResource InputStyle}"/>

                                <TextBlock Text="EMAIL ADDRESS" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="txtEmail" Style="{StaticResource InputStyle}"/>

                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="VALID ID TYPE" Style="{StaticResource FieldLabel}"/>
                                        <ComboBox x:Name="cmbIDType" Style="{StaticResource ComboStyle}">
                                            <ComboBoxItem Content="Passport"/>
                                            <ComboBoxItem Content="Driver's License"/>
                                            <ComboBoxItem Content="SSS ID"/>
                                            <ComboBoxItem Content="PhilHealth ID"/>
                                            <ComboBoxItem Content="Voter's ID"/>
                                            <ComboBoxItem Content="National ID"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="ID NUMBER" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="txtIDNumber" Style="{StaticResource InputStyle}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- DIVIDER -->
                                <Border Height="1" Background="#1E1E1E" Margin="0,18,0,0"/>

                                <!-- ── SECTION: RESERVATION DETAILS ── -->
                                <TextBlock Style="{StaticResource SectionTitle}"
                                           Text="🛏️  RESERVATION DETAILS"
                                           Margin="0,18,0,16"/>

                                <TextBlock Text="ROOM" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="cmbRoom" Style="{StaticResource ComboStyle}"
                                          SelectionChanged="CmbRoom_SelectionChanged"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="CHECK-IN DATE" Style="{StaticResource FieldLabel}"/>
                                        <DatePicker x:Name="dpCheckIn" Style="{StaticResource DateStyle}"
                                                    SelectedDateChanged="DatePicker_Changed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="CHECK-OUT DATE" Style="{StaticResource FieldLabel}"/>
                                        <DatePicker x:Name="dpCheckOut" Style="{StaticResource DateStyle}"
                                                    SelectedDateChanged="DatePicker_Changed"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="NUMBER OF GUESTS" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="cmbGuests" Style="{StaticResource ComboStyle}">
                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="2"/>
                                    <ComboBoxItem Content="3"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="5"/>
                                    <ComboBoxItem Content="6"/>
                                </ComboBox>

                                <!-- BILLING PREVIEW -->
                                <Border CornerRadius="8" Background="#1C1C1C"
                                        BorderBrush="#2A2A2A" BorderThickness="1"
                                        Margin="0,14,0,0" Padding="14,12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition Height="1"/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <TextBlock Text="Room / Night" Foreground="#666" FontSize="12" FontFamily="Segoe UI"/>
                                            <TextBlock x:Name="lblRoomRate" HorizontalAlignment="Right"
                                                       Foreground="#C9922A" FontSize="12" FontFamily="Segoe UI" FontWeight="SemiBold"/>
                                        </Grid>
                                        <Grid Grid.Row="1" Margin="0,6,0,0">
                                            <TextBlock Text="Nights" Foreground="#666" FontSize="12" FontFamily="Segoe UI"/>
                                            <TextBlock x:Name="lblNights" HorizontalAlignment="Right"
                                                       Foreground="#888" FontSize="12" FontFamily="Segoe UI"/>
                                        </Grid>
                                        <Grid Grid.Row="2" Margin="0,6,0,8">
                                            <TextBlock Text="Tax (12%)" Foreground="#666" FontSize="12" FontFamily="Segoe UI"/>
                                            <TextBlock x:Name="lblTax" HorizontalAlignment="Right"
                                                       Foreground="#888" FontSize="12" FontFamily="Segoe UI"/>
                                        </Grid>
                                        <Border Grid.Row="3" Background="#2A2A2A"/>
                                        <Grid Grid.Row="4" Margin="0,8,0,0">
                                            <TextBlock Text="TOTAL" Foreground="#F0F0F0"
                                                       FontSize="14" FontWeight="Bold" FontFamily="Segoe UI"/>
                                            <TextBlock x:Name="lblTotal" HorizontalAlignment="Right"
                                                       Foreground="#2ECC71" FontSize="14"
                                                       FontWeight="Bold" FontFamily="Segoe UI"/>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- DIVIDER -->
                                <Border Height="1" Background="#1E1E1E" Margin="0,18,0,0"/>

                                <!-- ── SECTION: PAYMENT ── -->
                                <TextBlock Style="{StaticResource SectionTitle}"
                                           Text="💳  PAYMENT"
                                           Margin="0,18,0,16"/>

                                <TextBlock Text="PAYMENT METHOD" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="cmbPaymentMethod" Style="{StaticResource ComboStyle}">
                                    <ComboBoxItem Content="Cash"/>
                                    <ComboBoxItem Content="Credit Card"/>
                                    <ComboBoxItem Content="Debit Card"/>
                                    <ComboBoxItem Content="GCash"/>
                                    <ComboBoxItem Content="Maya"/>
                                    <ComboBoxItem Content="Bank Transfer"/>
                                </ComboBox>

                                <TextBlock Text="REFERENCE NUMBER" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="txtPaymentRef" Style="{StaticResource InputStyle}"/>

                                <TextBlock Text="AMOUNT PAID" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="txtAmountPaid" Style="{StaticResource InputStyle}"/>

                                <!-- CREATED BY (Staff) -->
                                <TextBlock Text="PROCESSED BY (STAFF)" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="cmbStaff" Style="{StaticResource ComboStyle}"/>

                                <!-- ACTION BUTTONS -->
                                <Button Content="✔  CONFIRM BOOKING"
                                        Style="{StaticResource BtnPrimary}"
                                        Margin="0,20,0,6"
                                        Click="BtnBook_Click"/>

                                <Button Content="✕  CLEAR FORM"
                                        Style="{StaticResource BtnSecondary}"
                                        Click="BtnClear_Click"/>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- ═══════════════════════════════════ -->
                    <!-- CENTER PANEL – ROOM GRID           -->
                    <!-- ═══════════════════════════════════ -->
                    <Border Grid.Column="1" CornerRadius="12"
                            Background="#141414" Margin="0,0,8,0"
                            BorderBrush="#1E1E1E" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header row -->
                            <Grid Grid.Row="0" Margin="18,16,18,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🗺️  ROOM MAP"
                                           Style="{StaticResource SectionTitle}"
                                           Margin="0"/>
                                <Button Grid.Column="1" Content="⟳  Refresh"
                                        Style="{StaticResource BtnSecondary}"
                                        Width="90" Click="BtnRefresh_Click"/>
                            </Grid>

                            <!-- Legend -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="18,0,18,12">
                                <Ellipse Width="10" Height="10" Fill="#2ECC71" VerticalAlignment="Center"/>
                                <TextBlock Text="Available" Foreground="#666" FontSize="11" Margin="4,0,16,0" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                <Ellipse Width="10" Height="10" Fill="#E53935" VerticalAlignment="Center"/>
                                <TextBlock Text="Occupied" Foreground="#666" FontSize="11" Margin="4,0,16,0" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                <Ellipse Width="10" Height="10" Fill="#FF9800" VerticalAlignment="Center"/>
                                <TextBlock Text="Cleaning" Foreground="#666" FontSize="11" Margin="4,0,16,0" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                <Ellipse Width="10" Height="10" Fill="#555555" VerticalAlignment="Center"/>
                                <TextBlock Text="Maintenance" Foreground="#666" FontSize="11" Margin="4,0,0,0" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Room Grid -->
                            <ScrollViewer Grid.Row="2" Margin="14,0,14,14"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="icRooms">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- Room Card -->
                                            <Border x:Name="roomCard"
                                                    Width="110" Height="100"
                                                    CornerRadius="10"
                                                    Margin="5"
                                                    Cursor="Hand"
                                                    BorderThickness="1"
                                                    BorderBrush="{Binding BorderColor}"
                                                    Background="{Binding BackgroundColor}">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="Black" BlurRadius="10"
                                                                      ShadowDepth="2" Opacity="0.4"/>
                                                </Border.Effect>
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick"
                                                                  Command="{Binding RoomClickCommand}"/>
                                                </Border.InputBindings>
                                                <Grid>
                                                    <!-- Status bar top -->
                                                    <Border CornerRadius="10,10,0,0" Height="5"
                                                            VerticalAlignment="Top"
                                                            Background="{Binding StatusColor}"/>
                                                    <StackPanel VerticalAlignment="Center"
                                                                HorizontalAlignment="Center"
                                                                Margin="0,6,0,0">
                                                        <TextBlock Text="{Binding RoomNumber}"
                                                                   Foreground="#F0F0F0"
                                                                   FontSize="20"
                                                                   FontWeight="Bold"
                                                                   FontFamily="Segoe UI"
                                                                   HorizontalAlignment="Center"/>
                                                        <TextBlock Text="{Binding TypeName}"
                                                                   Foreground="#888888"
                                                                   FontSize="9"
                                                                   FontFamily="Segoe UI"
                                                                   HorizontalAlignment="Center"
                                                                   TextWrapping="Wrap"
                                                                   TextAlignment="Center"
                                                                   MaxWidth="100"
                                                                   Margin="0,2,0,0"/>
                                                        <Border CornerRadius="4"
                                                                Padding="6,2"
                                                                Margin="0,6,0,0"
                                                                Background="{Binding StatusBadgeBg}">
                                                            <TextBlock Text="{Binding Status}"
                                                                       Foreground="{Binding StatusColor}"
                                                                       FontSize="9"
                                                                       FontWeight="Bold"
                                                                       FontFamily="Segoe UI"
                                                                       HorizontalAlignment="Center"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- ═══════════════════════════════════ -->
                    <!-- RIGHT PANEL – STATS + ACTIONS      -->
                    <!-- ═══════════════════════════════════ -->
                    <Border Grid.Column="2" CornerRadius="12"
                            Background="#141414"
                            BorderBrush="#1E1E1E" BorderThickness="1">
                        <StackPanel Margin="22,20">

                            <TextBlock Text="📊  DASHBOARD" Style="{StaticResource SectionTitle}"/>

                            <!-- Stat Cards -->
                            <Border CornerRadius="8" Background="#1C1C1C"
                                    BorderBrush="#2A2A2A" BorderThickness="1"
                                    Padding="14,12" Margin="0,0,0,8">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="OCCUPIED ROOMS" Style="{StaticResource StatLabel}"/>
                                        <TextBlock x:Name="lblOccupied" Style="{StaticResource StatValue}"
                                                   Foreground="#E53935"/>
                                    </StackPanel>
                                    <TextBlock Text="🔴" FontSize="28" HorizontalAlignment="Right"
                                               VerticalAlignment="Center" Opacity="0.3"/>
                                </Grid>
                            </Border>

                            <Border CornerRadius="8" Background="#1C1C1C"
                                    BorderBrush="#2A2A2A" BorderThickness="1"
                                    Padding="14,12" Margin="0,0,0,8">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="AVAILABLE ROOMS" Style="{StaticResource StatLabel}"/>
                                        <TextBlock x:Name="lblAvailable" Style="{StaticResource StatValue}"
                                                   Foreground="#2ECC71"/>
                                    </StackPanel>
                                    <TextBlock Text="🟢" FontSize="28" HorizontalAlignment="Right"
                                               VerticalAlignment="Center" Opacity="0.3"/>
                                </Grid>
                            </Border>

                            <Border CornerRadius="8" Background="#1C1C1C"
                                    BorderBrush="#2A2A2A" BorderThickness="1"
                                    Padding="14,12" Margin="0,0,0,8">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="TODAY'S ARRIVALS" Style="{StaticResource StatLabel}"/>
                                        <TextBlock x:Name="lblArrivals" Style="{StaticResource StatValue}"
                                                   Foreground="#FF9800"/>
                                    </StackPanel>
                                    <TextBlock Text="📅" FontSize="28" HorizontalAlignment="Right"
                                               VerticalAlignment="Center" Opacity="0.3"/>
                                </Grid>
                            </Border>

                            <Border CornerRadius="8" Background="#1C1C1C"
                                    BorderBrush="#2A2A2A" BorderThickness="1"
                                    Padding="14,12" Margin="0,0,0,8">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="TODAY'S REVENUE" Style="{StaticResource StatLabel}"/>
                                        <TextBlock x:Name="lblRevenue" Style="{StaticResource StatValue}"
                                                   Foreground="#2ECC71"/>
                                    </StackPanel>
                                    <TextBlock Text="💰" FontSize="28" HorizontalAlignment="Right"
                                               VerticalAlignment="Center" Opacity="0.3"/>
                                </Grid>
                            </Border>

                            <!-- DIVIDER -->
                            <Border Height="1" Background="#1E1E1E" Margin="0,6,0,14"/>

                            <!-- Quick actions -->
                            <TextBlock Text="⚡  QUICK ACTIONS"
                                       Foreground="#888888" FontSize="10"
                                       FontWeight="SemiBold" FontFamily="Segoe UI"
                                       Margin="0,0,0,10"/>

                            <Button Content="🔍  Search Reservation"
                                    Style="{StaticResource BtnSecondary}"
                                    Margin="0,0,0,6"
                                    Click="BtnSearchReservation_Click"/>

                            <Button Content="✔  Check-Out Guest"
                                    Style="{StaticResource BtnSecondary}"
                                    Margin="0,0,0,6"
                                    Click="BtnCheckOut_Click"/>

                            <Button Content="🧹  Housekeeping Log"
                                    Style="{StaticResource BtnSecondary}"
                                    Margin="0,0,0,6"
                                    Click="BtnHousekeeping_Click"/>

                            <Button Content="🗑  Cancel Reservation"
                                    Style="{StaticResource BtnDanger}"
                                    Margin="0,0,0,6"
                                    Click="BtnCancel_Click"/>

                            <Border Height="1" Background="#1E1E1E" Margin="0,6,0,14"/>

                            <TextBlock Text="🔎  SEARCH GUEST"
                                       Foreground="#888888" FontSize="10"
                                       FontWeight="SemiBold" FontFamily="Segoe UI"
                                       Margin="0,0,0,6"/>

                            <TextBox x:Name="txtSearch"
                                     Style="{StaticResource InputStyle}"
                                     Height="36"
                                     TextChanged="TxtSearch_TextChanged"/>

                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ══════════════════════════════════════ -->
                <!-- FOOTER – BOOKING LIST                 -->
                <!-- ══════════════════════════════════════ -->
                <Border Grid.Row="2" CornerRadius="12"
                        Background="#141414" Margin="16,0,16,14"
                        BorderBrush="#1E1E1E" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="18,12,18,8">
                            <TextBlock Text="📋  ACTIVE RESERVATIONS"
                                       Style="{StaticResource SectionTitle}" Margin="0"/>
                        </Grid>

                        <ListView x:Name="lvBookings" Grid.Row="1"
                                  Margin="10,0,10,10"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="#F0F0F0"
                                  FontFamily="Segoe UI"
                                  FontSize="12"
                                  SelectionChanged="LvBookings_SelectionChanged">

                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Res. ID"   Width="70"  DisplayMemberBinding="{Binding ReservationID}"/>
                                    <GridViewColumn Header="Guest Name" Width="160" DisplayMemberBinding="{Binding GuestName}"/>
                                    <GridViewColumn Header="Room"      Width="70"  DisplayMemberBinding="{Binding RoomNumber}"/>
                                    <GridViewColumn Header="Type"      Width="130" DisplayMemberBinding="{Binding RoomType}"/>
                                    <GridViewColumn Header="Check-In"  Width="100" DisplayMemberBinding="{Binding CheckIn}"/>
                                    <GridViewColumn Header="Check-Out" Width="100" DisplayMemberBinding="{Binding CheckOut}"/>
                                    <GridViewColumn Header="Guests"    Width="60"  DisplayMemberBinding="{Binding Guests}"/>
                                    <GridViewColumn Header="Total"     Width="100" DisplayMemberBinding="{Binding Total}"/>
                                    <GridViewColumn Header="Status"    Width="100" DisplayMemberBinding="{Binding Status}"/>
                                    <GridViewColumn Header="Payment"   Width="100" DisplayMemberBinding="{Binding PaymentStatus}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Border>
</Window>
