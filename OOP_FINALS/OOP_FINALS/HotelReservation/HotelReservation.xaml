<Window x:Class="OOP_FINALS.HotelReservation.HotelReservation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Johncis Lodge — Reservation System"
        Height="720" Width="1240"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent" AllowsTransparency="True"
        MouseDown="Window_MouseDown"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- ═══════ PALETTE ═══════ -->
        <SolidColorBrush x:Key="BgRoot"        Color="#0B0806"/>
        <SolidColorBrush x:Key="BgSidebar"     Color="#0E0C09"/>
        <SolidColorBrush x:Key="BgPanel"       Color="#141009"/>
        <SolidColorBrush x:Key="BgCard"        Color="#1C150E"/>
        <SolidColorBrush x:Key="BgInput"       Color="#231A11"/>
        <SolidColorBrush x:Key="BgInputHover"  Color="#2C2014"/>
        <SolidColorBrush x:Key="Gold"          Color="#D4973A"/>
        <SolidColorBrush x:Key="GoldLight"     Color="#EDBA5A"/>
        <SolidColorBrush x:Key="GoldDim"       Color="#7A5514"/>
        <SolidColorBrush x:Key="GoldFaint"     Color="#3D2A0A"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="BLACK"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#C4A882"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#7A6040"/>
        <SolidColorBrush x:Key="TextDim"       Color="#3D2E1E"/>
        <SolidColorBrush x:Key="Border1"       Color="#2A1E12"/>
        <SolidColorBrush x:Key="Border2"       Color="#3D2C18"/>
        <SolidColorBrush x:Key="GreenOk"       Color="#2DD36F"/>
        <SolidColorBrush x:Key="GreenFaint"    Color="#0D2018"/>
        <SolidColorBrush x:Key="RedAlert"      Color="#F25555"/>
        <SolidColorBrush x:Key="OrangeWarn"    Color="#F5A623"/>

        <!-- ═══════ SECTION LABEL ═══════ -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#7A5514"/>
            <Setter Property="FontSize"    Value="9"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="Margin"      Value="14,0,0,7"/>
        </Style>

        <!-- ═══════ FIELD LABEL ═══════ -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#C4A882"/>
            <Setter Property="FontSize"    Value="10.5"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,10,0,5"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
        </Style>

        <!-- ═══════ INPUT ═══════ -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background"               Value="#231A11"/>
            <Setter Property="Foreground"               Value="BLACK"/>
            <Setter Property="CaretBrush"               Value="#D4973A"/>
            <Setter Property="BorderBrush"              Value="#2A1E12"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="FontFamily"               Value="Segoe UI"/>
            <Setter Property="Height"                   Value="44"/>
            <Setter Property="Padding"                  Value="13,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#D4973A"/>
                                <Setter TargetName="bd" Property="Background"  Value="#2C1F10"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#5A3E1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════ COMBOBOX ═══════ -->
        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Background"      Value="#231A11"/>
            <Setter Property="Foreground"      Value="Black"/>
            <Setter Property="BorderBrush"     Value="#2A1E12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="Padding"         Value="11,0"/>
        </Style>

        <!-- ═══════ DATEPICKER ═══════ -->
        <Style x:Key="DateStyle" TargetType="DatePicker">
            <Setter Property="Background"      Value="#231A11"/>
            <Setter Property="Foreground"      Value="Black"/>
            <Setter Property="BorderBrush"     Value="#2A1E12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Height"          Value="44"/>
        </Style>

        <!-- ═══════ PRIMARY BUTTON ═══════ -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"  Value="#D4973A"/>
            <Setter Property="Foreground"  Value="#0B0806"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="Height"      Value="48"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="11" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EDBA5A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#A87228"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#2A1E12"/>
                                <Setter Property="Foreground" Value="#5A3E1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════ SECONDARY BUTTON ═══════ -->
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background"  Value="#1C150E"/>
            <Setter Property="Foreground"  Value="#D4973A"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="Height"      Value="44"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="9" Background="{TemplateBinding Background}"
                                BorderBrush="#3D2C18" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#261C0F"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#D4973A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════ NAV BUTTON ═══════ -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#C4A882"/>
            <Setter Property="FontSize"        Value="12.5"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="9" Background="{TemplateBinding Background}" Padding="14,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1C150E"/>
                                <Setter Property="Foreground" Value="#D4973A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════ STAT CARD ═══════ -->
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#7A6040"/>
            <Setter Property="FontSize"    Value="9"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
        </Style>

        <!-- ═══════ RECEIPT ROW ═══════ -->
        <Style x:Key="RcptLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#C4A882"/>
            <Setter Property="FontSize"    Value="12.5"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="RcptValue" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#F7EFE0"/>
            <Setter Property="FontSize"    Value="12.5"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
        </Style>
    </Window.Resources>

    <!-- ROOT CHROME -->
    <Border CornerRadius="18">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0B0806" Offset="0"/>
                <GradientStop Color="#141009" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="60" ShadowDepth="0" Opacity="0.98"/>
        </Border.Effect>

        <Border CornerRadius="18" BorderThickness="1">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#D4973A" Offset="0"/>
                    <GradientStop Color="#3D2A0A" Offset="0.5"/>
                    <GradientStop Color="#D4973A" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

               
                <Border Grid.Column="0"
        CornerRadius="18,0,0,18"
        BorderBrush="#1C150E"
        BorderThickness="0,0,1,0">

                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            
                            <GradientStop Color="#6B3F1D" Offset="0"/>

                            
                            <GradientStop Color="#8C4F1F" Offset="0.5"/>

                            
                            <GradientStop Color="#A65A1E" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>


                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Logo -->
                        <StackPanel Grid.Row="0" Margin="18,24,18,16">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="42" Height="42" CornerRadius="12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#D4973A" Offset="0"/>
                                            <GradientStop Color="#8A5E1A" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="🏨" FontSize="20"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="JOHNCIS" Foreground="#D4973A" FontSize="15"
                                               FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Text="LODGE" Foreground="#5A3E1C" FontSize="10"
                                               FontFamily="Segoe UI" Margin="0,-2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Height="1" Margin="0,16,0,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#2A1E12" Offset="0"/>
                                        <GradientStop Color="#3D2C18" Offset="0.5"/>
                                        <GradientStop Color="#2A1E12" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </StackPanel>

                        <!-- Navigation -->
                        <StackPanel Grid.Row="1" Margin="10,4,10,0">
                            <TextBlock Text="RESERVATION" Style="{StaticResource SectionLabel}"/>
                            <Button x:Name="btnNavNewBooking" Content="  ＋  New Booking"
                                    Style="{StaticResource NavBtn}" Click="NavNewBooking_Click"/>
                            <Button x:Name="btnNavRoomMap" Content="  🗺  Room Map"
                                    Style="{StaticResource NavBtn}" Click="NavRoomMap_Click"/>
                            <Button x:Name="btnNavBookings" Content="  📋  Active Bookings"
                                    Style="{StaticResource NavBtn}" Click="NavBookings_Click"/>

                            <Border Height="1" Background="#1C150E" Margin="10,10"/>

                            <TextBlock Text="OPERATIONS" Style="{StaticResource SectionLabel}"/>
                            <Button Content="  🔍  Search Reservation"
                                    Style="{StaticResource NavBtn}" Click="BtnSearchReservation_Click"/>
                            <Button Content="  ✔  Check-Out Guest"
                                    Style="{StaticResource NavBtn}" Click="BtnCheckOut_Click"/>
                            <Button Content="  📅  Extend Stay"
                                    Style="{StaticResource NavBtn}" Click="BtnExtendStay_Click"/>
                            <Button Content="  🧹  Housekeeping Log"
                                    Style="{StaticResource NavBtn}" Click="BtnHousekeeping_Click"/>
                            <Button Content="  🗑  Cancel Reservation"
                                    Style="{StaticResource NavBtn}"
                                    Foreground="#F25555" Click="BtnCancel_Click"/>

                            <Border Height="1" Background="#1C150E" Margin="10,10"/>

                            <!-- Dashboard Stats -->
                            <TextBlock Text="DASHBOARD" Style="{StaticResource SectionLabel}"/>

                            <Border Background="#1C150E" CornerRadius="10" Padding="14,10" Margin="2,2">
                                <Grid>
                                    <TextBlock Text="OCCUPIED" Style="{StaticResource StatLabel}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="lblOccupied" HorizontalAlignment="Right"
                                               Foreground="#F25555" FontSize="20" FontWeight="Bold"
                                               FontFamily="Segoe UI" Text="—" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Background="#1C150E" CornerRadius="10" Padding="14,10" Margin="2,2">
                                <Grid>
                                    <TextBlock Text="AVAILABLE" Style="{StaticResource StatLabel}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="lblAvailable" HorizontalAlignment="Right"
                                               Foreground="#2DD36F" FontSize="20" FontWeight="Bold"
                                               FontFamily="Segoe UI" Text="—" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Background="#1C150E" CornerRadius="10" Padding="14,10" Margin="2,2">
                                <Grid>
                                    <TextBlock Text="ARRIVALS TODAY" Style="{StaticResource StatLabel}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="lblArrivals" HorizontalAlignment="Right"
                                               Foreground="#F5A623" FontSize="20" FontWeight="Bold"
                                               FontFamily="Segoe UI" Text="—" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Background="#1C150E" CornerRadius="10" Padding="14,10" Margin="2,2">
                                <Grid>
                                    <TextBlock Text="TODAY'S REVENUE" Style="{StaticResource StatLabel}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="lblRevenue" HorizontalAlignment="Right"
                                               Foreground="#2DD36F" FontSize="12" FontWeight="Bold"
                                               FontFamily="Segoe UI" Text="—" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Staff Footer -->
                        <Border Grid.Row="2" BorderBrush="#1C150E" BorderThickness="0,1,0,0" Padding="14,12">
                            <StackPanel>
                                <TextBlock x:Name="lblClock" Foreground="#3D2E1E" FontSize="9.5"
                                           FontFamily="Segoe UI" TextAlignment="Center"/>
                                <Border Height="1" Background="#1C150E" Margin="0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="32" Height="32" CornerRadius="16" Background="#231A11"
                                            BorderBrush="#3D2C18" BorderThickness="1">
                                        <TextBlock Text="👤" FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Margin="9,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="lblStaffName" Text="Staff" Foreground="#F7EFE0"
                                                   FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                        <TextBlock x:Name="lblStaffRole" Text="Front Desk" Foreground="#7A5514"
                                                   FontSize="10" FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- ═══════ MAIN CONTENT ═══════ -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="52"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- TOP BAR -->
                    <Border Grid.Row="0" Background="#0E0C09" CornerRadius="0,18,0,0"
                            BorderBrush="#1C150E" BorderThickness="0,0,0,1">
                        <Grid Margin="22,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="4" Height="20" CornerRadius="2" Background="#D4973A" Margin="0,0,12,0"/>
                                <TextBlock x:Name="lblPageTitle" Text="New Reservation"
                                           Foreground="#F7EFE0" FontSize="14.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                        VerticalAlignment="Center" Margin="0,0,2,0">
                                <Button Content="—" Width="36" Height="28" Foreground="#7A6040"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Click="BtnMinimize_Click" FontFamily="Segoe UI" FontSize="14"/>
                                <Button Content="✕" Width="36" Height="28"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Click="BtnClose_Click" FontFamily="Segoe UI" Foreground="#7A6040"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ═══════ PANELS ═══════ -->
                    <Grid Grid.Row="1" Margin="16,12,16,12">

                        <!-- ─── PANEL: NEW BOOKING ─── -->
                        <Grid x:Name="panelNewBooking">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Step Progress -->
                            <Border Grid.Row="0" Background="#1C150E" CornerRadius="14"
                                    BorderBrush="#2A1E12" BorderThickness="1"
                                    Padding="28,16" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <Border x:Name="step1Circle" Width="38" Height="38" CornerRadius="19"
                                                Background="#D4973A" HorizontalAlignment="Center">
                                            <TextBlock Text="🛏" FontSize="17"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock x:Name="step1Lbl" Text="Select Room"
                                                   Foreground="#D4973A" FontSize="10.5" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0" FontFamily="Segoe UI"/>
                                    </StackPanel>

                                    <Border Grid.Column="1" Height="2" VerticalAlignment="Center" Margin="0,0,0,20">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#D4973A" Offset="0"/>
                                                <GradientStop Color="#2A1E12" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>

                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <Border x:Name="step2Circle" Width="38" Height="38" CornerRadius="19"
                                                Background="#231A11" BorderBrush="#2A1E12" BorderThickness="1"
                                                HorizontalAlignment="Center">
                                            <TextBlock x:Name="step2Icon" Text="👤" FontSize="17"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.35"/>
                                        </Border>
                                        <TextBlock x:Name="step2Lbl" Text="Guest Info"
                                                   Foreground="#5A3E1C" FontSize="10.5" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0" FontFamily="Segoe UI"/>
                                    </StackPanel>

                                    <Border Grid.Column="3" Height="2" Background="#2A1E12"
                                            VerticalAlignment="Center" Margin="0,0,0,20"/>

                                    <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                        <Border x:Name="step3Circle" Width="38" Height="38" CornerRadius="19"
                                                Background="#231A11" BorderBrush="#2A1E12" BorderThickness="1"
                                                HorizontalAlignment="Center">
                                            <TextBlock x:Name="step3Icon" Text="💳" FontSize="17"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.35"/>
                                        </Border>
                                        <TextBlock x:Name="step3Lbl" Text="Payment"
                                                   Foreground="#5A3E1C" FontSize="10.5" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0" FontFamily="Segoe UI"/>
                                    </StackPanel>

                                    <Border Grid.Column="5" Height="2" Background="#2A1E12"
                                            VerticalAlignment="Center" Margin="0,0,0,20"/>

                                    <StackPanel Grid.Column="6" HorizontalAlignment="Center">
                                        <Border x:Name="step4Circle" Width="38" Height="38" CornerRadius="19"
                                                Background="#231A11" BorderBrush="#2A1E12" BorderThickness="1"
                                                HorizontalAlignment="Center">
                                            <TextBlock x:Name="step4Icon" Text="✅" FontSize="17"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.35"/>
                                        </Border>
                                        <TextBlock x:Name="step4Lbl" Text="Confirmation"
                                                   Foreground="#5A3E1C" FontSize="10.5" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0" FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Step Pages -->
                            <Grid Grid.Row="1">

                                <!-- ━━━ STEP 1: ROOM SELECTION ━━━ -->
                                <Grid x:Name="pageStep1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Background="#1C150E" CornerRadius="13"
                                            BorderBrush="#2A1E12" BorderThickness="1"
                                            Padding="20,14" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="CHECK-IN DATE" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                                <DatePicker x:Name="dpCheckIn" Style="{StaticResource DateStyle}"
                                                            SelectedDateChanged="DateFilter_Changed"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="CHECK-OUT DATE" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                                <DatePicker x:Name="dpCheckOut" Style="{StaticResource DateStyle}"
                                                            SelectedDateChanged="DateFilter_Changed"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="ROOM TYPE" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="cmbRoomTypeFilter" Style="{StaticResource ComboStyle}"
                                                          SelectionChanged="RoomTypeFilter_Changed">
                                                    <ComboBoxItem Content="All Types"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <Button Grid.Column="6" Content="↺  Refresh"
                                                    Style="{StaticResource BtnSecondary}"
                                                    Margin="0,24,0,0" Click="BtnRefresh_Click"/>
                                        </Grid>
                                    </Border>

                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <TextBlock x:Name="lblRoomStatus"
                                                       Foreground="#7A6040" FontSize="11.5"
                                                       FontFamily="Segoe UI" Margin="4,0,0,10"/>
                                            <ItemsControl x:Name="icRoomCards">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Width="230" Height="188" CornerRadius="14" Margin="6"
                                                                Cursor="Hand" BorderThickness="1.5"
                                                                BorderBrush="{Binding BorderColor}"
                                                                Background="{Binding BackgroundColor}">
                                                            <Border.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick" Command="{Binding SelectCommand}"/>
                                                            </Border.InputBindings>
                                                            <Grid>
                                                                <Border CornerRadius="14,14,0,0" Height="4"
                                                                        VerticalAlignment="Top"
                                                                        Background="{Binding StatusColor}"/>
                                                                <StackPanel Margin="16,8,16,8" VerticalAlignment="Center">
                                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                                        <TextBlock Text="{Binding RoomNumber}"
                                                                                   Foreground="#F7EFE0" FontSize="24"
                                                                                   FontWeight="Bold" FontFamily="Segoe UI"/>
                                                                        <Border CornerRadius="6" Padding="7,2" Margin="8,5,0,0"
                                                                                Background="{Binding StatusBadgeBg}" VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Status}"
                                                                                       Foreground="{Binding StatusColor}"
                                                                                       FontSize="9.5" FontWeight="Bold"
                                                                                       FontFamily="Segoe UI"/>
                                                                        </Border>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding TypeName}"
                                                                               Foreground="#C4A882" FontSize="12.5"
                                                                               FontFamily="Segoe UI" Margin="0,2,0,0"/>
                                                                    <TextBlock Text="{Binding Description}"
                                                                               Foreground="#7A6040" FontSize="10.5"
                                                                               FontFamily="Segoe UI" TextWrapping="Wrap"
                                                                               Margin="0,3,0,0" MaxHeight="30"/>
                                                                    <Border Height="1" Background="#2A1E12" Margin="0,8"/>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="₱" Foreground="#D4973A"
                                                                                   FontSize="14" FontFamily="Segoe UI"
                                                                                   VerticalAlignment="Bottom" Margin="0,0,1,2"/>
                                                                        <TextBlock Text="{Binding PriceFormatted}"
                                                                                   Foreground="#D4973A" FontSize="20"
                                                                                   FontWeight="Bold" FontFamily="Segoe UI"/>
                                                                        <!-- CHANGED: /night → /3 hrs -->
                                                                        <TextBlock Text="/3 hrs" Foreground="#5A3E1C"
                                                                                   FontSize="11" FontFamily="Segoe UI"
                                                                                   VerticalAlignment="Bottom" Margin="4,0,0,3"/>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding SelectHint}"
                                                                               Foreground="{Binding HintColor}"
                                                                               FontSize="10.5" FontFamily="Segoe UI"
                                                                               Margin="0,4,0,0" FontWeight="SemiBold"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <Border Grid.Row="2" x:Name="selectedRoomBar"
                                            Background="#1C150E" CornerRadius="13" Padding="20,14"
                                            BorderBrush="#D4973A" BorderThickness="1"
                                            Margin="0,10,0,0" Visibility="Collapsed">
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="SELECTED ROOM" Foreground="#7A5514"
                                                           FontSize="9" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                <TextBlock x:Name="lblSelectedRoomSummary"
                                                           Foreground="#F7EFE0" FontSize="13.5"
                                                           FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                                <Button Content="✕  Deselect" Style="{StaticResource BtnSecondary}"
                                                        Width="120" Margin="0,0,10,0" Click="BtnDeselect_Click"/>
                                                <Button Content="Next: Guest Info  →"
                                                        Style="{StaticResource BtnPrimary}"
                                                        Width="190" Click="BtnStep1Next_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- ━━━ STEP 2: GUEST INFO ━━━ -->
                                <Grid x:Name="pageStep2" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <Border Background="#1C150E" CornerRadius="14"
                                                    BorderBrush="#D4973A" BorderThickness="1"
                                                    Padding="26,22" Margin="0,0,0,12">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                                        <Border Width="38" Height="38" CornerRadius="10" Background="#231A11"
                                                                BorderBrush="#3D2C18" BorderThickness="1">
                                                            <TextBlock Text="👤" FontSize="18"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel Margin="13,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock Text="GUEST INFORMATION" Foreground="#D4973A"
                                                                       FontSize="12.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                            <TextBlock Text="Customer identity and contact details"
                                                                       Foreground="#7A5514" FontSize="11" FontFamily="Segoe UI"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition Width="14"/>
                                                            <ColumnDefinition/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="FIRST NAME" Style="{StaticResource FieldLabel}"/>
                                                            <TextBox x:Name="txtFirstName" Style="{StaticResource InputStyle}"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="LAST NAME" Style="{StaticResource FieldLabel}"/>
                                                            <TextBox x:Name="txtLastName" Style="{StaticResource InputStyle}"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Margin="0,4,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition Width="14"/>
                                                            <ColumnDefinition/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="CONTACT NUMBER" Style="{StaticResource FieldLabel}"/>
                                                            <TextBox x:Name="txtContactNumber" Style="{StaticResource InputStyle}"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="EMAIL ADDRESS" Style="{StaticResource FieldLabel}"/>
                                                            <TextBox x:Name="txtEmail" Style="{StaticResource InputStyle}"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Margin="0,4,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition Width="14"/>
                                                            <ColumnDefinition/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="VALID ID TYPE" Style="{StaticResource FieldLabel}"/>
                                                            <ComboBox x:Name="cmbIDType" Style="{StaticResource ComboStyle}">
                                                                <ComboBoxItem Content="Passport"/>
                                                                <ComboBoxItem Content="Driver's License"/>
                                                                <ComboBoxItem Content="SSS ID"/>
                                                                <ComboBoxItem Content="PhilHealth ID"/>
                                                                <ComboBoxItem Content="Voter's ID"/>
                                                                <ComboBoxItem Content="National ID"/>
                                                            </ComboBox>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="ID NUMBER" Style="{StaticResource FieldLabel}"/>
                                                            <TextBox x:Name="txtIDNumber" Style="{StaticResource InputStyle}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <Border Background="#1C150E" CornerRadius="14"
                                                    BorderBrush="#2A1E12" BorderThickness="1"
                                                    Padding="26,22" Margin="0,0,0,12">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                                        <Border Width="38" Height="38" CornerRadius="10" Background="#231A11"
                                                                BorderBrush="#3D2C18" BorderThickness="1">
                                                            <TextBlock Text="🛏️" FontSize="18"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel Margin="13,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock Text="STAY DETAILS" Foreground="#D4973A"
                                                                       FontSize="12.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                            <TextBlock Text="Dates and number of guests"
                                                                       Foreground="#7A5514" FontSize="11" FontFamily="Segoe UI"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition Width="14"/>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition Width="14"/>
                                                            <ColumnDefinition/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="CHECK-IN DATE" Style="{StaticResource FieldLabel}"/>
                                                            <Border Background="#231A11" CornerRadius="9"
                                                                    Padding="13,11" BorderBrush="#2A1E12" BorderThickness="1">
                                                                <TextBlock x:Name="lblCheckInDisplay"
                                                                           Foreground="#F7EFE0" FontSize="13" FontFamily="Segoe UI"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="CHECK-OUT DATE" Style="{StaticResource FieldLabel}"/>
                                                            <Border Background="#231A11" CornerRadius="9"
                                                                    Padding="13,11" BorderBrush="#2A1E12" BorderThickness="1">
                                                                <TextBlock x:Name="lblCheckOutDisplay"
                                                                           Foreground="#F7EFE0" FontSize="13" FontFamily="Segoe UI"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="4">
                                                            <TextBlock Text="NO. OF GUESTS" Style="{StaticResource FieldLabel}"/>
                                                            <ComboBox x:Name="cmbGuests" Style="{StaticResource ComboStyle}">
                                                                <ComboBoxItem Content="1"/>
                                                                <ComboBoxItem Content="2"/>
                                                                <ComboBoxItem Content="3"/>
                                                                <ComboBoxItem Content="4"/>
                                                                <ComboBoxItem Content="5"/>
                                                                <ComboBoxItem Content="6"/>
                                                            </ComboBox>
                                                        </StackPanel>
                                                    </Grid>

                                                    <TextBlock Text="PROCESSED BY (STAFF)" Style="{StaticResource FieldLabel}"/>
                                                    <ComboBox x:Name="cmbStaff" Style="{StaticResource ComboStyle}"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <Grid Grid.Row="1" Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="210"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="← Back"
                                                Style="{StaticResource BtnSecondary}" Click="BtnStep2Back_Click"/>
                                        <Button Grid.Column="2" Content="Next: Payment  →"
                                                Style="{StaticResource BtnPrimary}" Click="BtnStep2Next_Click"/>
                                    </Grid>
                                </Grid>

                                <!-- ━━━ STEP 3: PAYMENT ━━━ -->
                                <Grid x:Name="pageStep3" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="360"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <Border Background="#1C150E" CornerRadius="14"
                                                        BorderBrush="#D4973A" BorderThickness="1"
                                                        Padding="26,22" Margin="0,0,0,12">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                                            <Border Width="38" Height="38" CornerRadius="10" Background="#231A11"
                                                                    BorderBrush="#3D2C18" BorderThickness="1">
                                                                <TextBlock Text="💳" FontSize="18"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <StackPanel Margin="13,0,0,0" VerticalAlignment="Center">
                                                                <TextBlock Text="PAYMENT DETAILS" Foreground="#D4973A"
                                                                           FontSize="12.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                                <TextBlock Text="How the guest will settle the bill"
                                                                           Foreground="#7A5514" FontSize="11" FontFamily="Segoe UI"/>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition Width="14"/>
                                                                <ColumnDefinition/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="PAYMENT METHOD" Style="{StaticResource FieldLabel}"/>
                                                                <ComboBox x:Name="cmbPaymentMethod" Style="{StaticResource ComboStyle}">
                                                                    <ComboBoxItem Content="Cash"/>
                                                                    <ComboBoxItem Content="Credit Card"/>
                                                                    <ComboBoxItem Content="Debit Card"/>
                                                                    <ComboBoxItem Content="GCash"/>
                                                                    <ComboBoxItem Content="Maya"/>
                                                                    <ComboBoxItem Content="Bank Transfer"/>
                                                                </ComboBox>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="REFERENCE NUMBER" Style="{StaticResource FieldLabel}"/>
                                                                <TextBox x:Name="txtPaymentRef" Style="{StaticResource InputStyle}"/>
                                                            </StackPanel>
                                                        </Grid>

                                                        <Grid Margin="0,6,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition Width="14"/>
                                                                <ColumnDefinition/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="DISCOUNT AMOUNT (₱)" Style="{StaticResource FieldLabel}"/>
                                                                <TextBox x:Name="txtDiscount" Style="{StaticResource InputStyle}"
                                                                         Text="0" TextChanged="Discount_Changed"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="AMOUNT PAID (₱)" Style="{StaticResource FieldLabel}"/>
                                                                <TextBox x:Name="txtAmountPaid" Style="{StaticResource InputStyle}"
                                                                         TextChanged="AmountPaid_Changed"/>
                                                            </StackPanel>
                                                        </Grid>

                                                        <Border Background="#141009" CornerRadius="9"
                                                                Padding="16,12" BorderBrush="#2A1E12"
                                                                BorderThickness="1" Margin="0,12,0,0">
                                                            <TextBlock x:Name="lblPaymentStatus"
                                                                       Text="— Enter amount above"
                                                                       Foreground="#5A3E1C"
                                                                       FontSize="12.5" FontFamily="Segoe UI"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>

                                                <Border Background="#1C150E" CornerRadius="14"
                                                        BorderBrush="#2A1E12" BorderThickness="1"
                                                        Padding="26,22">
                                                    <StackPanel>
                                                        <TextBlock Text="ADDITIONAL CHARGES"
                                                                   Foreground="#D4973A" FontSize="12" FontWeight="Bold"
                                                                   FontFamily="Segoe UI" Margin="0,0,0,4"/>
                                                        <TextBlock Text="Optional — add extra services or items to the bill"
                                                                   Foreground="#7A5514" FontSize="10.5"
                                                                   FontFamily="Segoe UI" Margin="0,0,0,14"/>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="2*"/>
                                                                <ColumnDefinition Width="10"/>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition Width="10"/>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition Width="10"/>
                                                                <ColumnDefinition Width="86"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox x:Name="txtItemDesc" Style="{StaticResource InputStyle}"
                                                                     Height="40" Grid.Column="0"/>
                                                            <TextBox x:Name="txtItemQty" Style="{StaticResource InputStyle}"
                                                                     Height="40" Grid.Column="2"/>
                                                            <TextBox x:Name="txtItemPrice" Style="{StaticResource InputStyle}"
                                                                     Height="40" Grid.Column="4"/>
                                                            <Button Grid.Column="6" Content="+ Add"
                                                                    Style="{StaticResource BtnSecondary}"
                                                                    Height="40" Click="AddBillingItem_Click"/>
                                                        </Grid>
                                                        <Grid Margin="2,5,2,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="2*"/>
                                                                <ColumnDefinition Width="10"/>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition Width="10"/>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition Width="96"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="Description" Foreground="#5A3E1C" FontSize="10" FontFamily="Segoe UI"/>
                                                            <TextBlock Grid.Column="2" Text="Qty"         Foreground="#5A3E1C" FontSize="10" FontFamily="Segoe UI"/>
                                                            <TextBlock Grid.Column="4" Text="Unit Price"  Foreground="#5A3E1C" FontSize="10" FontFamily="Segoe UI"/>
                                                        </Grid>
                                                        <ListView x:Name="lvBillingItems" Background="Transparent"
                                                                  BorderThickness="0" Foreground="#F7EFE0"
                                                                  FontFamily="Segoe UI" FontSize="12" MaxHeight="110">
                                                            <ListView.View>
                                                                <GridView>
                                                                    <GridViewColumn Header="Description" Width="190" DisplayMemberBinding="{Binding Description}"/>
                                                                    <GridViewColumn Header="Qty"         Width="55"  DisplayMemberBinding="{Binding Quantity}"/>
                                                                    <GridViewColumn Header="Unit Price"  Width="95"  DisplayMemberBinding="{Binding UnitPrice}"/>
                                                                    <GridViewColumn Header="Subtotal"    Width="95"  DisplayMemberBinding="{Binding Subtotal}"/>
                                                                </GridView>
                                                            </ListView.View>
                                                        </ListView>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <Grid Grid.Row="1" Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="230"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="← Back"
                                                    Style="{StaticResource BtnSecondary}" Click="BtnStep3Back_Click"/>
                                            <Button Grid.Column="2" Content="✔  CONFIRM BOOKING"
                                                    Style="{StaticResource BtnPrimary}" Click="BtnBook_Click"/>
                                        </Grid>
                                    </Grid>

                                    <!-- Billing Summary -->
                                    <Border Grid.Column="2" Background="#1C150E" CornerRadius="14"
                                            BorderBrush="#2A1E12" BorderThickness="1" Padding="22,20">
                                        <StackPanel>
                                            <TextBlock Text="🧾  BOOKING SUMMARY"
                                                       Foreground="#D4973A" FontSize="12" FontWeight="Bold"
                                                       FontFamily="Segoe UI" Margin="0,0,0,18"/>

                                            <Border Background="#141009" CornerRadius="11"
                                                    Padding="16,14" Margin="0,0,0,14"
                                                    BorderBrush="#2A1E12" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock x:Name="summRoomNumber" Foreground="#F7EFE0"
                                                               FontSize="20" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                    <TextBlock x:Name="summRoomType" Foreground="#C4A882"
                                                               FontSize="12.5" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                                                    <TextBlock x:Name="summDates" Foreground="#7A5514"
                                                               FontSize="11" FontFamily="Segoe UI" Margin="0,5,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Background="#141009" CornerRadius="11"
                                                    Padding="16,14" BorderBrush="#2A1E12" BorderThickness="1">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,9">
                                                        <!-- CHANGED label: Rate / 3 hrs -->
                                                        <TextBlock Text="Rate / 3 hrs" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="lblRoomRate" Style="{StaticResource RcptValue}"
                                                                   Foreground="#D4973A"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,9">
                                                        <TextBlock Text="Number of Sessions" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="lblNights" Style="{StaticResource RcptValue}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,9">
                                                        <TextBlock Text="Subtotal"  Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="lblSubtotal" Style="{StaticResource RcptValue}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,9">
                                                        <TextBlock Text="Tax (12%)" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="lblTax"  Style="{StaticResource RcptValue}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,4">
                                                        <TextBlock Text="Discount"     Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="lblDiscount" Style="{StaticResource RcptValue}"
                                                                   Foreground="#F25555"/>
                                                    </Grid>
                                                    <Border Height="1" Background="#2A1E12" Margin="0,10"/>
                                                    <Grid>
                                                        <TextBlock Text="TOTAL DUE"
                                                                   Foreground="#F7EFE0" FontSize="15"
                                                                   FontWeight="Bold" FontFamily="Segoe UI"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="lblTotal" HorizontalAlignment="Right"
                                                                   Foreground="#2DD36F" FontSize="22"
                                                                   FontWeight="Bold" FontFamily="Segoe UI"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- ━━━ STEP 4: CONFIRMATION ━━━ -->
                                <Grid x:Name="pageStep4" Visibility="Collapsed">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel HorizontalAlignment="Center" MaxWidth="720" Margin="0,20,0,20">

                                            <Border Width="88" Height="88" CornerRadius="44"
                                                    Background="#0D2018" HorizontalAlignment="Center"
                                                    BorderBrush="#2DD36F" BorderThickness="2">
                                                <TextBlock Text="✓" Foreground="#2DD36F" FontSize="42"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontFamily="Segoe UI" FontWeight="Bold"/>
                                            </Border>

                                            <TextBlock Text="BOOKING CONFIRMED"
                                                       Foreground="#2DD36F" FontSize="24"
                                                       FontWeight="Bold" FontFamily="Segoe UI"
                                                       HorizontalAlignment="Center" Margin="0,18,0,4"/>
                                            <TextBlock x:Name="lblConfirmSubtitle"
                                                       Text="A confirmation email has been sent to the guest."
                                                       Foreground="#7A5514" FontSize="13"
                                                       FontFamily="Segoe UI" HorizontalAlignment="Center"
                                                       Margin="0,0,0,26"/>

                                            <Border Background="#1C150E" CornerRadius="16"
                                                    BorderBrush="#D4973A" BorderThickness="1" Padding="30,26">
                                                <StackPanel>
                                                    <TextBlock Text="TRANSACTION RECEIPT"
                                                               Foreground="#D4973A" FontSize="11"
                                                               FontWeight="Bold" FontFamily="Segoe UI"
                                                               HorizontalAlignment="Center" Margin="0,0,0,22"/>

                                                    <Border Background="#141009" CornerRadius="10"
                                                            Padding="0,14" Margin="0,0,0,18"
                                                            BorderBrush="#3D2A0A" BorderThickness="1">
                                                        <StackPanel HorizontalAlignment="Center">
                                                            <TextBlock Text="RESERVATION ID"
                                                                       Foreground="#7A5514" FontSize="9.5"
                                                                       FontWeight="Bold" FontFamily="Segoe UI"
                                                                       HorizontalAlignment="Center"/>
                                                            <TextBlock x:Name="rcptResID" Foreground="#D4973A"
                                                                       FontSize="30" FontWeight="Bold"
                                                                       FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Height="1" Background="#2A1E12" Margin="0,0,0,12"/>

                                                    <Grid Margin="0,0,0,10">
                                                        <TextBlock Text="Guest Name" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="rcptGuest" Style="{StaticResource RcptValue}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,10">
                                                        <TextBlock Text="Email" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="rcptEmail" Style="{StaticResource RcptValue}" FontSize="11.5"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,10">
                                                        <TextBlock Text="Room" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="rcptRoom" Style="{StaticResource RcptValue}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,10">
                                                        <TextBlock Text="Check-In" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="rcptCheckIn" Style="{StaticResource RcptValue}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,10">
                                                        <TextBlock Text="Check-Out" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="rcptCheckOut" Style="{StaticResource RcptValue}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,10">
                                                        <!-- CHANGED label: Sessions (3 hrs each) -->
                                                        <TextBlock Text="Sessions (3 hrs each)" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="rcptNights" Style="{StaticResource RcptValue}"/>
                                                    </Grid>

                                                    <Border Height="1" Background="#2A1E12" Margin="0,6,0,12"/>

                                                    <Grid Margin="0,0,0,10">
                                                        <TextBlock Text="Total Due" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="rcptTotal" Style="{StaticResource RcptValue}"
                                                                   Foreground="#2DD36F" FontSize="16"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,10">
                                                        <TextBlock Text="Amount Paid" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="rcptAmountPaid" Style="{StaticResource RcptValue}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,10">
                                                        <TextBlock Text="Payment Status" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="rcptPayStatus"
                                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                                   FontSize="13" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                    </Grid>
                                                    <Grid>
                                                        <TextBlock Text="Payment Date &amp; Time" Style="{StaticResource RcptLabel}"/>
                                                        <TextBlock x:Name="rcptPaymentDate" Style="{StaticResource RcptValue}"
                                                                   Foreground="#C4A882" FontSize="11.5"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <Grid Margin="0,22,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="14"/>
                                                    <ColumnDefinition/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Content="📋  View All Bookings"
                                                        Style="{StaticResource BtnSecondary}"
                                                        Click="BtnViewBookings_Click"/>
                                                <Button Grid.Column="2" Content="＋  New Booking"
                                                        Style="{StaticResource BtnPrimary}"
                                                        Click="BtnNewBookingFromConfirm_Click"/>
                                            </Grid>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>

                            </Grid>
                        </Grid>

                        <!-- ─── PANEL: ACTIVE BOOKINGS ─── -->
                        <Grid x:Name="panelBookings" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#1C150E" CornerRadius="13"
                                    BorderBrush="#2A1E12" BorderThickness="1"
                                    Padding="18,12" Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔎" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBox x:Name="txtSearch" Style="{StaticResource InputStyle}"
                                             Width="340" Height="38" TextChanged="TxtSearch_TextChanged"/>
                                    <TextBlock Text="Search by guest name, reservation ID, or room number"
                                               Foreground="#3D2E1E" FontSize="11" FontFamily="Segoe UI"
                                               VerticalAlignment="Center" Margin="14,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Background="#141009" CornerRadius="9"
                                    Padding="12,9" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="155"/>
                                        <ColumnDefinition Width="68"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="98"/>
                                        <ColumnDefinition Width="98"/>
                                        <ColumnDefinition Width="58"/>
                                        <ColumnDefinition Width="108"/>
                                        <ColumnDefinition Width="95"/>
                                        <ColumnDefinition Width="95"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"  Text="RES. ID"    Foreground="#7A5514" FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Grid.Column="1"  Text="GUEST"      Foreground="#7A5514" FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Grid.Column="2"  Text="ROOM"       Foreground="#7A5514" FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Grid.Column="3"  Text="TYPE"       Foreground="#7A5514" FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Grid.Column="4"  Text="CHECK-IN"   Foreground="#7A5514" FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Grid.Column="5"  Text="CHECK-OUT"  Foreground="#7A5514" FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Grid.Column="6"  Text="PAX"        Foreground="#7A5514" FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Grid.Column="7"  Text="TOTAL"      Foreground="#7A5514" FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Grid.Column="8"  Text="STATUS"     Foreground="#7A5514" FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Grid.Column="9"  Text="PAYMENT"    Foreground="#7A5514" FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Grid.Column="10" Text="PAID AT"    Foreground="#7A5514" FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"/>
                                </Grid>
                            </Border>

                            <ListView x:Name="lvBookings" Grid.Row="2"
                                      Background="Transparent" BorderThickness="0"
                                      Foreground="#F7EFE0" FontFamily="Segoe UI" FontSize="12.5"
                                      SelectionChanged="LvBookings_SelectionChanged">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="" Width="70"   DisplayMemberBinding="{Binding ReservationID}"/>
                                        <GridViewColumn Header="" Width="155"  DisplayMemberBinding="{Binding GuestName}"/>
                                        <GridViewColumn Header="" Width="68"   DisplayMemberBinding="{Binding RoomNumber}"/>
                                        <GridViewColumn Header="" Width="130"  DisplayMemberBinding="{Binding RoomType}"/>
                                        <GridViewColumn Header="" Width="98"   DisplayMemberBinding="{Binding CheckIn}"/>
                                        <GridViewColumn Header="" Width="98"   DisplayMemberBinding="{Binding CheckOut}"/>
                                        <GridViewColumn Header="" Width="58"   DisplayMemberBinding="{Binding Guests}"/>
                                        <GridViewColumn Header="" Width="108"  DisplayMemberBinding="{Binding Total}"/>
                                        <GridViewColumn Header="" Width="95"   DisplayMemberBinding="{Binding Status}"/>
                                        <GridViewColumn Header="" Width="95"   DisplayMemberBinding="{Binding PaymentStatus}"/>
                                        <GridViewColumn Header="" Width="145"  DisplayMemberBinding="{Binding PaymentDate}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>

                        <!-- ─── PANEL: ROOM MAP ─── -->
                        <Grid x:Name="panelRoomMap" Visibility="Collapsed">
                            <Border Background="#1C150E" CornerRadius="14"
                                    BorderBrush="#2A1E12" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="22,16,22,14">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="🗺  FULL ROOM MAP"
                                                       Foreground="#D4973A" FontSize="13.5"
                                                       FontWeight="Bold" FontFamily="Segoe UI"/>
                                            <StackPanel Orientation="Horizontal" Margin="28,0,0,0">
                                                <Ellipse Width="9" Height="9" Fill="#2DD36F" VerticalAlignment="Center"/>
                                                <TextBlock Text="Available" Foreground="#7A6040" FontSize="10.5"
                                                           Margin="5,0,14,0" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                                <Ellipse Width="9" Height="9" Fill="#F25555" VerticalAlignment="Center"/>
                                                <TextBlock Text="Occupied"  Foreground="#7A6040" FontSize="10.5"
                                                           Margin="5,0,14,0" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                                <Ellipse Width="9" Height="9" Fill="#F5A623" VerticalAlignment="Center"/>
                                                <TextBlock Text="Cleaning"  Foreground="#7A6040" FontSize="10.5"
                                                           Margin="5,0,14,0" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                                <Ellipse Width="9" Height="9" Fill="#666666" VerticalAlignment="Center"/>
                                                <TextBlock Text="Maint."    Foreground="#7A6040" FontSize="10.5"
                                                           Margin="5,0,0,0"  FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button Content="⟳  Refresh" HorizontalAlignment="Right"
                                                Style="{StaticResource BtnSecondary}" Width="110"
                                                Click="BtnRefresh_Click"/>
                                    </Grid>

                                    <ScrollViewer Grid.Row="1" Margin="14,0,14,14"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="icRoomsLarge">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="150" Height="118" CornerRadius="13" Margin="6"
                                                            Cursor="Hand" BorderThickness="1"
                                                            BorderBrush="{Binding BorderColor}"
                                                            Background="{Binding BackgroundColor}">
                                                        <Grid>
                                                            <Border CornerRadius="13,13,0,0" Height="4"
                                                                    VerticalAlignment="Top"
                                                                    Background="{Binding StatusColor}"/>
                                                            <StackPanel VerticalAlignment="Center"
                                                                        HorizontalAlignment="Center"
                                                                        Margin="0,5,0,0">
                                                                <TextBlock Text="{Binding RoomNumber}"
                                                                           Foreground="#F7EFE0" FontSize="24"
                                                                           FontWeight="Bold" FontFamily="Segoe UI"
                                                                           HorizontalAlignment="Center"/>
                                                                <TextBlock Text="{Binding TypeName}"
                                                                           Foreground="#C4A882" FontSize="10.5"
                                                                           FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                                                                <!-- CHANGED: /3hrs -->
                                                                <TextBlock Text="{Binding PriceDisplay}"
                                                                           Foreground="#D4973A" FontSize="10.5"
                                                                           FontWeight="SemiBold" FontFamily="Segoe UI"
                                                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                                <Border CornerRadius="6" Padding="7,2" Margin="0,5,0,0"
                                                                        Background="{Binding StatusBadgeBg}">
                                                                    <TextBlock Text="{Binding Status}"
                                                                               Foreground="{Binding StatusColor}"
                                                                               FontSize="9.5" FontWeight="Bold"
                                                                               FontFamily="Segoe UI"
                                                                               HorizontalAlignment="Center"/>
                                                                </Border>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ─── PANEL: EXTEND STAY ─── -->
                        <Grid x:Name="panelExtendStay" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Border Grid.Row="0" Background="#1C150E" CornerRadius="13"
                                    BorderBrush="#D4973A" BorderThickness="1"
                                    Padding="22,16" Margin="0,0,0,12">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="38" Height="38" CornerRadius="10" Background="#231A11"
                                                BorderBrush="#3D2C18" BorderThickness="1">
                                            <TextBlock Text="📅" FontSize="18"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="EXTEND GUEST STAY" Foreground="#D4973A"
                                                       FontSize="13" FontWeight="Bold" FontFamily="Segoe UI"/>
                                            <TextBlock Text="Add more 3-hour sessions to an existing confirmed reservation"
                                                       Foreground="#7A5514" FontSize="11" FontFamily="Segoe UI"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Button Content="← Back to Bookings" HorizontalAlignment="Right"
                                            Style="{StaticResource BtnSecondary}" Width="160"
                                            Click="BtnExtendBack_Click"/>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="380"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left: form -->
                                <Border Grid.Column="0" Background="#1C150E" CornerRadius="14"
                                        BorderBrush="#2A1E12" BorderThickness="1" Padding="26,22">
                                    <StackPanel>
                                        <!-- Current booking info -->
                                        <Border Background="#141009" CornerRadius="10"
                                                Padding="18,14" Margin="0,0,0,20"
                                                BorderBrush="#2A1E12" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="14"/>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="14"/>
                                                    <ColumnDefinition/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="RESERVATION" Foreground="#7A5514" FontSize="9"
                                                               FontWeight="Bold" FontFamily="Segoe UI"/>
                                                    <TextBlock x:Name="extResID" Foreground="#D4973A"
                                                               FontSize="20" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,4,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="GUEST" Foreground="#7A5514" FontSize="9"
                                                               FontWeight="Bold" FontFamily="Segoe UI"/>
                                                    <TextBlock x:Name="extGuestName" Foreground="#F7EFE0"
                                                               FontSize="14" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,4,0,0"/>
                                                    <TextBlock x:Name="extRoomInfo" Foreground="#C4A882"
                                                               FontSize="11" FontFamily="Segoe UI"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="CURRENT CHECK-OUT" Foreground="#7A5514" FontSize="9"
                                                               FontWeight="Bold" FontFamily="Segoe UI"/>
                                                    <TextBlock x:Name="extCurrentCheckOut" Foreground="#F5A623"
                                                               FontSize="14" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="EXTENSION DETAILS" Foreground="#7A5514"
                                                   FontSize="9" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,14"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="ADDITIONAL SESSIONS (3 HRS EACH)" Style="{StaticResource FieldLabel}"/>
                                                <ComboBox x:Name="cmbExtSessions" Style="{StaticResource ComboStyle}"
                                                          SelectionChanged="ExtSessions_Changed">
                                                    <ComboBoxItem Content="1  (3 hrs)"/>
                                                    <ComboBoxItem Content="2  (6 hrs)"/>
                                                    <ComboBoxItem Content="3  (9 hrs)"/>
                                                    <ComboBoxItem Content="4  (12 hrs)"/>
                                                    <ComboBoxItem Content="5  (15 hrs)"/>
                                                    <ComboBoxItem Content="6  (18 hrs)"/>
                                                    <ComboBoxItem Content="7  (21 hrs)"/>
                                                    <ComboBoxItem Content="8  (24 hrs / 1 day)"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="NEW CHECK-OUT DATE" Style="{StaticResource FieldLabel}"/>
                                                <Border Background="#231A11" CornerRadius="9"
                                                        Padding="13,11" BorderBrush="#D4973A" BorderThickness="1" Height="44">
                                                    <TextBlock x:Name="extNewCheckOut" Foreground="#2DD36F"
                                                               FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <Border Height="1" Background="#2A1E12" Margin="0,20,0,20"/>

                                        <TextBlock Text="EXTENSION PAYMENT" Foreground="#7A5514"
                                                   FontSize="9" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,14"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="PAYMENT METHOD" Style="{StaticResource FieldLabel}"/>
                                                <ComboBox x:Name="cmbExtPayMethod" Style="{StaticResource ComboStyle}">
                                                    <ComboBoxItem Content="Cash"/>
                                                    <ComboBoxItem Content="Credit Card"/>
                                                    <ComboBoxItem Content="Debit Card"/>
                                                    <ComboBoxItem Content="GCash"/>
                                                    <ComboBoxItem Content="Maya"/>
                                                    <ComboBoxItem Content="Bank Transfer"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="REFERENCE NUMBER" Style="{StaticResource FieldLabel}"/>
                                                <TextBox x:Name="txtExtPayRef" Style="{StaticResource InputStyle}"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="DISCOUNT FOR EXTENSION (₱)" Style="{StaticResource FieldLabel}"/>
                                                <TextBox x:Name="txtExtDiscount" Style="{StaticResource InputStyle}"
                                                         Text="0" TextChanged="ExtDiscount_Changed"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="AMOUNT PAID FOR EXTENSION (₱)" Style="{StaticResource FieldLabel}"/>
                                                <TextBox x:Name="txtExtAmountPaid" Style="{StaticResource InputStyle}"
                                                         TextChanged="ExtAmountPaid_Changed"/>
                                            </StackPanel>
                                        </Grid>

                                        <Border Background="#141009" CornerRadius="9"
                                                Padding="16,12" BorderBrush="#2A1E12"
                                                BorderThickness="1" Margin="0,12,0,0">
                                            <TextBlock x:Name="lblExtPayStatus"
                                                       Text="— Enter amount above"
                                                       Foreground="#5A3E1C"
                                                       FontSize="12.5" FontFamily="Segoe UI"/>
                                        </Border>

                                        <Button Content="📅  CONFIRM EXTENSION"
                                                Style="{StaticResource BtnPrimary}"
                                                Margin="0,20,0,0" Click="BtnConfirmExtension_Click"/>
                                    </StackPanel>
                                </Border>

                                <!-- Right: extension summary -->
                                <Border Grid.Column="2" Background="#1C150E" CornerRadius="14"
                                        BorderBrush="#2A1E12" BorderThickness="1" Padding="22,20">
                                    <StackPanel>
                                        <TextBlock Text="🧾  EXTENSION SUMMARY"
                                                   Foreground="#D4973A" FontSize="12" FontWeight="Bold"
                                                   FontFamily="Segoe UI" Margin="0,0,0,18"/>

                                        <Border Background="#141009" CornerRadius="11"
                                                Padding="16,14" Margin="0,0,0,14"
                                                BorderBrush="#2A1E12" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock x:Name="extSummRoom" Foreground="#F7EFE0"
                                                           FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                <TextBlock x:Name="extSummType" Foreground="#C4A882"
                                                           FontSize="12" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                                                <TextBlock x:Name="extSummPeriod" Foreground="#7A5514"
                                                           FontSize="11" FontFamily="Segoe UI" Margin="0,5,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Background="#141009" CornerRadius="11"
                                                Padding="16,14" BorderBrush="#2A1E12" BorderThickness="1">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,9">
                                                    <TextBlock Text="Rate / 3 hrs" Style="{StaticResource RcptLabel}"/>
                                                    <TextBlock x:Name="extSummRate" Style="{StaticResource RcptValue}"
                                                               Foreground="#D4973A"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,9">
                                                    <TextBlock Text="Sessions to Add" Style="{StaticResource RcptLabel}"/>
                                                    <TextBlock x:Name="extSummSessions" Style="{StaticResource RcptValue}"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,9">
                                                    <TextBlock Text="Subtotal" Style="{StaticResource RcptLabel}"/>
                                                    <TextBlock x:Name="extSummSubtotal" Style="{StaticResource RcptValue}"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,9">
                                                    <TextBlock Text="Tax (12%)" Style="{StaticResource RcptLabel}"/>
                                                    <TextBlock x:Name="extSummTax" Style="{StaticResource RcptValue}"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,4">
                                                    <TextBlock Text="Discount" Style="{StaticResource RcptLabel}"/>
                                                    <TextBlock x:Name="extSummDiscount" Style="{StaticResource RcptValue}"
                                                               Foreground="#F25555"/>
                                                </Grid>
                                                <Border Height="1" Background="#2A1E12" Margin="0,10"/>
                                                <Grid>
                                                    <TextBlock Text="EXTENSION TOTAL"
                                                               Foreground="#F7EFE0" FontSize="13"
                                                               FontWeight="Bold" FontFamily="Segoe UI"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="extSummTotal" HorizontalAlignment="Right"
                                                               Foreground="#2DD36F" FontSize="22"
                                                               FontWeight="Bold" FontFamily="Segoe UI"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- Info note -->
                                        <Border Background="#0D1A10" CornerRadius="10"
                                                Padding="14,12" Margin="0,14,0,0"
                                                BorderBrush="#1A3020" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="ℹ  HOW EXTENSION WORKS"
                                                           Foreground="#2DD36F" FontSize="10" FontWeight="Bold"
                                                           FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                                <TextBlock TextWrapping="Wrap" Foreground="#5A8060" FontSize="10.5"
                                                           FontFamily="Segoe UI" LineHeight="17">
                                                    Each session = 3 hours of accommodation. The room stays Occupied and the guest's check-out date is pushed forward. A separate billing and payment record is created for the extension.
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
