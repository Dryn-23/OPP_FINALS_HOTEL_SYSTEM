<Window x:Class="OOP_FINALS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OOP_FINALS"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="550"
        Width="800"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown">

    <Border CornerRadius="12">

        <!-- Background Image -->
        <Border.Background>
            <ImageBrush ImageSource="\images\BG.jpg" Stretch="None"/>
        </Border.Background>

        <Border CornerRadius="10"
                BorderThickness="2"
                Opacity="0.95">

            <!-- Border -->
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFA7D82A" Offset="0"/>
                    <GradientStop Color="#DA34AE" Offset="0.75"/>
                    <GradientStop Color="#FF9800E0" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <!-- Background -->
            <Border.Background>
                <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                    <GradientStop Color="Black" Offset="0"/>
                    <GradientStop Color="#FF9E6827" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>

                <!-- ROWS -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!-- TOP BAR -->
                <Grid Grid.Row="0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="25"/>
                        <ColumnDefinition Width="25"/>
                        <ColumnDefinition Width="25"/>
                        <ColumnDefinition Width="5"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="LOG IN"
                               Foreground="DarkGray"
                               FontSize="10"
                               FontFamily="Montserrat"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>

                    <!-- MINIMIZE -->
                    <Button x:Name="btnMinimize"
                            Grid.Column="1"
                            Content="-"
                            Click="btnMinimize_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#28AEED"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontSize" Value="16"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#278BEF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="18" Height="18" CornerRadius="9"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- MAXIMIZE/RESTORE -->
                    <Button x:Name="btnMaximize"
                            Grid.Column="2"
                            Content="□"
                            Click="btnMaximize_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#FF9E6827"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FF7F5915"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="18" Height="18" CornerRadius="9"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- CLOSE -->
                    <Button Grid.Column="3"
                            Content="X"
                            Click="btnClose_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#FFDA8034"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FFC6572D"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="18" Height="18" CornerRadius="9"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- LOGIN FORM -->
                <StackPanel Grid.Row="1"
                            Width="220"
                            Margin="0,35,0,0"
                            Orientation="Vertical">

                    <Image Source="\Images\logonobg.png"
                           Width="100"
                           Height="100"
                           Stretch="Fill"/>

                    <TextBlock Text="JOHNCIS LODGE"
                               Foreground="White"
                               FontSize="25"
                               FontFamily="Montserrat"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="MY DEFINITION OF A GOOD MOTEL IS A PLACE I'D STAY AT"
                               Foreground="LightGray"
                               FontSize="12"
                               FontFamily="Montserrat"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,5,0,0"/>

                    <!-- USERNAME -->
                    <TextBlock Text="Username"
                               Foreground="DarkGray"
                               FontSize="12"
                               Margin="0,35,0,0"/>

                    <TextBox x:Name="txtUser"
                             Height="28"
                             Margin="0,5,0,0"
                             Padding="20,0,0,0"
                             Foreground="White"
                             BorderThickness="0,0,0,2"
                             BorderBrush="DarkGray"
                             VerticalContentAlignment="Center">

                        <TextBox.Background>
                            <ImageBrush ImageSource="\images\user-icon.png"
                                        AlignmentX="Left"
                                        Stretch="None"/>
                        </TextBox.Background>
                    </TextBox>

                    <!-- PASSWORD -->
                    <TextBlock Text="Password"
                               Foreground="DarkGray"
                               FontSize="12"
                               Margin="0,15,0,0"/>

                    <Grid Margin="0,5,0,0">

                        <!-- PASSWORD BOX -->
                        <PasswordBox x:Name="txtPass"
                                     Height="28"
                                     Padding="20,0,40,0"
                                     Foreground="White"
                                     BorderThickness="0,0,0,2"
                                     BorderBrush="DarkGray"
                                     VerticalContentAlignment="Center"
                                     PasswordChanged="txtPass_PasswordChanged">

                            <PasswordBox.Background>
                                <ImageBrush ImageSource="\images\key-icon.png"
                                            AlignmentX="Left"
                                            Stretch="None"/>
                            </PasswordBox.Background>
                        </PasswordBox>

                        <!-- TEXTBOX -->
                        <TextBox x:Name="txtPassVisible"
                                 Height="28"
                                 Padding="20,0,40,0"
                                 Foreground="White"
                                 BorderThickness="0,0,0,2"
                                 BorderBrush="DarkGray"
                                 VerticalContentAlignment="Center"
                                 Visibility="Collapsed"
                                 TextChanged="txtPassVisible_TextChanged">

                            <TextBox.Background>
                                <ImageBrush ImageSource="\images\key-icon.png"
                                            AlignmentX="Left"
                                            Stretch="None"/>
                            </TextBox.Background>
                        </TextBox>

                        <!-- SHOW BUTTON -->
                        <Button Content="👁"
                                Width="30"
                                Height="25"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="White"
                                Click="TogglePassword_Click"/>
                    </Grid>

                    <!-- LOGIN BUTTON -->
                    <Button x:Name="btnLogin"
                            Content="LOG IN"
                            Margin="0,50,0,0"
                            Height="40"
                            Width="150"
                            Click="btnLogin_Click">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#FF7F5915"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#28AEED"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="20"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- FORGOT -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,15,0,0">

                        <TextBlock Text="Forgot Password?"
                                   Foreground="DarkGray"
                                   FontSize="12"/>

                        <TextBlock Text="Reset"
                        Foreground="White"
                        FontSize="12"
                        Cursor="Hand"
                        Margin="8,0,0,0"
                        Background="Transparent"
                        MouseLeftButtonDown="Reset_Click">

                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#28AEED"/>
                                            <Setter Property="TextDecorations" Value="Underline"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>

                        </TextBlock>
                    </StackPanel>

                </StackPanel>

            </Grid>

        </Border>

    </Border>
</Window>