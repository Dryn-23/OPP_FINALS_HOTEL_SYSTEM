<Window x:Class="OOP_FINALS.OTPResetPassword"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OTPResetPassword" Height="550" Width="800"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent" AllowsTransparency="True"
        MouseDown="Window_MouseDown">

    <Border CornerRadius="12">

        <!-- 🔥 SAME BACKGROUND IMAGE -->
        <Border.Background>
            <ImageBrush ImageSource="/Images/BG.jpg" Stretch="Fill"/>
        </Border.Background>

        <!-- MAIN CONTAINER -->
        <Border CornerRadius="10" BorderThickness="2" Opacity="0.95">

            <!-- GRADIENT BORDER -->
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFA7D82A" Offset="0"/>
                    <GradientStop Color="#DA34AE" Offset="0.75"/>
                    <GradientStop Color="#FF9800E0" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <!-- DARK GRADIENT BG -->
            <Border.Background>
                <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                    <GradientStop Color="Black" Offset="0"/>
                    <GradientStop Color="#FF9E6827" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>

                <!-- ROWS -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 🔝 TOP BAR -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="25"/>
                        <ColumnDefinition Width="25"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="RESET PASSWORD"
                               Foreground="DarkGray"
                               FontSize="10"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>

                    <Button Grid.Column="1" Content="-" Click="btnMinimize_Click"/>
                    <Button Grid.Column="2" Content="X" Click="btnClose_Click"/>
                </Grid>

                <!-- 💻 CONTENT -->
                <!-- 💻 CONTENT - EMAIL + OTP ONLY -->
                <StackPanel Grid.Row="1" Width="260" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,60,0,0">

                    <TextBlock Text="RESET PASSWORD" Foreground="White" FontSize="22" HorizontalAlignment="Center"/>
                    <TextBlock Text="Enter your email to receive OTP" Foreground="LightGray" FontSize="12" 
                   TextAlignment="Center" Margin="0,5,0,20"/>

                    <!-- EMAIL -->
                    <TextBlock Text="Email Address" Foreground="DarkGray" FontSize="12"/>
                    <TextBox x:Name="txtEmail" Height="28" Margin="0,5,0,15" Padding="20,0,0,0" 
                 Foreground="White" BorderThickness="0,0,0,2" BorderBrush="DarkGray">
                        <TextBox.Background>
                            <ImageBrush ImageSource="\images\user-icon.png" AlignmentX="Left" Stretch="None"/>
                        </TextBox.Background>
                    </TextBox>

                    <!-- SEND OTP BUTTON -->
                    <Button x:Name="btnSendOtp"
        Content="LOG IN"
        Margin="0,0,0,0"
        Height="40"
        Width="260"
        Click="btnSendOtp_Click">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#FF7F5915"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#28AEED"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="0"
                    Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- OTP INPUT (Hidden initially) -->
                    <PasswordBox x:Name="txtOtp" Height="28" Margin="0,20,0,10" Padding="20,0,0,0" 
                     Foreground="White" BorderThickness="0,0,0,2" BorderBrush="DarkGray" 
                     Visibility="Collapsed">
                        <PasswordBox.Background>
                            <ImageBrush ImageSource="\images\key-icon.png" AlignmentX="Left" Stretch="None"/>
                        </PasswordBox.Background>
                    </PasswordBox>

                    <!-- VERIFY BUTTON (Hidden initially) -->
                    <Button x:Name="btnVerifyOtp"
         Content="VERIFY EMAIL"
         Margin="0,0,0,20"
         Height="40"
         Width="260"
         Visibility="Collapsed" 
         Click="btnVerifyOtp_Click">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#FF7F5915"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#28AEED"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="0"
                     Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- SUCCESS MESSAGE -->
                    <TextBlock x:Name="txtSuccess" Text="✅ Email verified! Opening password reset..." 
                   Foreground="#4CAF50" FontSize="14" HorizontalAlignment="Center" 
                   Visibility="Collapsed" Margin="0,20,0,0"/>

                </StackPanel>

            </Grid>

        </Border>
    </Border>
</Window>