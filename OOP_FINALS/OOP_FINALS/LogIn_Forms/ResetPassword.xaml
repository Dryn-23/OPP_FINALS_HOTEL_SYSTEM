<Window x:Class="OOP_FINALS.ResetPassword"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset Password"
        Height="550"
        Width="800"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown">

    <Border CornerRadius="12">

        <!-- SAME BACKGROUND IMAGE -->
        <Border.Background>
            <ImageBrush ImageSource="\Images\BG.jpg" Stretch="None"/>
        </Border.Background>

        <Border CornerRadius="10"
                BorderThickness="2"
                Opacity="0.95">

            <!-- SAME BORDER -->
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFA7D82A" Offset="0"/>
                    <GradientStop Color="#DA34AE" Offset="0.75"/>
                    <GradientStop Color="#FF9800E0" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <!-- SAME BACKGROUND -->
            <Border.Background>
                <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                    <GradientStop Color="Black" Offset="0"/>
                    <GradientStop Color="#FF9E6827" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>

                <StackPanel Width="220"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">

                    <!-- LOGO -->
                    <Image Source="\Images\logonobg.png"
                           Width="100"
                           Height="100"/>

                    <!-- TITLE -->
                    <TextBlock Text="RESET PASSWORD"
                               Foreground="White"
                               FontSize="22"
                               FontFamily="Montserrat"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,10"/>

                    <!-- USERNAME -->
                    <TextBlock Text="Username"
                               Foreground="DarkGray"
                               FontSize="12"
                               Margin="0,10,0,0"/>

                    <TextBox x:Name="txtUsername"
                             Height="28"
                             Margin="0,5,0,0"
                             Padding="20,0,0,0"
                             Foreground="White"
                             BorderThickness="0,0,0,2"
                             BorderBrush="DarkGray"
                             VerticalContentAlignment="Center">

                        <TextBox.Background>
                            <ImageBrush ImageSource="\Images\user-icon.png"
                                        AlignmentX="Left"
                                        Stretch="None"/>
                        </TextBox.Background>
                    </TextBox>
                    <!-- NEW PASSWORD -->
                    <TextBlock Text="New Password"
           Foreground="DarkGray"
           FontSize="12"
           Margin="0,15,0,0"/>

                    <Grid Margin="0,5,0,0">
                        <!-- PASSWORD BOX -->
                        <PasswordBox x:Name="txtNewPassword"
                 Height="28"
                 Padding="20,0,40,0"
                 Foreground="White"
                 BorderThickness="0,0,0,2"
                 BorderBrush="DarkGray"
                 VerticalContentAlignment="Center"
                 PasswordChanged="txtNewPassword_PasswordChanged">

                            <PasswordBox.Background>
                                <ImageBrush ImageSource="\Images\key-icon.png"
                        AlignmentX="Left"
                        Stretch="None"/>
                            </PasswordBox.Background>
                        </PasswordBox>

                        <!-- TEXTBOX -->
                        <TextBox x:Name="txtNewPasswordVisible"
             Height="28"
             Padding="20,0,40,0"
             Foreground="White"
             BorderThickness="0,0,0,2"
             BorderBrush="DarkGray"
             VerticalContentAlignment="Center"
             Visibility="Collapsed"
             TextChanged="txtNewPasswordVisible_TextChanged">

                            <TextBox.Background>
                                <ImageBrush ImageSource="\Images\key-icon.png"
                        AlignmentX="Left"
                        Stretch="None"/>
                            </TextBox.Background>
                        </TextBox>

                        <!-- SHOW BUTTON -->
                        <Button x:Name="btnToggleNewPassword"
            Content="👁"
            Width="30"
            Height="25"
            HorizontalAlignment="Right"
            Margin="0,2,5,2"
            Background="Transparent"
            BorderThickness="0"
            Foreground="White"
            FontSize="12"
            Click="ToggleNewPassword_Click"/>
                    </Grid>

                    <!-- CONFIRM PASSWORD -->
                    <TextBlock Text="Confirm Password"
           Foreground="DarkGray"
           FontSize="12"
           Margin="0,15,0,0"/>

                    <Grid Margin="0,5,0,0">
                        <!-- PASSWORD BOX -->
                        <PasswordBox x:Name="txtConfirmPassword"
                 Height="28"
                 Padding="20,0,40,0"
                 Foreground="White"
                 BorderThickness="0,0,0,2"
                 BorderBrush="DarkGray"
                 VerticalContentAlignment="Center"
                 PasswordChanged="txtConfirmPassword_PasswordChanged">

                            <PasswordBox.Background>
                                <ImageBrush ImageSource="\Images\key-icon.png"
                        AlignmentX="Left"
                        Stretch="None"/>
                            </PasswordBox.Background>
                        </PasswordBox>

                        <!-- TEXTBOX -->
                        <TextBox x:Name="txtConfirmPasswordVisible"
             Height="28"
             Padding="20,0,40,0"
             Foreground="White"
             BorderThickness="0,0,0,2"
             BorderBrush="DarkGray"
             VerticalContentAlignment="Center"
             Visibility="Collapsed"
             TextChanged="txtConfirmPasswordVisible_TextChanged">

                            <TextBox.Background>
                                <ImageBrush ImageSource="\Images\key-icon.png"
                        AlignmentX="Left"
                        Stretch="None"/>
                            </TextBox.Background>
                        </TextBox>

                        <!-- SHOW BUTTON -->
                        <Button x:Name="btnToggleConfirmPassword"
            Content="👁"
            Width="30"
            Height="25"
            HorizontalAlignment="Right"
            Margin="0,2,5,2"
            Background="Transparent"
            BorderThickness="0"
            Foreground="White"
            FontSize="12"
            Click="ToggleConfirmPassword_Click"/>
                    </Grid>
                    <!-- RESET BUTTON -->
                    <Button x:Name="btnReset"
                            Content="RESET"
                            Height="40"
                            Width="150"
                            Margin="0,40,0,0"
                            Click="btnReset_Click">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#FF7F5915"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#28AEED"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="20"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- BACK TO LOGIN -->
                    <TextBlock Text="Back to Login"
                               Foreground="White"
                               Cursor="Hand"
                               HorizontalAlignment="Center"
                               Margin="0,15,0,0"
                               MouseLeftButtonUp="BackToLogin_Click"/>

                </StackPanel>

            </Grid>

        </Border>

    </Border>
</Window>