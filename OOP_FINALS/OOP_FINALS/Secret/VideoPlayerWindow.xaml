                        Orientation="Horizontal">
                <Button Content="⏸️ Pause" Click="Pause_Click" Margin="5" Padding="15,8" FontSize="16"/>
                <Button Content="▶️ Play" Click="Play_Click" Margin="5" Padding="15,8" FontSize="16"/>
                <Button Content="⏹️ Stop" Click="Stop_Click" Margin="5" Padding="15,8" FontSize="16"/>
            </StackPanel>
        </Border>-->

        <!-- Welcome Text Overlay -->
        <TextBlock Text=" "
                   Foreground="White"
