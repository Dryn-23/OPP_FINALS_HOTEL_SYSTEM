<Page x:Class="OOP_FINALS.StaffPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Background="Transparent">

    <!-- Styles -->
    <Page.Resources>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>

            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform/>
                </Setter.Value>
            </Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Status Style -->
        <Style x:Key="StatusStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="Text" Value="Active">
                    <Setter Property="Foreground" Value="#48BB78"/>
                </Trigger>
                <Trigger Property="Text" Value="Inactive">
                    <Setter Property="Foreground" Value="#F56565"/>
                </Trigger>
                <Trigger Property="Text" Value="Suspended">
                    <Setter Property="Foreground" Value="#ED8936"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
            <Icon:PackIconMaterial Kind="AccountGroup" Width="30" Height="30" Foreground="#FF9E6827" VerticalAlignment="Center"/>
            <TextBlock Foreground="White" Text="Staff Management" FontSize="26" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- SEARCH + ADD -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#F7FAFC" CornerRadius="25" Padding="15" Margin="0,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Icon:PackIconMaterial Kind="Magnify"
                               Width="18"
                               Height="18"
                               Foreground="#A0AEC0"
                               VerticalAlignment="Center"/>

                    <TextBox x:Name="SearchBox"
                 Grid.Column="1"
                 BorderThickness="0"
                 Background="Transparent"
                 Margin="10,0,0,0"
                 FontSize="14"
                 VerticalContentAlignment="Center"
                 Padding="0"
                 TextChanged="SearchBox_TextChanged"/>
                </Grid>
            </Border>

            <Button Grid.Column="1"
                    Content="Add Staff"
                    Style="{StaticResource RoundedButton}"
                    Background="#FF9E6827"
                    Width="140" Height="45"
                    Click="AddStaffBtn_Click"/>
        </Grid>

        <!-- DATAGRID -->
        <DataGrid x:Name="StaffDataGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  GridLinesVisibility="None"
                  RowBackground="White"
                  AlternatingRowBackground="#F8FAFC"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Margin" Value="0,2"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#EDF2F7"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#E2E8F0"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <!-- Name Column -->
                <DataGridTextColumn Header="Name" 
                                   Binding="{Binding Fullname}" 
                                   Width="220">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="12,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="Medium"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Department Column -->
                <DataGridTextColumn Header="Department" 
                                   Binding="{Binding Department}" 
                                   Width="160">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="12,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Username Column -->
                <DataGridTextColumn Header="Username" 
                                   Binding="{Binding Username}" 
                                   Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="12,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Contact Column -->
                <DataGridTextColumn Header="Contact" 
                                   Binding="{Binding ContactNumber}" 
                                   Width="140">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="12,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Email Column -->
                <DataGridTextColumn Header="Email" 
                                   Binding="{Binding Email}" 
                                   Width="200">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="12,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Status Column -->
                <DataGridTemplateColumn Header="Status" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Status}" 
                                     Style="{StaticResource StatusStyle}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Actions Column -->
                <DataGridTemplateColumn Header="Actions" Width="180" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Style="{StaticResource RoundedButton}"
                                        Background="#48BB78"
                                        Width="65" Height="30"
                                        Margin="0,0,6,0"
                                        Click="EditStaff_Click"
                                        Tag="{Binding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Icon:PackIconMaterial Kind="Pencil" Width="12" Margin="0,0,3,0"/>
                                        <TextBlock Text="Edit" FontSize="10"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource RoundedButton}"
                                        Background="#F56565"
                                        Width="65" Height="30"
                                        Click="DeleteStaff_Click"
                                        Tag="{Binding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Icon:PackIconMaterial Kind="Delete" Width="12" Margin="0,0,3,0"/>
                                        <TextBlock Text="Delete" FontSize="10"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>