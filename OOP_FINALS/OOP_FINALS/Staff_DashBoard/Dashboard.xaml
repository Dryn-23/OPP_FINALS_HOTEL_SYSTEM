<Window x:Class="OOP_FINALS.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard"
        Height="600"
        Width="1000"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown">

    <Border CornerRadius="12">

        <!-- BACKGROUND -->
        <Border.Background>
            <ImageBrush ImageSource="\images\BG.jpg" Stretch="Fill"/>
        </Border.Background>

        <Border CornerRadius="10"
                BorderThickness="2"
                Opacity="0.95">

            <!-- BORDER -->
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFA7D82A" Offset="0"/>
                    <GradientStop Color="#DA34AE" Offset="0.75"/>
                    <GradientStop Color="#FF9800E0" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <!-- BG -->
            <Border.Background>
                <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                    <GradientStop Color="Black" Offset="0"/>
                    <GradientStop Color="#FF9E6827" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>

                <!-- ROWS -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!-- 🔵 TOP BAR -->
                <Grid Grid.Row="0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="25"/>
                        <ColumnDefinition Width="25"/>
                        <ColumnDefinition Width="5"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="STAFF DASHBOARD"
                               Foreground="DarkGray"
                               FontSize="10"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"/>

                    <!-- MIN -->
                    <Button Grid.Column="1" Content="-" Click="btnMinimize_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="18" Height="18" CornerRadius="9"
                                        Background="#28AEED">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- CLOSE -->
                    <Button Grid.Column="2" Content="X" Click="btnClose_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="18" Height="18" CornerRadius="9"
                                        Background="#FFDA8034">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- MAIN -->
                <Grid Grid.Row="1">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <!-- 🟣 SIDEBAR -->
                    <StackPanel Background="#22000000">

                        <TextBlock Text="STAFF"
                                   Foreground="White"
                                   FontSize="18"
                                   Margin="20"/>

                        <Button Content="Dashboard" Margin="10"/>
                        <Button Content="Bookings" Margin="10" Click="Bookings_Click"/>
                        <Button Content="Rooms" Margin="10" Click="Rooms_Click"/>
                        <Button Content="Profile" Margin="10" Click="Profile_Click"/>
                        <Button Content="Logout" Margin="10" Click="Logout_Click"/>

                    </StackPanel>

                    <!-- 🟢 CONTENT -->
                    <StackPanel Grid.Column="1" Margin="20">

                        <TextBlock Text="Welcome Staff"
                                   FontSize="24"
                                   Foreground="White"/>

                        <WrapPanel Margin="0,20,0,0">

                            <!-- BOOKINGS -->
                            <Border Width="200" Height="120" Margin="10"
                                    CornerRadius="15" Background="#33000000">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="My Bookings"
                                               Foreground="White"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtMyBookings"
                                               Text="0"
                                               FontSize="28"
                                               Foreground="White"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- AVAILABLE ROOMS -->
                            <Border Width="200" Height="120" Margin="10"
                                    CornerRadius="15" Background="#33000000">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Available Rooms"
                                               Foreground="White"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtRooms"
                                               Text="0"
                                               FontSize="28"
                                               Foreground="White"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                        </WrapPanel>

                    </StackPanel>

                </Grid>

            </Grid>
        </Border>
    </Border>
</Window>